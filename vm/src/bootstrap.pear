 optimize-expr (\ (rec expr)
  (% expr
   value expr
   (add args)
    (: left (rec rec (.left args))
     (: right (rec rec (.right args))
      ()
      (| add (& left left right right))
     )
    )
  ))
 optimize (\ (function)
  (&
   arguments (@arguments function)
   captured (@captured function)
   body (optimize-expr optimize-expr (@body function))))


  blob (@fields (& x 1 y 2)))
 (optimize (\ (a) (@add 2 1)))



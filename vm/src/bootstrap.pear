   (.draw (rec-2 data (.width size) (\ (render data width)
    (% (@kind data)
     int (text (int->string data) int-color)
     string (text data string-color)
     struct
      (row ([]
       (sized-box 10. 10. (text "&" struct-color))
       (column
        (iter->array
         (map-indexed
          (array->iter (@fields data))
          (\ (index field) (:
           name (text (.name field) struct-color)
           (column ([]
            name
            (empty-box 0. 2.)
            (row ([]
             (empty-box 10. 0.)
             (render (.value field) (f- width 10.)))))))))))))
     (enum enum)
      (row ([]
       (sized-box 10. 10. (text "|" enum-color))
       (column ([]
        (text (@variant data) enum-color)
        (empty-box 0. 2.)
        (render (@payload data) (f- width 10.))))))
     array
      (row ([]
       (sized-box 10. 10. (text "[]" array-color))
       (rec-2 (array->list data) 0 (\ (rec items index)
        (% items
         empty (empty-box 0. 0.)
         (more m)
          (column ([]
           (render (.item m) (f- width 10.))
           (empty-box 0. (% (.rest m) empty 0. more 2.))
           (rec (.rest m) (+ index 1)))))))))
     _ (text "..." black))))))))

 parse-many (\ (code) (:
  chars (string->chars-array code)
  char-at (\ (i) (array-get chars i))
  at-end? (\ (i) (= i (array-length chars)))
  is-digit (\ (char)
   (and
    (>= (ascii-char char) (ascii-char "0"))
    (<= (ascii-char char) (ascii-char "9"))))
  is-name (\ (char)
   (and-5
    (!= char "\n")
    (!= char " ")
    (!= char "(")
    (!= char ")")
    (!= char "\"")))
  digit-value (\ (char) (- (ascii-char char) (ascii-char "0")))
  consume-whitespace (\ (start)
   (rec start (\ (rec i)
    (if (at-end? i)
     i
     (if (or (= (char-at i) "\n") (= (char-at i) " "))
      (rec (+ i 1))
      i)))))
  parse-int (\ (start)
   (rec-2 start 0 (\ (rec i num)
    (if (at-end? i)
     (& offset i num num)
     (if (is-digit (char-at i))
      (rec (+ i 1) (+ (* num 10) (digit-value (char-at i))))
      (& offset i num num))))))
  parse-frac (\ (start)
   (rec-3 start 0 0 (\ (rec i frac digits)
    (if (at-end? i)
     (& offset i frac frac digits digits)
     (if (is-digit (char-at i))
      (rec (+ i 1) (+ (* frac 10) (digit-value (char-at i))) (+ digits 1))
      (& offset i frac frac digits digits))))))
  pow10 (\ (k)
   (rec k (\ (rec k)
    (if (= k 0) 1. (f* 10. (rec (- k 1)))))))
  finish-float (\ (start int-part)
   (: r (parse-frac start)
    float-val
     (f+ (int->float int-part) (f/ (int->float (.frac r)) (pow10 (.digits r))))
    (& offset (.offset r) ast (| float float-val))))
  parse-string (\ (start)
   (rec-2 start "" (\ (rec i acc)
    (if (at-end? i)
     (crash "string doesn't end")
     (: c (char-at i)
      (cond
       (= c "\"") (& offset (+ i 1) value acc)
       (= c "\\")
        (if (at-end? (+ i 1))
         (crash "expected escape char")
         (: e (char-at (+ i 1))
          escaped
           (cond
            (= e "\\") "\\"
            (= e "\"") "\""
            (= e "n") "\n"
            else (crash "unknown escape sequence"))
          (rec (+ i 2) (string-concat acc escaped))))
       else (rec (+ i 1) (string-concat acc c))))))))
  parse-name (\ (start)
   (rec-2 start "" (\ (rec i acc)
    (if (at-end? i)
     (& offset i value acc)
     (if (is-name (char-at i))
      (rec (+ i 1) (string-concat acc (char-at i)))
      (& offset i value acc))))))
  parse-rec (\ (mode start)
   (rec-2 mode start (\ (rec mode i)
    (% mode
     (list acc) (:
      e (rec (| expr) i)
      (% e
       none (& offset i items acc)
       (some s) (rec (| list (array-append acc (.ast s))) (.offset s))))
     expr (:
      i (consume-whitespace i)
      (if (at-end? i)
       (| none)
       (: c (char-at i)
        (cond
         (= c ")") (| none)
         (is-digit c) (:
          r (parse-int i)
          j (.offset r)
          (if (at-end? j)
           (| some (& offset j ast (| int (.num r))))
           (if (= (char-at j) ".")
            (: f (finish-float (+ j 1) (.num r))
             (| some (& offset (.offset f) ast (.ast f))))
            (| some (& offset j ast (| int (.num r)))))))
         (= c "\"") (:
          r (parse-string (+ i 1))
          (| some (& offset (.offset r) ast (| string (.value r)))))
         (= c "(") (:
          g (rec (| list ([])) (+ i 1))
          after (consume-whitespace (.offset g))
          (if (at-end? after)
           (crash "expected closing paren")
           (if (= (char-at after) ")")
            (| some (& offset (+ after 1) ast (| group (.items g))))
            (crash "expected closing paren"))))
         else (:
          r (parse-name i)
          (| some (& offset (.offset r) ast (| name (.value r)))))))))))))
  result (parse-rec (| list ([])) 0)
  end (consume-whitespace (.offset result))
  (if (at-end? end) (.items result) (crash "unexpected trailing input"))))
 parse (\ (code) (:
  items (parse-many code)
  (if (= (array-length items) 1)
   (array-get items 0)
   (crash "expected a single expression"))))

 _ (assert (= (parse "42") (| int 42)))
 _ (assert (= (parse "  42  ") (| int 42)))
 _ (assert (= (parse "foo") (| name "foo")))
 _ (assert (= (parse "\"hi\"") (| string "hi")))
 _ (assert (= (parse "1.5") (| float 1.5)))
 _ (assert (= (parse "(a b)") (| group ([] (| name "a") (| name "b")))))
 _ (assert
  (= (parse "(a 7 (b))")
   (| group ([] (| name "a") (| int 7) (| group ([] (| name "b")))))))

 parse-code-block (\ (code) (:
  items (parse-many code)
  count (array-length items)
  (cond
   (= count 0) (| empty)
   (= count 1) (| expr (array-get items 0))
   (= count 2)
    (% (array-get items 0)
     (name n) (| bind (& name n expr (array-get items 1)))
     _ (crash "a code block must start with a name to bind a value"))
   else (crash "a code block has too many expressions"))))

 analyze (\ (node)
  (rec node (\ (analyze node)
   (% node
    (name string) (| name string)
    (group children) (:
     _ (if (= (array-length children) 0) (crash "empty group") nil)
     first (array-get children 0)
     rest (array-skip children 1)
     (% first
      (name name)
       (cond
        (= name ":") (:
         # "rest is a sequence of (name value) binding pairs followed by a
            single body expression, so its length must be odd. We desugar a
            multi-binding let into nested single-binding lets right here."
         _ (if (even? (array-length rest)) (crash "bad let") nil)
         body-index (- (array-length rest) 1)
         (rec 0 (\ (recurse i)
          (if (= i body-index)
           (analyze (array-get rest body-index))
           (| let (&
            name
             (% (array-get rest i)
              (name n) n
              _ (crash "a let binding name must be a name"))
            value (analyze (array-get rest (+ i 1)))
            body (recurse (+ i 2))))))))
        (= name "[]") (| array (iter->array (map (array->iter rest) analyze)))
        (= name "&") (:
         _ (if (even? (array-length rest)) nil (crash "bad struct"))
         fields
          (rec 0 (\ (recurse i)
           (if (= i (array-length rest))
            ([])
            (array-insert
             (recurse (+ i 2))
             0
             (&
              name
               (% (array-get rest i) (name n) n _ (crash "bad struct field"))
              value (analyze (array-get rest (+ i 1))))))))
         (| struct fields))
        (string-starts-with name ".") (:
         _ (if (= (array-length rest) 1) nil (crash "bad field"))
         (| field (&
          of (analyze (array-get rest 0))
          name (| value (string-slice name 1 (string-length name))))))
        (= name "|") (:
         _ (if (= (array-length rest) 0) (crash "bad enum") nil)
         variant (% (array-get rest 0) (name n) n _ (crash "bad enum"))
         payload
          (if (= (array-length rest) 2)
           (analyze (array-get rest 1))
           (| value nil))
         (| enum (& variant variant payload payload)))
        (= name "%") (:
         _ (if (odd? (array-length rest)) nil (crash "bad switch"))
         condition (analyze (array-get rest 0))
         result
          (rec 1 (\ (recurse i)
           (if (= i (array-length rest))
            (& cases ([]) default (| none))
            (:
             body (analyze (array-get rest (+ i 1)))
             after (recurse (+ i 2))
             (% (array-get rest i)
              (name n)
               (if (= n "_")
                (& cases (.cases after) default (| some body))
                (&
                 cases
                  (array-insert
                   (.cases after)
                   0
                   (& variant n payload (| none) body body))
                 default (.default after)))
              (group children) (:
               _
                (if (= (array-length children) 2) nil (crash "bad switch case"))
               variant
                (% (array-get children 0)
                 (name v) v
                 _ (crash "bad switch case variant"))
               payload-name
                (% (array-get children 1)
                 (name p) p
                 _ (crash "bad switch case payload"))
               (&
                cases
                 (array-insert
                  (.cases after)
                  0
                  (& variant variant payload (| some payload-name) body body))
                default (.default after)))
              _ (crash "bad switch case"))))))
         (| switch (&
          condition condition
          cases (.cases result)
          default (.default result))))
        (= name "if") (:
         _ (if (= (array-length rest) 3) nil (crash "bad if"))
         (| switch (&
          condition (analyze (array-get rest 0))
          cases ([]
           (& variant "true" payload (| none) body (analyze (array-get rest 1)))
           (&
            variant "false"
            payload (| none)
            body (analyze (array-get rest 2))))
          default (| some (| crash (| value "if on non-bool"))))))
        (= name "cond") (:
         _ (if (even? (array-length rest)) nil (crash "bad cond"))
         (crash "cond"))
        (= name "\\") (:
         _ (if (= (array-length rest) 2) nil (crash "bad function"))
         arguments
          (% (array-get rest 0)
           (group g)
            (iter->array
             (map
              (array->iter g)
              (\ (arg) (% arg (name n) n _ (crash "bad function")))))
           _ (crash "bad function"))
         body (analyze (array-get rest 1))
         (| function (& arguments arguments body body)))
        else
         (| call (&
          function (analyze first)
          arguments (iter->array (map (array->iter rest) analyze))))
       )
      _
       (| call (&
        function (analyze first)
        arguments (iter->array (map (array->iter rest) analyze))))))
    (int i) (| value i)
    (float f) (| value f)
    (string s) (| value s)))))

 base-env
  (array->list ([]
   (& name "@add" definition (\ (a b) (@add a b)))
   (& name "@subtract" definition (\ (a b) (@subtract a b)))
   (& name "@multiply" definition (\ (a b) (@multiply a b)))
   (& name "@divide" definition (\ (a b) (@divide a b)))
   (& name "@modulo" definition (\ (a b) (@modulo a b)))
   (& name "@shift-left" definition (\ (a b) (@shift-left a b)))
   (& name "@shift-right" definition (\ (a b) (@shift-right a b)))
   (& name "@and" definition (\ (a b) (@and a b)))
   (& name "@or" definition (\ (a b) (@or a b)))
   (& name "@xor" definition (\ (a b) (@xor a b)))
   (& name "@compare" definition (\ (a b) (@compare a b)))
   (& name "@equal?" definition (\ (a b) (@equal? a b)))
   (& name "@kind" definition (\ (a) (@kind a)))
   (& name "@f-add" definition (\ (a b) (@f-add a b)))
   (& name "@f-subtract" definition (\ (a b) (@f-subtract a b)))
   (& name "@f-multiply" definition (\ (a b) (@f-multiply a b)))
   (& name "@f-divide" definition (\ (a b) (@f-divide a b)))
   (& name "@f-compare" definition (\ (a b) (@f-compare a b)))
   (& name "@int->float" definition (\ (a) (@int->float a)))
   (& name "@float->int" definition (\ (a) (@float->int a)))
   (& name "@string->bytes" definition (\ (a) (@string->bytes a)))
   (& name "@bytes->string" definition (\ (a) (@bytes->string a)))
   (& name "@string-get-byte" definition (\ (s i) (@string-get-byte s i)))
   (& name "@string->words" definition (\ (a) (@string->words a)))
   (& name "@words->string" definition (\ (a) (@words->string a)))
   (& name "@string-get-word" definition (\ (s i) (@string-get-word s i)))
   (& name "@struct" definition (\ (a) (@struct a)))
   (& name "@field" definition (\ (of name) (@field of name)))
   (& name "@fields" definition (\ (a) (@fields a)))
   (& name "@enum" definition (\ (variant payload) (@enum variant payload)))
   (& name "@variant" definition (\ (a) (@variant a)))
   (& name "@payload" definition (\ (a) (@payload a)))
   (& name "@array-length" definition (\ (a) (@array-length a)))
   (& name "@array-get" definition (\ (a i) (@array-get a i)))
   (& name "@array->list" definition (\ (a) (@array->list a)))
   (& name "@list->array" definition (\ (a) (@list->array a)))
   (&
    name "@function"
    definition
     (\ (arguments body captured) (@function arguments body captured)))
   (& name "@arguments" definition (\ (a) (@arguments a)))
   (& name "@captured" definition (\ (a) (@captured a)))
   (& name "@body" definition (\ (a) (@body a)))
   (&
    name "@call"
    definition (\ (function arguments) (@call function arguments)))
   (& name "@crash" definition (\ (a) (@crash a)))
   (& name "@collect-garbage" definition (\ (a) (@collect-garbage a)))
   (&
    name "@sandbox"
    definition (\ (limit function) (@sandbox limit function)))))

 names-of-env (\ (env)
  (rec env (\ (recurse env)
   (% env
    empty (| empty)
    (more m) (| more (& item (.name (.item m)) rest (recurse (.rest m))))))))
 name-in-scope? (\ (scope name)
  (rec scope (\ (recurse scope)
   (% scope
    empty false
    (more m) (if (= (.item m) name) true (recurse (.rest m)))))))
 add-to-scope (\ (names scope)
  (rec 0 (\ (recurse i)
   (if (= i (array-length names))
    scope
    (| more (& item (array-get names i) rest (recurse (+ i 1))))))))
 collect-errors (\ (node scope)
  (rec-2 node scope (\ (check node scope)
   (% node
    (value v) (array->iter ([]))
    (name n)
     (if (name-in-scope? scope n)
      (array->iter ([]))
      (array->iter ([] (string-concat "unknown name " n))))
    (error message) (array->iter ([] message))
    (call c)
     (concat
      (check (.function c) scope)
      (concat-all
       (map (array->iter (.arguments c)) (\ (arg) (check arg scope)))))
    (function f) (check (.body f) (add-to-scope (.arguments f) scope))
    (enum e) (check (.payload e) scope)
    (struct fields)
     (concat-all
      (map (array->iter fields) (\ (field) (check (.value field) scope))))
    (array items)
     (concat-all
      (map (array->iter items) (\ (item) (check item scope))))
    (field f) (check (.of f) scope)
    (switch s)
     (concat-3
      (check (.condition s) scope)
      (concat-all (map (array->iter (.cases s)) (\ (case)
       (check (.body case)
        (% (.payload case) (some p) (add-to-scope ([] p) scope) _ scope)))))
      (% (.default s) (some d) (check d scope) _ (array->iter ([]))))
    (let l)
     (concat
      (check (.value l) scope)
      (check (.body l) (add-to-scope ([] (.name l)) scope)))
    _ (array->iter ([]))))))

 env-lookup (\ (env name)
  (rec env (\ (rec env)
   (% env
    empty (crash (string-concat "unknown name " name))
    (more m)
     (if (= (.name (.item m)) name) (.definition (.item m)) (rec (.rest m)))))))
 env-has? (\ (env name)
  (rec env (\ (rec env)
   (% env
    empty false
    (more m) (if (= (.name (.item m)) name) true (rec (.rest m)))))))

 wrap-captured (\ (body names)
  (rec names (\ (wrap names)
   (% names
    empty body
    (more m)
     (| let (&
      name (.item m)
      definition (| field (& of (| name "@captured") name (| value (.item m))))
      body (wrap (.rest m))))))))
 captured-struct (\ (names)
  (| struct
   (iter->array
    (map (list->iter names) (\ (name) (& name name value (| name name)))))))

 compile (\ (node bound env)
  (@function
   ([])
   (rec-2 node bound (\ (compile node bound)
    (% node
     (error message) (| crash (| value message))
     (value v) (| value v)
     (name n)
      (if (name-in-scope? bound n)
       (| name n)
       (if (env-has? env n)
        (| value (env-lookup env n))
        (| crash (| value (string-concat "unknown name " n)))))
     (struct fields)
      (| struct
       (iter->array
        (map
         (array->iter fields)
         (\ (field)
          (& name (.name field) value (compile (.value field) bound))))))
     (field f) (| field (& of (compile (.of f) bound) name (.name f)))
     (enum e)
      (| enum (& variant (.variant e) payload (compile (.payload e) bound)))
     (switch s)
      (| switch (&
       condition (compile (.condition s) bound)
       cases
        (iter->array
         (map (array->iter (.cases s)) (\ (case)
          (&
           variant (.variant case)
           payload (.payload case)
           body
            (compile
             (.body case)
             (% (.payload case)
              (some p) (add-to-scope ([] p) bound)
              _ bound))))))
       default (% (.default s) (some d) (| some (compile d bound)) _ (| none))))
     (array items)
      (| array
       (iter->array (map (array->iter items) (\ (item) (compile item bound)))))
     (function f) (:
      params (.arguments f)
      (| make-function (&
       arguments (| value params)
       body
        (| value
         (wrap-captured (compile (.body f) (add-to-scope params bound)) bound))
       captured (captured-struct bound))))
     (call c)
      (| call (&
       function (compile (.function c) bound)
       arguments
        (iter->array
         (map (array->iter (.arguments c)) (\ (a) (compile a bound))))))
     (let l)
      (| let (&
       name (.name l)
       definition (compile (.value l) bound)
       body (compile (.body l) (add-to-scope ([] (.name l)) bound))))
     (crash c) (| crash (compile c bound))
     _ (crash (| cannot-compile node)))))
   nil))

 compile-fuel 10000000
 run-fuel 10000000
 eval-code (\ (source env)
  (% (@sandbox compile-fuel (\ () (parse-code-block source)))
   (crashed e) (& name (| none) errors ([] e) result (| empty))
   out-of-fuel (& name (| none) errors ([] "timeout") result (| empty))
   (returned block)
    (% block
     empty (& name (| none) errors ([]) result (| empty))
     (expr ast)
      (% (@sandbox compile-fuel (\ () (analyze ast)))
       (crashed e) (& name (| none) errors ([] e) result (| empty))
       out-of-fuel (& name (| none) errors ([] "timeout") result (| empty))
       (returned analyzed)
        (&
         name (| none)
         errors (iter->array (collect-errors analyzed (names-of-env env)))
         result 
          (% (@sandbox run-fuel (compile analyzed (| empty) env))
           (returned value) (| ok value)
           (crashed error) (| error error)
           out-of-fuel (| timeout))))
     (bind b)
      (% (@sandbox compile-fuel (\ () (analyze (.expr b))))
       (crashed e) (& name (| some (.name b)) errors ([] e) result (| empty))
       out-of-fuel
        (& name (| some (.name b)) errors ([] "timeout") result (| empty))
       (returned analyzed)
        (&
         name (| some (.name b))
         errors (iter->array (collect-errors analyzed (names-of-env env)))
         result 
          (% (@sandbox run-fuel (compile analyzed (| empty) env))
           (returned value) (| ok value)
           (crashed error) (| error error)
           out-of-fuel (| timeout)))))))

 _ (assert (= (.result (eval-code "(: x 5 x)" base-env)) (| ok 5)))
 _ (assert
  (= (.result (eval-code "(: a 5 b (@add a 3) b)" base-env)) (| ok 8)))
 _ (assert
  (= (.errors (eval-code "(: x 5 y)" base-env)) ([] "unknown name y")))

 # "A computation cache is a tree mirroring the notebook:
    Cache = (| chapter ([] Cache) entry CacheEntry skip (&)),
      where chapters become chapters, code parts become entries, and other nodes
      get skipped.
    CacheEntry = (& code String evald <result of eval-code>)"
 # "Extend the environment with the binding produced by an eval-code result, if
    any: only named blocks whose body ran successfully add a definition."
 extend-env (\ (env r)
  (% (.name r)
   (some name)
    (% (.result r)
     (ok value) (| more (& item (& name name definition value) rest env))
     _ env)
   _ env))
 join-lines (\ (lines)
  (fold (array->iter lines) "" (\ (acc line)
   (if (= acc "") line (string-concat-3 acc "\n" line)))))

 # "Flatten a cache tree back into the flat linked list of entries in document
    order. Used internally to drive incremental reuse, which only cares about
    the sequence of code-block results, ignoring text/chapter structure."
 flatten-cache (\ (cache)
  (list-reverse
   (rec-2 cache (| empty) (\ (rec node acc)
    (% node
     (chapter children)
      (fold (array->iter children) acc (\ (a child) (rec child a)))
     (entry e) (| more (& item e rest acc))
     _ acc)))))

 # "Incrementally process one code block against the old cache. The state
    carries the current env and the not-yet-consumed tail of the old (flat)
    cache. Returns the updated env, remaining old cache, and the resulting cache
    entry."
 eval-code-incremental (\ (source state) (:
  env (.env state)
  old (.old state)
  prev (% old (more m) (| some (.item m)) _ (| none))
  reuse? (% prev (some e) (= (.code e) source) _ false)
  (if reuse?
   (:
    entry (% prev (some e) e _ (crash "unreachable"))
    (&
     env (extend-env env (.evald entry))
     old (% old (more m) (.rest m) _ (| empty))
     entry entry))
   (:
    r (eval-code source env)
    entry (& code source evald r)
    # "If a definition's result changed, everything after it might reference
       the old value, so clear the cache and re-evaluate the rest."
    cleared?
     (and
      (% (.name r) (some n) true _ false)
      (% prev (some e) (not (= (.result (.evald e)) (.result r))) _ true))
    (&
     env (extend-env env r)
     old (if cleared? (| empty) (% old (more m) (.rest m) _ (| empty)))
     entry entry)))))

 # "Evaluate a notebook, producing a cache tree that mirrors the book: each code
    part becomes (| entry cache-entry), each other part (| skip), and each
    chapter (| chapter array-of-children). The old cache (same tree shape) is
    flattened internally so unchanged code blocks reuse their previous results."
 eval-book (\ (book old-cache) (:
  result
   (rec-3 book base-env (flatten-cache old-cache) (\ (walk node env old)
    (% node
     (chapter chapter) (:
      acc
       (fold
        (array->iter (.parts chapter))
        (& env env old old nodes (| empty))
        (\ (state part) (:
         r (walk part (.env state) (.old state))
         (&
          env (.env r)
          old (.old r)
          nodes (| more (& item (.node r) rest (.nodes state)))))))
      (&
       env (.env acc)
       old (.old acc)
       node (| chapter (list->array (list-reverse (.nodes acc))))))
     (code source) (:
      r (eval-code-incremental source (& env env old old))
      (& env (.env r) old (.old r) node (| entry (.entry r))))
     _ (& env env old old node (| skip)))))
  (.node result)))

 any-to-string (\ (value)
  (rec value (\ (recurse value)
   (% (@kind value)
    int (int->string value)
    float "float"
    string (string-concat-3 "\"" value "\"")
    struct
     (string-concat
      (fold (array->iter (@fields value)) "(&"
       (\ (acc field)
        (string-concat-5
         acc
         " "
         (.name field)
         " "
         (recurse (.value field)))))
      ")")
    enum (:
     variant (@variant value)
     payload (@payload value)
     empty-payload?
      (if (= (@kind payload) (| struct))
       (= (array-length (@fields payload)) 0)
       false)
     (if empty-payload?
      (string-concat-3 "(| " variant ")")
      (string-concat-5 "(| " variant " " (recurse payload) ")")))
    array
     (string-concat
      (fold (array->iter value) "([]"
       (\ (acc item) (string-concat-3 acc " " (recurse item))))
      ")")
    function
     (: args (@arguments value)
      (string-concat-3 "(\\ ("
       (rec 0 (\ (rec i)
        (if (= i (array-length args))
         ""
         (string-concat-3
          (if (= i 0) "" " ")
          (array-get args i)
          (rec (+ i 1))))))
       ") ...)"))))))
 _ (assert (= (any-to-string (& a 1 b 2)) "(& a 1 b 2)"))
 _ (assert (= (any-to-string (& x (| some 3))) "(& x (| some 3))"))
 _ (assert (= (any-to-string (| some 5)) "(| some 5)"))
 _ (assert (= (any-to-string (| empty)) "(| empty)"))
 _ (assert (= (any-to-string ([] 1 2)) "([] 1 2)"))
 _ (assert (= (any-to-string (\ (x y) x)) "(\\ (x y) ...)"))
 _ (assert (= (any-to-string (\ () 0)) "(\\ () ...)"))

 notebook-app (&
  create (\ (book)
   (& book book focus (| at 0) eval (eval-book book (| empty))
      size (& width 0. height 0.)))
  apply (\ (book action) action)
  handle (\ (state event) (:
   enter-focus (\ (node)
    (% node
     new (| text)
     (text string)
      (&
       anchor (string-length string)
       active (string-length string)
       desired-x
        (text-x-offset
         string
         (f- (.width (.size state)) 4.)
         (string-length string)))
     (chapter chapter) (| at-title)
     (code string)
      (&
       anchor (string-length string)
       active (string-length string)
       desired-x (text-x-offset string 100000. (string-length string)))
     _ (crash "what's the focus for entering this node?")
     ))
   (% event
    (new-state s) (& state state action (| none))
    (resize new-size)
     (& state (&
       book (.book state)
       focus (.focus state)
       eval (.eval state)
       size new-size)
      action (| none))
    _ (:
     result
      (rec-2 (.book state) (.focus state) (\ (handle node focus)
       (% node
        new
         (% event
          (pressed-key key)
          (cond
           (key-escape? key) (& node node focus (| yield))
           (key-enter? key) (:
            new-node
             (% focus
              text (| text "")
              chapter (| chapter (& title "" parts ([])))
              code (| code "")
              )
            (& node new-node focus (| here (enter-focus new-node))))
           (key-left? key)
            (&
             node node
             focus
              (| here
               (% focus text (| text) chapter (| text) code (| chapter))))
           (key-right? key)
            (&
             node node
             focus
              (| here
               (% focus text (| chapter) chapter (| code) code (| code))))
           else (& node node focus (| here focus)))
          _ (& node node focus (| here focus)))
        (text string) (:
         is-escape (% event (pressed-key key) (key-escape? key) _ false)
         (if is-escape
          (& node (| text string) focus (| yield))
          (: edited
            (handle-text-edit-with-cursor
             string (f- (.width (.size state)) 4.) focus event)
           (& node (| text (.string edited)) focus (| here (.cursor edited))))))
        (chapter chapter) (:
         title (.title chapter)
         parts (.parts chapter)
         (% focus
          at-title
           (% event
            (pressed-key key)
             (cond
              (key-escape? key) (& node node focus (| yield))
              (key-down? key)
               (&
                node node
                focus (| here (if (= (array-length parts) 0) focus (| at 0))))
              (key-ctrl-n? key)
               (&
                node
                 (| chapter (&
                  title title
                  parts (array-insert parts 0 (| new))))
                focus (| here (| in (& index 0 inner (| text)))))
              else (&
               node
                (| chapter (& title (handle-text-edit title event) parts parts))
               focus (| here (| at-title)))
              )
            char (&
             node
              (| chapter (& title (handle-text-edit title event) parts parts))
             focus (| here (| at-title)))
            )
          (at i)
           (% event
            (pressed-key key)
             (cond
              (key-escape? key) (& node node focus (| yield))
              (key-up? key)
               (&
                node node
                focus (| here (if (= i 0) (| at-title) (| at (- i 1)))))
              (key-down? key)
               (&
                node node
                focus
                 (| here
                  (if (= i (- (array-length parts) 1)) focus (| at (+ i 1)))))
              (key-alt-up? key)
               (if (= i 0)
                (& node node focus (| here focus))
                (&
                 node
                  (| chapter (& title title parts (array-swap parts i (- i 1))))
                 focus (| here (| at (- i 1)))))
              (key-alt-down? key)
               (if (= i (- (array-length parts) 1))
                (& node node focus (| here focus))
                (&
                 node
                  (| chapter (& title title parts (array-swap parts i (+ i 1))))
                 focus (| here (| at (+ i 1)))))
              (key-shift-alt-up? key)
               (if (= i 0)
                (& node node focus (| here focus))
                (% (array-get parts (- i 1))
                 (chapter above) (:
                  block (array-get parts i)
                  new-above
                   (| chapter (&
                    title (.title above)
                    parts
                     (array-insert
                      (.parts above) (array-length (.parts above)) block)))
                  new-parts
                   (array-remove (array-update parts (- i 1) new-above) i)
                  (&
                   node (| chapter (& title title parts new-parts))
                   focus
                    (| here
                     (| in (&
                      index (- i 1)
                      inner (| at (array-length (.parts above))))))))
                 _ (& node node focus (| here focus))))
              (key-shift-alt-down? key)
               (if (= i (- (array-length parts) 1))
                (& node node focus (| here focus))
                (% (array-get parts (+ i 1))
                 (chapter below) (:
                  block (array-get parts i)
                  new-below
                   (| chapter (&
                    title (.title below)
                    parts (array-insert (.parts below) 0 block)))
                  new-parts
                   (array-remove (array-update parts (+ i 1) new-below) i)
                  (&
                   node (| chapter (& title title parts new-parts))
                   focus (| here (| in (& index i inner (| at 0))))))
                 _ (& node node focus (| here focus))))
              (key-shift-alt-left? key)
               (& node node focus (| eject (& index i)))
              (key-enter? key)
               (&
                node node
                focus
                 (| here
                  (| in (& index i inner (enter-focus (array-get parts i))))))
              (key-ctrl-n? key)
               (&
                node
                 (| chapter (&
                  title title
                  parts (array-insert parts (+ i 1) (| new))))
                focus (| here (| in (& index (+ i 1) inner (| text)))))
              (key-backspace? key) (:
               part (array-get parts i)
               deletable
                (% part (chapter c) (= (array-length (.parts c)) 0) _ true)
               (if deletable
                (: new-parts (array-remove parts i)
                 (&
                  node (| chapter (& title title parts new-parts))
                  focus (| here (if (= i 0) (| at-title) (| at (- i 1))))))
                (& node node focus (| here focus))))
              else (& node node focus (| here focus)))
            _ (& node node focus (| here focus)))
          (in f) (:
           index (.index f)
           inner-state (handle (array-get parts index) (.inner f))
           inner-node (.node inner-state)
           inner-focus (.focus inner-state)
           (% inner-focus
            (eject e) (:
             child
              (% inner-node (chapter c) c _ (crash "eject from non-chapter"))
             block (array-get (.parts child) (.index e))
             new-child
              (| chapter (&
               title (.title child)
               parts (array-remove (.parts child) (.index e))))
             (&
              node
               (| chapter (&
                title (.title chapter)
                parts
                 (array-insert
                  (array-update parts index new-child) (+ index 1) block)))
              focus (| here (| at (+ index 1)))))
            _ (&
             node
              (| chapter (&
               title (.title chapter)
               parts (array-update parts index inner-node)))
             focus
              (| here
               (% inner-focus
                yield (| at index)
                (here focus) (| in (& index index inner focus))
                _ (crash "weird inner focus"))))))
          _ (crash "bad chapter focus")))
        (code string) (:
         is-escape (% event (pressed-key key) (key-escape? key) _ false)
         (if is-escape
          (& node (| code string) focus (| yield))
          (: edited (handle-text-edit-with-cursor string 100000. focus event)
           (& node (| code (.string edited)) focus (| here (.cursor edited))))))
        _ (crash "handle node type")
        )))
      (&
       state (&
        book (.node result)
        focus
         (% (.focus result)
          (here f) f
          yield (enter-focus (.node result))
          (eject e) (| at (.index e)))
        eval (eval-book (.node result) (.eval state))
        size (.size state))
       action (| some (.node result)))))))
  render (\ (state) (:
   size (.size state)
   chapter-and-focus
    (rec-2 (.book state) (.focus state) (\ (rec node focus)
     (: chapter (% node (chapter chapter) chapter _ (crash "bad"))
      (% focus
       (in args) (:
        part (array-get (.parts chapter) (.index args))
        (% part
         chapter (rec part (.inner args))
         _ (& chapter chapter focus focus)))
       _ (& chapter chapter focus focus)))))
   chapter (.chapter chapter-and-focus)
   focus (.focus chapter-and-focus)
   current-caches
    (rec-2 (.eval state) (.focus state) (\ (rec cache focus)
     (: caches (% cache (chapter caches) caches _ (crash "bad cache"))
      (% focus
       (in args) (:
        child (array-get caches (.index args))
        (% child
         chapter (rec child (.inner args))
         _ caches))
       _ caches))))
   render-part (\ (part cache width focus)
    (% part
     new
      (padding 2.
       (row ([]
        (maybe-render-cursor
         (% focus outside false (inside f) (% f text true _ false))
         (text "text" blue))
        (empty-box 5. 0.)
        (maybe-render-cursor
         (% focus outside false (inside f) (% f chapter true _ false))
         (text "chapter" blue))
        (empty-box 5. 0.)
        (maybe-render-cursor
         (% focus outside false (inside f) (% f code true _ false))
         (text "code" blue))
        )))
     (text string)
      (padding 2.
       (% focus
        (inside cursor) (editable-text string black cursor (f- width 4.))
        outside (text-wrapped string black (f- width 4.))))
     (chapter chapter) (padding 2. (text (.title chapter) orchard-color))
     (code string) (:
      evald
       (% cache
        (entry e) (.evald e)
        _ (& name (| none) errors ([]) result (| empty)))
      binding? (% (.name evald) (some n) true _ false)
      code-element
       (padding 2.
        (% focus
         (inside cursor) (editable-text string green cursor 100000.)
         outside (text string green)))
      run-element
       (% (.result evald)
        (ok value) (text (any-to-string value) blue)
        (error value) (text (any-to-string value) red)
        timeout (text "timeout" yellow)
        empty (text "" black))
      errors-element (text (join-lines (.errors evald)) red)
      has-errors? (> (array-length (.errors evald)) 0)
      # "For definitions we don't surface the bound value, but we still show
         runtime crashes and timeouts. Plain expressions always show their run."
      show-run?
       (% (.result evald)
        (ok value) (not binding?)
        empty false
        _ true)
      result-element
       (padding 2.
        (if has-errors?
         (if show-run? (column ([] errors-element run-element)) errors-element)
         (if show-run? run-element (text "" black))))
      hide-result? (and (not has-errors?) (not show-run?))
      is-outside (% focus outside true _ false)
      single-line?
       (and
        (f<= (.height code-element) (f+ line-height 4.))
        (f<= (.height result-element) (f+ line-height 4.)))
      fits-inline?
       (f<= (f+ (f+ (.width code-element) 10.) (.width result-element)) width)
      (if hide-result?
       code-element
       (if (and-3 is-outside single-line? fits-inline?)
        (row ([] code-element (empty-box 10. 0.) result-element))
        (column ([] code-element result-element)))))
     _ (colored red (text "unknown part" white))))
   rendered
    (column ([]
     (colored orchard-color
      (sized-box (.width size) (f+ line-height 4.)
       (padding 2. (text (.title chapter) white))))
     (column
      (iter->array
       (map-indexed (array->iter (.parts chapter)) (\ (index part)
        (maybe-render-cursor (% focus (at i) (= i index) _ false)
         (render-part
          part
          (array-get current-caches index)
          (.width size)
          (% focus
           (in args)
            (if (= (.index args) index) (| inside (.inner args)) (| outside))
           _ (| outside))))))))))
   (.draw rendered))))

 overwrite-app (&
  create (\ (state) (&))
  apply (\ (state action)
   (| chapter (&
    title "Orchard"
    parts ([] (| text "Hello, world!") (| text "Example text.")))))
  handle (\ (state event) (& state state action (| some (&))))
  render (\ (state) (| nothing)))

 notebook-app
)


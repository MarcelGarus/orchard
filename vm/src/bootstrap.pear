(:
 # "Nil is used whenever we don't actually want to provide a useful value.
  Functions that only have side-effects (aka they may crash or hang) return nil.
  See the assert function for an example."
 nil (&)

 + (\ (a b) (@add a b))
 - (\ (a b) (@subtract a b))
 * (\ (a b) (@multiply a b))
 / (\ (a b) (@divide a b))
 mod (\ (a b) (@modulo a b))
 << (\ (a b) (@shift-left a b))
 >> (\ (a b) (@shift-right a b))
 bit-and (\ (a b) (@and a b))
 bit-or (\ (a b) (@or a b))
 bit-xor (\ (a b) (@xor a b))
 compare (\ (a b) (@compare a b))

 # "Crashing stuff"
 crash (\ (error) (@crash error))

 (&
  generic-equality (@equal? 2 2)
  kind (@kind "hey")
  variant (@variant (| foo))
  payload (@payload (| bar 2))
  field-access (@field (& x 1 y 2) "x")
  fields (@fields (& x 1 y 2))
  code-reflection (@body (\ (a) (@add a 1)))
  blub (@struct ([] (& name "x" value 5) (& name "y" value 9)))
  blob (@enum "foo" 5)
  flup (@array-get ([] 10 11 12) 1)
  a (@list->array (@array->list ([] 1 2 3)))
))

  fds (@string-get "Hi" 0)


     (and (>= c (ascii-char "A")) (<= c (ascii-char "Z"))))
     (| some (| name (& name char focus (| inside))))
    (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
     (| some (| int (& int (- c (ascii-char "0")) focus (| inside))))
    (= char "|")
     (| some (| enum (& variant "" payload (| none) focus (| in-variant))))
    (= char "[") (| some (| array (& items ([]) focus (| at-start))))
    else (| none))))


  (pixel-glyph "Y" 6 "|MM  MM|MM  MM|MM  MM|MM  MM| MMMM|  MM|  MM|  MM|  MM|")
  (pixel-glyph "Z" 6 "|MMMMMM|    MM|   MM|   MM|  MM| MM| MM|MM|MMMMMM|")
  (pixel-glyph "[" 3 "|MMM|MM|MM|MM|MM|MM|MM|MM|MMM|")
  (pixel-glyph "\\" 5 "|MM|MM| MM| MM| MM|  MM|  MM|  MM|   MM|")
  (pixel-glyph "]" 3 "|MMM| MM| MM| MM| MM| MM| MM| MM|MMM|")
  (pixel-glyph "^" 6 "|  MM| MMMM|MM  MM|")
  (pixel-glyph "_" 6 "|||||||||MMMMMM|")
  (pixel-glyph "`" 2 "|M| M|")
  (pixel-glyph "a" 6 "||| MMMM|M   MM|    MM| MMMMM|MM  MM|MM  MM| MMMMM|")
  (pixel-glyph "b" 6 "|MM|MM|MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|MMMMM|")
  (pixel-glyph "c" 5 "||| MMM|MM  M|MM|MM|MM|MM  M| MMM|")
  (pixel-glyph "d" 6 "|    MM|    MM| MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMMM|")
  (pixel-glyph "e" 6 "||| MMMM|MM  MM|MM  MM|MMMMMM|MM|MM   M| MMMM|")
  (pixel-glyph "f" 5 "|  MMM| MM|MMMM| MM| MM| MM| MM| MM| MM|")
  (pixel-glyph "g" 6 "||| MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMMM|    MM| M  MM|  MMM|")
  (pixel-glyph "h" 6 "|MM|MM|MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|")
  (pixel-glyph "i" 2 "|MM||MM|MM|MM|MM|MM|MM|MM|")
  (pixel-glyph "j" 4 "|  MM||  MM|  MM|  MM|  MM|  MM|  MM|  MM|  MM|MMM|")
  (pixel-glyph "k" 6 "|MM|MM|MM  MM|MM MM|MMMM|MM|MMMM|MM MM|MM  MM|")
  (pixel-glyph "l" 3 "|MM|MM|MM|MM|MM|MM|MM|MM| MM|")
  (pixel-glyph "m" 10 "|||MMMMM MMM|MM  MM  MM|MM  MM  MM|MM  MM  MM|MM  MM  MM|MM  MM  MM|MM  MM  MM|")
  (pixel-glyph "n" 6 "|||MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|")
  (pixel-glyph "o" 6 "||| MMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMM|")
  (pixel-glyph "p" 6 "|||MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|MMMMM|MM|MM|")
  (pixel-glyph "q" 6 "||| MMMMM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMMM|    MM|    MM|")
  (pixel-glyph "r" 5 "|||MM MM|MMMMM|MM|MM|MM|MM|MM|")
  (pixel-glyph "s" 5 "||| MMM|MM  M|MMM| MMM|  MMM|M  MM| MMM|")
  (pixel-glyph "t" 5 "| MM| MM|MMMM| MM| MM| MM| MM| MM|  MM|")
  (pixel-glyph "u" 6 "|||MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMMM|")
  (pixel-glyph "v" 6 "|||MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMM|  MM|")
  (pixel-glyph "w" 10 "|||MM  MM  MM|MM  MM  MM|MM  MM  MM|MM  MM  MM|MM  MM  MM|MM  MM  MM|MMMMMMMM|")
  (pixel-glyph "x" 6 "|||MM  MM|MM  MM|MM  MM|  MM|MM  MM|MM  MM|MM  MM|")
  (pixel-glyph "y" 6 "|||MM  MM|MM  MM|MM  MM|MM  MM|MM  MM|MM  MM| MMMMM|    MM| M  MM|  MMM|")
  (pixel-glyph "z" 6 "|||MMMMMM|    MM|   MM|  MM| MM|MM|MMMMMM|")
  (pixel-glyph "{" 4 "  MM| MM| MM| MM| MM|MM| MM| MM| MM| MM|  MM|")
  (pixel-glyph "|" 2 "MM|MM|MM|MM|MM|MM|MM|MM|MM|MM|MM|")
  (pixel-glyph "{" 4 "MM| MM| MM| MM| MM|  MM| MM| MM| MM| MM|MM|")
  (pixel-glyph "~" 7 "||||  MM  M| M  MM|M  M|")
  default-glyph)
 find-glyph (\ (rec char i)
  (if (= i (array-length glyphs))
   default-glyph
   (: g (array-get glyphs i) (if (= char (.char g)) g (rec rec char (+ i 1))))))
 find-glyph (\ (char)
  (: bytes (@string->bytes char)
   (if (and (= (array-length bytes) 1) (< (array-get bytes 0) 123))
    (: glyph (array-get glyphs (array-get bytes 0))
     _
      (if (= (.char glyph) char)
       nil
       (crash (| bad-glyph (& char char glyph glyph))))
     glyph)
    (find-glyph find-glyph char 0))))
 find-kerning (\ (a b) 1)
 layout-text (\ (text max-width)
  (rec-3 (string->chars-list text) 0 0 (\ (rec chars x y)
   (% chars
    empty (| empty)
    (more m) (:
     char (.item m)
     rest (.rest m)
     glyph (find-glyph char)
     (if (= char "\n")
      (:
       next-x 0
       next-y (+ y line-height)
       (| more (&
        item (& x x y y char char glyph glyph cursor-x next-x cursor-y next-y)
        rest (rec rest next-x next-y))))
      (:
       width (.width glyph)
       kerning (% rest empty 0 (more next) (find-kerning char (.item next)))
       next-x (+ x (+ width kerning))
       next-y y
       next-cursor-x (+ x (- width (/ kerning 2)))
       (| more (&
        item (& x x y y char char glyph glyph cursor-x next-cursor-x cursor-y y)
        rest (rec rest next-x next-y))))))))))
 draw-glyph (\ (glyph color)
  (| all
   (list->array
    (list-map
     (.paths glyph)
     (\ (path) (| fill-path (& path path color color)))))))
 text (\ (string color)
  (:
   layouted (layout-text string 100000)
   draw
    (| all
     (list->array
      (list-map layouted (\ (glyph)
       (| translate (&
        by (& x (.x glyph) y (.y glyph))
        what (draw-glyph (.glyph glyph) color)))))))
   (&
    draw draw
    width
     (list-max
      (list-map layouted (\ (glyph) (+ (.x glyph) (.width (.glyph glyph))))))
    height
     (list-max (list-map layouted (\ (glyph) (+ (.y glyph) line-height)))))))

 no-modifiers? (\ (key)
  (and-3 (not (.control key)) (not (.shift key)) (not (.alt key))))
 ctrl-modifier? (\ (key)
  (and-3 (.control key) (not (.shift key)) (not (.alt key))))
 alt-modifier? (\ (key)
  (and-3 (not (.control key)) (not (.shift key)) (.alt key)))
 shift-modifier? (\ (key)
  (and-3 (not (.control key)) (.shift key) (not (.alt key))))
 ctrl-shift-modifiers? (\ (key)
  (and-3 (.control key) (.shift key) (not (.alt key))))
 key-escape? (\ (key) (and (= (.keycode key) 256) (no-modifiers? key)))
 key-enter? (\ (key) (and (= (.keycode key) 257) (no-modifiers? key)))
 key-backspace? (\ (key) (and (= (.keycode key) 259) (no-modifiers? key)))
 key-delete? (\ (key) (and (= (.keycode key) 261) (no-modifiers? key)))
 key-right? (\ (key) (and (= (.keycode key) 262) (no-modifiers? key)))
 key-left? (\ (key) (and (= (.keycode key) 263) (no-modifiers? key)))
 key-down? (\ (key) (and (= (.keycode key) 264) (no-modifiers? key)))
 key-up? (\ (key) (and (= (.keycode key) 265) (no-modifiers? key)))
 key-start? (\ (key) (and (= (.keycode key) 268) (no-modifiers? key)))
 key-end? (\ (key) (and (= (.keycode key) 269) (no-modifiers? key)))
 key-ctrl-enter? (\ (key) (and (= (.keycode key) 257) (ctrl-modifier? key)))
 key-ctrl-backspace? (\ (key) (and (= (.keycode key) 259) (ctrl-modifier? key)))
 key-ctrl-right? (\ (key) (and (= (.keycode key) 262) (ctrl-modifier? key)))
 key-ctrl-left? (\ (key) (and (= (.keycode key) 263) (ctrl-modifier? key)))
 key-alt-right? (\ (key) (and (= (.keycode key) 262) (alt-modifier? key)))
 key-alt-left? (\ (key) (and (= (.keycode key) 263) (alt-modifier? key)))
 key-alt-down? (\ (key) (and (= (.keycode key) 264) (alt-modifier? key)))
 key-alt-up? (\ (key) (and (= (.keycode key) 265) (alt-modifier? key)))
 key-shift-right? (\ (key) (and (= (.keycode key) 262) (shift-modifier? key)))
 key-shift-left? (\ (key) (and (= (.keycode key) 263) (shift-modifier? key)))
 key-shift-down? (\ (key) (and (= (.keycode key) 264) (shift-modifier? key)))
 key-shift-up? (\ (key) (and (= (.keycode key) 265) (shift-modifier? key)))
 key-shift-start? (\ (key) (and (= (.keycode key) 268) (shift-modifier? key)))
 key-shift-end? (\ (key) (and (= (.keycode key) 269) (shift-modifier? key)))
 key-ctrl-shift-right? (\ (key)
  (and (= (.keycode key) 262) (ctrl-shift-modifiers? key)))
 key-ctrl-shift-left? (\ (key)
  (and (= (.keycode key) 263) (ctrl-shift-modifiers? key)))

 # "Text editing

  A cursor consists of the following state:
   - the anchor position (where a selection started)
   - the active position (where the part controlled by the arrow keys is)
   - the desired x position"

 new-cursor (& anchor 0 active 0 desired-x 0)
 cursor-start (\ (cursor) (min (.anchor cursor) (.active cursor)))
 cursor-end (\ (cursor) (max (.anchor cursor) (.active cursor)))
 cursor-has-selection? (\ (cursor) (!= (.anchor cursor) (.active cursor)))
 cursor-selection (\ (cursor)
  (& start (cursor-start cursor) end (cursor-end cursor)))

 text-x-offset (\ (string width offset)
  (if (= offset 0) 0 (.x (list-get (layout-text string width) (- offset 1)))))
 list-indexed (\ (list)
  (rec-2 list 0 (\ (rec list i)
   (% list
    empty (| empty)
    (more m)
     (| more (&
      item (& index i glyph (.item m))
      rest (rec (.rest m) (+ i 1))))))))
 pick-closer (\ (x a b)
  (:
   ga (.glyph a)
   gb (.glyph b)
   dist-a (abs (- (.x ga) x))
   dist-b (abs (- (.x gb) x))
   (if (< dist-a dist-b) a b)))
 find-offset-above (\ (x y glyphs)
  (:
   indexed (list-indexed glyphs)
   before (list-take-while indexed (\ (ig) (< (.y (.glyph ig)) y)))
   (% before
    empty (| none)
    more
     (| some
      (.index
       (list-reduce before (\ (a b)
        (if (< (.y (.glyph a)) (.y (.glyph b)))
         b
         (pick-closer x a b)))))))))
 find-offset-below (\ (x y glyphs)
  (:
   indexed (list-indexed glyphs)
   after (list-skip-while indexed (\ (ig) (<= (.y (.glyph ig)) y)))
   (% after
    empty (| none)
    more
     (| some
      (.index
       (list-reduce after (\ (a b)
        (if (< (.y (.glyph a)) (.y (.glyph b)))
         a
         (pick-closer x a b)))))))))
 find-line-start (\ (chars offset)
  (rec offset (\ (rec candidate)
   (cond
    (= candidate 0) 0
    (= (array-get chars (- candidate 1)) "\n") candidate
    else (rec (- candidate 1))))))
 find-line-end (\ (chars offset)
  (rec offset (\ (rec candidate)
   (cond
    (= candidate (array-length chars)) (array-length chars)
    (= (array-get chars candidate) "\n") candidate
    else (rec (+ candidate 1))))))

 word-char? (\ (char)
  (: c (ascii-char char)
   (or-4
    (= char "_")
    (and (>= c (ascii-char "a")) (<= c (ascii-char "z")))
    (and (>= c (ascii-char "A")) (<= c (ascii-char "Z")))
    (and (>= c (ascii-char "0")) (<= c (ascii-char "9"))))))
 punctuation-char? (\ (char) (and (!= char " ") (not (word-char? char))))
 num-leading-word-chars (\ (chars-list)
  (rec chars-list (\ (rec chars)
   (% chars
    empty 0
    (more m) (if (word-char? (.item m)) (+ 1 (rec (.rest m))) 0)))))
 num-leading-punctuation-chars (\ (chars-list)
  (rec chars-list (\ (rec chars)
   (% chars
    empty 0
    (more m) (if (punctuation-char? (.item m)) (+ 1 (rec (.rest m))) 0)))))
 
 # "Skipping (moving ctrl + left/right) =
    1. Skip spaces
    2. How many characters of punctuation follow?
       0: Skip all letters
       1: Skip the punctuation, then all letters after it
       2: Skip all punctuation"
 num-leading-skip-chars (\ (chars-list)
  (rec chars-list (\ (rec chars)
   (% chars
    empty 0
    (more m) (:
     char (.item m)
     rest (.rest m)
     (cond
      (= char " ") (+ (rec rest) 1)
      (word-char? char) (num-leading-word-chars chars)
      else
       (% rest
        empty 1
        (more next-m)
         (if (punctuation-char? (.item next-m))
          (num-leading-punctuation-chars chars)
          (+ (num-leading-word-chars (.rest next-m)) 1)))))))))
 find-word-boundary-after (\ (string offset)
  (+
   offset
   (num-leading-skip-chars
    (list-skip (array->list (string->bytes string)) offset))))
 find-word-boundary-before (\ (string offset)
  (-
   offset
   (num-leading-skip-chars
    (list-take-and-reverse (array->list (string->bytes string)) offset))))

 handle-text-edit-with-cursor (\ (string width cursor event)
  (% event
   (pressed-key key)
    (cond
     (key-enter? key) (:
      new-string (string-replace-range string (cursor-selection cursor) "\n")
      new-offset (+ (cursor-start cursor) 1)
      (&
       string new-string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset new-string width new-offset))))
     (key-ctrl-enter? key) (:
      line-end (find-line-end string (.active cursor))
      new-string (string-insert string line-end "\n")
      new-offset (+ line-end 1)
      (&
       string new-string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset new-string width new-offset))))
     (key-backspace? key)
      (if (cursor-has-selection? cursor)
       (: offset (cursor-start cursor)
        (&
         string (string-remove-range string (cursor-start cursor) (cursor-end cursor))
         cursor (&
          anchor offset
          active offset
          desired-x (text-x-offset string width offset))))
       (: offset (.active cursor)
        (if (= offset 0)
         (& string string cursor cursor)
         (&
          string (string-remove string (- offset 1))
          cursor (&
           anchor (- offset 1)
           active (- offset 1)
           desired-x (text-x-offset string width (- offset 1)))))))
     (key-ctrl-backspace? key)
      (if (cursor-has-selection? cursor)
       (: offset (cursor-start cursor)
        (&
         string (string-remove-range string (cursor-start cursor) (cursor-end cursor))
         cursor (&
          anchor offset
          active offset
          desired-x (text-x-offset string width offset))))
       (:
        offset (.active cursor)
        new-offset (find-word-boundary-before string offset)
        (&
         string (string-remove-range string new-offset offset)
         cursor (&
          anchor new-offset
          active new-offset
          desired-x (text-x-offset string width new-offset)))))
     (key-delete? key)
      (if (cursor-has-selection? cursor)
       (: offset (cursor-start cursor)
        (&
         string (string-remove-range string (cursor-start cursor) (cursor-end cursor))
         cursor
          (&
           anchor offset
           active offset
           desired-x (text-x-offset string width offset))))
       (: offset (cursor-start cursor)
        (if (= offset (string-length string))
         (& string string cursor cursor)
         (& string (string-remove string offset) cursor cursor))))
     (key-right? key) (:
      new-offset
       (if (cursor-has-selection? cursor)
        (cursor-end cursor)
        (min (string-length string) (+ (.anchor cursor) 1)))
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-shift-right? key) (:
      offset (.active cursor)
      (if (= offset (string-length text))
       (& string string cursor cursor)
       (&
        string string
        cursor (&
         anchor (.anchor cursor)
         active (+ offset 1)
         desired-x (text-x-offset string width (+ offset 1))))))
     (key-ctrl-right? key) (:
      new-offset (find-word-boundary-after string (.active cursor))
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-ctrl-shift-right? key) (:
      new-offset (find-word-boundary-after string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-left? key) (:
      new-offset
       (if (cursor-has-selection? cursor)
        (cursor-start cursor)
        (max 0 (- (.anchor cursor) 1)))
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-shift-left? key) (:
      offset (.active cursor)
      (if (= offset 0)
       (& string string cursor cursor)
       (&
        string string
        cursor (&
         anchor (.anchor cursor)
         active (- offset 1)
         desired-x (text-x-offset string width (- offset 1))))))
     (key-ctrl-left? key) (:
      new-offset (find-word-boundary-before (.active cursor) text)
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-ctrl-shift-left? key) (:
      new-offset (find-word-boundary-before string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-down? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-below cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none 0 (some v) v)
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x cursor-desired-x)))
     (key-alt-down? key) (:
      start (find-line-start string (cursor-start cursor))
      end (find-line-end string (cursor-end cursor))
      (if (= end (string-length string))
       (& string string cursor cursor)
       (:
        next-line-end (find-line-end string (+ end 1))
        bytes (array->list (string->bytes string))
        a (list-slice bytes 0 start)
        b (list-slice bytes start end)
        c (list-slice bytes (+ end 1) next-line-end)
        d (list-skip bytes next-line-end)
        (&
         string
          (bytes->string
           (list->array
            (list-concat
             a
             (list-concat
              c
              (list-concat
               (| more (& item 10 rest (| empty)))
               (list-concat b d))))))
         cursor (&
          anchor (+ (.anchor cursor) (+ (list-length c) 1))
          active (+ (.active cursor) (+ (list-length c) 1))
          desired-x (.desired-x cursor))))))
     (key-shift-down? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-below cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none (string-length text) (some v) v)
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x cursor-desired-x)))
     (key-up? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-above cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none 0 (some v) v)
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x cursor-desired-x)))
     (key-alt-up? key) (:
      start (find-line-start string (cursor-start cursor))
      end (find-line-end string (cursor-end cursor))
      (if (= start 0)
       (& string string cursor cursor)
       (:
        previous-line-start (find-line-start string (- start 1))
        bytes (array->list (string->bytes string))
        a (list-slice bytes 0 previous-line-start)
        b (list-slice bytes previous-line-start (- start 1))
        c (list-slice bytes start end)
        d (list-skip bytes end)
        (&
         string
          (bytes->string
           (list->array
            (list-concat
             a
             (list-concat
              c
              (list-concat
               (| more (& item 10 rest (| empty)))
               (list-concat b d))))))
         cursor (&
          anchor (+ (.anchor cursor) (+ (list-length c) 1))
          active (+ (.active cursor) (+ (list-length c) 1))
          desired-x (.desired-x cursor))))))
     (key-shift-up? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-above cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none (string-length text) (some v) v)
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x cursor-desired-x)))
     (key-start? key) (:
      line-start (find-line-start string (.active cursor))
      (&
       string string
       cursor (&
        anchor line-start
        active line-start
        desired-x (text-x-offset string width line-start))))
     (key-shift-start? key) (:
      line-start (find-line-start string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active line-start
        desired-x (text-x-offset string width line-start))))
     (key-end? key) (:
      line-end (find-line-end string (.active cursor))
      (&
       string string
       cursor (&
        anchor line-end
        active line-end
        desired-x (text-x-offset string width line-end))))
     (key-shift-end? key) (:
      line-end (find-line-end string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active line-end
        desired-x (text-x-offset string width line-end))))
     else (& string string cursor cursor))
   (char char)
    (:
     c (ascii-char char)
    (if
     (or
      (= c 10)
      (and (>= c 32) (<= c 126)))
     (:
      new-string (string-replace-range string (cursor-selection cursor) char)
      new-offset (+ (cursor-start cursor) 1)
      (&
       string new-string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset new-string width new-offset))))
     (& string string cursor cursor)))))

 handle-text-edit (\ (string event)
  (% event
   (pressed-key key)
    (cond
     (key-backspace? key)
      (if (> (string-length string) 0)
       (string-slice string 0 (- (string-length string) 1))
       string)
     (key-enter? key) (string-concat string "\n")
     else string)
   (char char) (string-concat string char)))

 cursor-color yellow

 draw-cursor (\ (cursor width layouted-text)
  (if (cursor-has-selection? cursor)
   (:
    start (cursor-start cursor)
    end (cursor-end cursor)
    start-position
     (if (= start 0)
      (point 0 0)
      (: layout (list-get layouted-text (- start 1))
       (point (.x layout) (.y layout))))
    end-position
     (: layout (list-get layouted-text (- end 1))
      (point (.x layout) (.y layout)))
    start-x (.x start-position)
    start-y (.y start-position)
    end-x (.x end-position)
    end-y (.y end-position)
    (if (= start-y end-y)
     (| fill-path (&
      path ([]
       (| move-to start-position)
       (| line-to (point (.x end-position) start-y))
       (| line-to (point (.x end-position) (+ start-y line-height)))
       (| line-to (point (.x start-position) (+ start-y line-height))))
      color cursor-color))
     (| fill-path (&
      path ([]
       (| move-to start-position)
       (| line-to (point width start-y))
       (| line-to (point width end-y))
       (| line-to end-position)
       (| line-to (point end-x (+ end-y line-height)))
       (| line-to (point 0 (+ end-y line-height)))
       (| line-to (point 0 (+ start-y line-height)))
       (| line-to (point start-x (+ start-y line-height))))
      color cursor-color))))
   (:
    offset (.anchor cursor)
    position (if (= offset 0) (point 0 0) (list-get layouted-text (- offset 1)))
    x (.x position)
    y (.y position)
    (| fill-path (&
     path ([]
      (| move-to (point x y))
      (| line-to (point (+ x 2) y))
      (| line-to (point (+ x 2) (+ y line-height)))
      (| line-to (point x (+ y line-height))))
     color cursor-color)))))

 maybe-render-cursor (\ (enabled node)
  (if enabled (colored cursor-color node) node))
 maybe-render-parenthesized (\ (enabled color child)
  (if enabled
   (row ([]
    (text "(" color)
    (empty-box 1 0)
    child
    (empty-box 1 0)
    (text ")" color)))
   child))

 new-root (\ (child) (| root (& child child focus (| here))))
 root-handle (\ (code-focus code-handle state event)
  (% (.focus state)
   here
    (% event
     (pressed-key key)
      (cond
       (key-down? key)
        (| update
         (| root (& child (code-focus (.child state)) focus (| inside))))
       else (| no-change))
     char (| no-change))
   inside
    (% (code-handle (.child state))
     no-change (| no-change)
     (update child) (| update (| root (& child child focus (| inside))))
     (yield-focus child) (| update (| root (& child child focus (| here)))))))
 root-render-singleline (\ (code-render-singleline state space-allowed)
  (maybe-render-cursor (% (.focus state) here true inside false)
   (code-render-singleline (.child state) space-allowed)))
 root-render (\ (code-render state width)
  (maybe-render-cursor (% (.focus state) here true inside false)
   (code-render (.child state) width)))

 new-code-node-from-char (\ (char)
  (:
   c (ascii-char char)
   (cond
    (or
     (and (>= c (ascii-char "a")) (<= c (ascii-char "z")))
     (and (>= c (ascii-char "A")) (<= c (ascii-char "Z"))))
     (| some (| name (& name char focus (| inside))))
    (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
     (| some (| int (& int (- c (ascii-char "0")) focus (| inside))))
    (= char "|")
     (| some (| enum (& variant "" payload (| none) focus (| in-variant))))
    (= char "[") (| some (| array (& items ([]) focus (| at-start))))
    else (| none))))

 new-int (\ (int) (| int (& int int focus (| outside))))
 int-focus (\ (state) (| int (& int (.int state) focus (| inside))))
 int-handle (\ (state event)
  (% (.focus state)
   outside (| no-change)
   inside (:
    int (.int state)
    (% event
     (pressed-key key)
      (cond
       (key-up? key) (| yield-focus (| int (& int int focus (| outside))))
       (key-backspace? key)
        (| update (| int (& int (/ int 10) focus (| inside))))
       else (| no-change))
     (char char) (:
      c (ascii-char char)
      (cond
       (= char " ") (| yield-focus (| int (& int int focus (| outside))))
       (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
        (| update
         (| int (& int (+ (* int 10) (- c (ascii-char "0"))) focus (| inside))))
       else (| no-change)))))))
 int-render-singleline (\ (state)
  (text
   (int->string (.int state))
   (% (.focus state) outside blue inside cursor-color)))
 int-render (\ (state) (int-render-singleline state))

 new-name (\ (name) (| name (& name name focus (| outside))))
 name-focus (\ (state) (| name (& name (.name state) focus (| inside))))
 name-handle (\ (state event)
  (% (.focus state)
   outside (| no-change)
   inside (:
    name (.name state)
    (% event
     (pressed-key key)
      (cond
       (key-up? key) (| yield-focus (| name (& name name focus (| outside))))
       else
        (| update
         (| name (& name (handle-text-edit name event) focus (| inside)))))
     (char char)
      (if (= char " ")
       (| yield-focus (| name (& name name focus (| outside))))
       (| update
        (| name (& name (handle-text-edit name event) focus (| inside)))))))))
 name-render-singleline (\ (state)
  (text (.name state) (% (.focus state) outside black inside cursor-color)))
 name-render (\ (state) (name-render-singleline state))

 new-enum (\ (variant payload)
  (| enum (& variant variant payload payload focus (| outside))))
 enum-focus (\ (state)
  (| enum
   (& variant (.variant state) payload (.payload state) focus (| at-variant))))
 enum-handle (\ (code-focus code-handle state event)
  (:
   variant (.variant state)
   payload (.payload state)
   focus (.focus state)
   (% focus
    outside (| no-change)
    at-variant
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus
          (| enum (& variant variant payload payload focus (| outside))))
        (key-down? key)
         (| update
          (| enum (& variant variant payload payload focus (| in-variant))))
        (key-right? key)
         (| update
          (| enum (& variant variant payload payload focus (| at-payload))))
        else (| no-change))
      (char char)
       (% payload
        some (| no-change)
        none 
         (% (new-code-node-from-char char)
          (some node)
           (| update
            (| enum
             (& variant variant payload (| some node) focus (| in-payload))))
          none (| no-change))))
    in-variant
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| update
          (| enum (& variant variant payload payload focus (| at-variant))))
        else
         (| update
          (| enum (&
           variant (handle-text-edit variant event)
           payload payload
           focus (| in-variant)))))
      char
       (| update
        (| enum (&
         variant (handle-text-edit variant event)
         payload payload
         focus (| in-variant)))))
    at-payload
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus
          (| enum (& variant variant payload payload focus (| outside))))
        (key-down? key)
         (| update
          (| enum (&
           variant variant
           payload (| some (code-focus (% payload (some p) p)))
           focus (| in-payload))))
        (key-left? key)
         (| update
          (| enum (& variant variant payload payload focus (| at-variant))))
        (key-backspace? key)
         (| update
          (| enum (& variant variant payload (| none) focus (| at-variant))))
        else (| no-change))
      (char char) (| no-change))
    in-payload
     (% (code-handle (% payload (some p) p))
      no-change (| no-change)
      (update new-payload)
       (| update
        (| enum (& variant variant payload (| some new-payload) focus focus)))
      (yield-focus new-payload)
       (| update
        (| enum
         (&
          variant variant
          payload (| some new-payload)
          focus (| at-payload))))))))
 enum-color purple
 enum-render-singleline (\ (code-render-singleline state space-allowed)
  (maybe-render-parenthesized (not space-allowed) enum-color
   (row ([]
    (text "|" enum-color)
    (empty-box 5 0)
    (maybe-render-cursor (% (.focus state) at-variant true _ false)
     (text (.variant state) enum-color))
    (% (.payload state)
     (some payload)
      (row ([]
       (empty-box 5 0)
       (maybe-render-cursor (% (.focus state) at-payload true _ false)
        (code-render-singleline payload false))))
     none (empty-box 0 0))))))
 enum-render (\ (code-render state width)
  (% (.payload state)
   none
    (row ([]
     (sized-box 10 10 (text "|" enum-color))
     (maybe-render-cursor (% (.focus state) at-variant true _ false)
      (text (.variant state) enum-color))))
   (some payload)
    (row ([]
     (sized-box 10 10 (text "|" enum-color))
     (column ([]
      (maybe-render-cursor (% (.focus state) at-variant true _ false)
       (text (.variant state) enum-color))
      (empty-box 0 2)
      (maybe-render-cursor (% (.focus state) at-payload true _ false)
       (code-render payload (- width 10)))))))))

 new-struct (\ (fields) (| struct (& fields fields focus (| outside))))
 struct-focus (\ (state)
  (| struct (&
   fields (.fields state)
   focus (if (= (array-length (.fields state)) 0) (| at-start) (| at-name 0)))))
 struct-handle (\ (code-focus code-handle state event)
  (:
   fields (.fields state)
   focus (.focus state)
   (% focus
    outside (| no-change)
    at-start
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus (| struct (& fields fields focus (| outside))))
        (key-right? key)
         (if (= (array-length fields) 0)
          (| no-change)
          (| update (| struct (& fields fields focus (| at-name 0)))))
        else (| no-change))
      (char char) (:
       new-field (&
        name (bytes->string ([] char))
        value (| int (& int 1 focus (| outside))))
       (| update
        (| struct (&
         fields (array-insert fields 0 new-field)
         focus (| in-name 0))))))
    (at-name index)
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus (| struct (& fields fields focus (| outside))))
        (key-left? key)
         (if (= index 0)
          (| update (| struct (& fields fields focus (| at-start))))
          (| update
           (| struct (& fields fields focus (| at-value (- index 1))))))
        (key-right? key)
         (| update (| struct (& fields fields focus (| at-value index))))
        (key-down? key)
         (| update (| struct (& fields fields focus (| in-name index))))
        (key-backspace? key)
         (| update
          (| struct
           (&
            fields (array-remove fields index)
            focus (if (= index 0) (| at-start) (| at-value (- index 1))))))
        (key-delete? key)
         (| update
          (| struct
           (&
            fields (array-remove fields index)
            focus
             (if (= index (- (array-length fields) 1))
              (if (= index 0) (| at-start) (| at-value (- index 1)))
              (| at-name index)))))
        else (| no-change))
      (char char) (| no-change))
    (in-name index)
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| update (| struct (& fields fields focus (| at-name index))))
        else (:
         field (array-get fields index)
         new-field (&
          name (handle-text-edit (.name field) event)
          value (.value field))
         (| update
          (| struct (&
           fields (array-update fields index new-field)
           focus (| in-name index))))))
      char (:
       field (array-get fields index)
       new-field (&
        name (handle-text-edit (.name field) event)
        value (.value field))
       (| update
        (| struct (&
         fields (array-update fields index new-field)
         focus (| in-name index))))))
    (at-value index)
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus (| struct (& fields fields focus (| outside))))
        (key-down? key) (:
         field (array-get fields index)
         new-field (& name (.name field) value (code-focus (.value field)))
         (| update
          (| struct (&
           fields (array-update fields index new-field)
           focus (| in-value index)))))
        (key-left? key)
         (| update (| struct (& fields fields focus (| at-name index))))
        (key-right? key)
         (if (= index (- (array-length fields) 1))
          (| no-change)
          (| update (| struct (& fields fields focus (| at-name (+ index 1))))))
        (key-backspace? key)
         (| update
          (| struct
           (&
            fields (array-remove fields index)
            focus (if (= index 0) (| at-start) (| at-value (- index 1))))))
        else (| no-change))
      (char char) (| no-change))
    (in-value index) (:
     field (array-get fields index)
     (% (code-handle (.value field))
      no-change (| no-change)
      (update new-value)
       (| update
        (| struct (&
         fields
          (array-update fields index (& name (.name field) value new-value))
         focus focus)))
      (yield-focus new-value)
       (| update
        (| struct (&
         fields
          (array-update fields index (& name (.name field) value new-value))
         focus (| at-value index)))))))))
 struct-color green
 struct-render-singleline (\ (code-render-singleline state space-allowed)
  (maybe-render-parenthesized (not space-allowed) struct-color
   (row ([]
    (maybe-render-cursor (% (.focus state) at-start true _ false)
     (text "&" struct-color))
    (row
     (array-map-indexed (.fields state) (\ (index field)
      (row ([]
       (empty-box 5 0)
       (maybe-render-cursor (% (.focus state) (at-name i) (= i index) _ false)
        (text (.name field) struct-color))
       (empty-box 5 0)
       (maybe-render-cursor (% (.focus state) (at-value i) (= i index) _ false)
        (code-render-singleline (.value field) false)))))))))))
 struct-render (\ (code-render code-render-singleline state width)
  (row ([]
   (sized-box 10 10 (text "&" struct-color))
   (column
    (array-map (.fields state) (\ (field) (:
     name (text (.name field) struct-color)
     singleline
      (row ([]
       name
       (empty-box 5 0)
       (code-render-singleline (.value field) false)))
     (if (<= (.width singleline) (- width 10))
      singleline
      (column ([]
       name
       (empty-box 0 2)
       (code-render (.value field) (- width 20))))))))))))

 new-array (\ (items) (| array (& items items focus (| outside))))
 array-focus (\ (state)
  (| array (&
   items (.items state)
   focus (if (= (array-length (.items state)) 0) (| at-start) (| at 0)))))
 array-handle (\ (code-focus code-handle state event)
  (:
   items (.items state)
   focus (.focus state)
   (% focus
    outside (| no-change)
    at-start
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus (| array (& items items focus (| outside))))
        (key-right? key)
         (if (= (array-length items) 0)
          (| no-change)
          (| update (| array (& items items focus (| at 0)))))
        else (| no-change))
      (char char)
       (% (new-code-node-from-char char)
        (some node)
         (| update
          (| array (& items (array-insert items 0 node) focus (| in 0))))
        none (| no-change)))
    (at index)
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus (| array (& items items focus (| outside))))
        (key-left? key)
         (if (= index 0)
          (| update (| array (& items items focus (| at-start))))
          (| update (| array (& items items focus (| at (- index 1))))))
        (key-right? key)
         (if (= index (- (array-length items) 1))
          (| no-change)
          (| update (| array (& items items focus (| at (+ index 1))))))
        (key-down? key)
         (| update
          (| array (&
           items (array-update items index (code-focus (array-get items index)))
           focus (| in index))))
        (key-backspace? key)
         (| update
          (| array
           (&
            items (array-remove items index)
            focus (if (= index 0) (| at-start) (| at (- index 1))))))
        (key-delete? key)
         (| update
          (| array
           (&
            items (array-remove items index)
            focus
             (if (= index (- (array-length items) 1))
              (if (= index 0) (| at-start) (| at (- index 1)))
              (| at index)))))
        (key-alt-left? key)
         (if (= index 0)
          (| no-change)
          (| update
           (| array (&
            items (array-swap items index (- index 1))
            focus (| at (- index 1))))))
        (key-alt-right? key)
         (if (= index (- (array-length items) 1))
          (| no-change)
          (| update
           (| array (&
            items (array-swap items index (+ index 1))
            focus (| at (+ index 1))))))
        else (| no-change))
      (char char)
       (% (new-code-node-from-char char)
        (some node)
         (| update
          (| array
           (&
            items (array-insert items (+ index 1) node)
            focus (| in (+ index 1)))))
        none (| no-change)))
    (in index)
     (% (code-handle (array-get items index))
      no-change (| no-change)
      (update new-item)
       (| update
        (| array (& items (array-update items index new-item) focus focus)))
      (yield-focus new-item)
       (| update
        (| array
         (& items (array-update items index new-item) focus (| at index))))))))
 array-color red
 array-render-singleline (\ (code-render-singleline state space-allowed)
  (maybe-render-parenthesized (not space-allowed) array-color
   (row ([]
    (maybe-render-cursor (% (.focus state) at-start true _ false)
     (text "[]" array-color))
    (row
     (array-map-indexed (.items state) (\ (index item)
      (row ([]
       (empty-box 5 0)
       (maybe-render-cursor (% (.focus state) (at i) (= i index) _ false)
        (code-render-singleline item false)))))))))))
 array-render (\ (code-render state width)
  (row ([]
   (sized-box 10 10 (text "[]" array-color))
   (rec-2 (array->list (.items state)) 0 (\ (rec items index)
    (% items
     empty (empty-box 0 0)
     (more m)
      (column ([]
       (maybe-render-cursor (% (.focus state) (at i) (= i index) _ false)
        (code-render (.item m) (- width 10)))
       (empty-box 0 (% (.rest m) empty 0 more 2))
       (rec (.rest m) (+ index 1))))))))))

 new-folded (\ (value) (| folded value))
 folded-focus (\ (focus value)
  (focus
   (% (@kind value)
    int (new-int value)
    string (new-name value)
    struct
     (new-struct
      (array-map
       (@fields value)
       (\ (field) (& name (.name field) value (| folded (.value field))))))
    enum (new-enum (@variant value) (| some (| folded (@payload value))))
    array (new-array (array-map value (\ (item) (| folded item))))
    _ (crash (| unknown-kind value))
    )))
 folded-render-singleline (\ (state) (text "..." red))
 folded-render (\ (state) (folded-render-singleline state))

 code-focus (\ (code)
  (rec code (\ (focus code)
   (% code
    (name state) (name-focus state)
    (int state) (int-focus state)
    (struct state) (struct-focus state)
    (enum state) (enum-focus state)
    (array state) (array-focus state)
    (folded state) (folded-focus focus state)
    _ (crash (| todo-focus code))))))
 code-handle (\ (code event)
  (rec code (\ (handle code)
   (% code
    (root state) (root-handle code-focus handle state event)
    (name state) (name-handle state event)
    (int state) (int-handle state event)
    (struct state) (struct-handle code-focus handle state event)
    (enum state) (enum-handle code-focus handle state event)
    (array state) (array-handle code-focus handle state event)
    _ (crash (| todo-handle code))))))
 code-render-singleline (\ (code space-allowed)
  (rec-2 code space-allowed (\ (render code space-allowed)
   (% code
    (root state) (root-render-singleline render state space-allowed)
    (name state) (name-render-singleline state)
    (int state) (int-render-singleline state)
    (struct state) (struct-render-singleline render state space-allowed)
    (enum state) (enum-render-singleline render state space-allowed)
    (array state) (array-render-singleline render state space-allowed)
    (folded state) (folded-render-singleline state)
    _ (crash (| todo-render code))))))
 code-render (\ (code width)
  (rec-2 code width (\ (render code width)
   (:
    singleline (code-render-singleline code true)
    (if (<= (.width singleline) width)
     singleline
     (% code
      (root state) (root-render render state width)
      (name state) (name-render state)
      (int state) (int-render state)
      (struct state) (struct-render render code-render-singleline state width)
      (enum state) (enum-render render state width)
      (array state) (array-render render state width)
      (folded state) (folded-render state)
      _ (crash (| todo-render code))))))))

 initial-state
  (new-root
   (new-array ([]
    (new-name "foo")
    (new-struct ([]
     (& name "x" value (new-int 3))
     (& name "y" value (new-int 5))))
    (new-enum "some" (| some (new-name "bar")))
    (new-array ([]
     (new-name "a")
     (new-name "b")
     (new-array ([]
      (new-name "c")
      (new-name "d")
      (new-name "e")))
     (new-name "f")
     (new-name "g"))))))

 render (\ (code size)
  (.draw (padding 2 (code-render code (- (.width size) 4)))))
 handle (\ (code event)
  (% (code-handle code event) no-change code (update code) code))
 make-app (\ (state)
  (rec state (\ (rec state)
   (&
    render (\ (size) (render state size))
    update (\ (event) (rec (handle state event)))
    state state))))
 app (make-app initial-state)

 edit (\ (value)
  (make-app (new-root (| folded value))))

 _ "Notes App"

 render (\ (state size)
  (.draw
   (padding 2
    (% (.focus state)
     (at index)
      (column
       (array-map-indexed
        (.notes state)
        (\ (i note) (text (.title note) (if (= i index) red black)))))
     (in info) (:
      note (array-get (.notes state) (.index info))
      (column ([]
       (text (.title note) red)
       (empty-box 0 5)
       (text (.content note) black))))))))
 handle (\ (state event)
  (:
   focus (.focus state)
   notes (.notes state)
   (% focus
    (at index)
     (% event
      (pressed-key key)
       (cond
        (key-down? key)
         (&
          focus
           (| at (if (= index (- (array-length notes) 1)) index (+ index 1)))
          notes notes)
        (key-up? key)
         (& focus (| at (if (= index 0) index (- index 1))) notes notes)
        (key-enter? key)
         (& focus (| in (& index index cursor new-cursor)) notes notes)
        else state)
      char state)
    (in info) (:
     index (.index info)
     cursor (.cursor info)
     note (array-get notes index)
     width 1000
     (% event
      (pressed-key key)
       (if (key-escape? key)
        (& focus (| at index) notes notes)
        (:
         result
          (handle-text-edit-with-cursor (.content note) width cursor event)
         new-note (& title (.title note) content (.string result))
         (&
          focus (| in (& index index cursor (.cursor result)))
          notes (array-update notes index new-note))))
      (char c) (:
       result (handle-text-edit-with-cursor (.content note) width cursor event)
       new-note (& title (.title note) content (.string result))
       (&
        focus (| in (& index index cursor (.cursor result)))
        notes (array-update notes index new-note))))))))
 make-app (\ (state)
  (rec state (\ (rec state)
   (&
    render (\ (size) (render state size))
    update (\ (event) (rec (handle state event)))
    state state))))
 notes-app (\ (notes) (make-app (& focus (| at 0) notes notes)))

 (&
  render (.render app)
  update (.update app)
  state initial-state
  edit edit
  notes-app notes-app)
)


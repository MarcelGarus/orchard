(:
 # "Nil is used whenever we don't actually want to provide a useful value.
  Functions that only have side-effects (aka they may crash or hang) return nil.
  See the assert function for an example."
 nil (&)

 # "Crashing stuff"
 crash (\ (error) (@crash error))
 assert (\ (check) (if check nil (crash "Assert failed.")))

 rec (\ (input function)
  (:
   rec (\ (rec input) (function (\ (new) (rec rec new)) input))
   (rec rec input)))
 rec-2 (\ (a b function)
  (:
   rec (\ (rec a b) (function (\ (a b) (rec rec a b)) a b))
   (rec rec a b)))
 rec-3 (\ (a b c function)
  (:
   rec (\ (rec a b c) (function (\ (a b c) (rec rec a b c)) a b c))
   (rec rec a b c)))

 true (| true)
 false (| false)

 _ (assert true)

 else true

 not (\ (a) (if a false true))
 and (\ (a b) (if a b false))
 and-3 (\ (a b c) (and (and a b) c))
 and-4 (\ (a b c d) (and (and a b c) d))
 and-5 (\ (a b c d e) (and (and a b c d) e))
 or (\ (a b) (if a true b))
 or-3 (\ (a b c) (or (or a b) c))
 or-4 (\ (a b c d) (or (or a b c) d))
 or-5 (\ (a b c d e) (or (or a b c d) e))

 + (\ (a b) (@add a b))
 - (\ (a b) (@subtract a b))
 * (\ (a b) (@multiply a b))
 / (\ (a b) (@divide a b))
 mod (\ (a b) (@modulo a b))
 << (\ (a b) (@shift-left a b))
 >> (\ (a b) (@shift-right a b))
 bit-and (\ (a b) (@and a b))
 bit-or (\ (a b) (@or a b))
 bit-xor (\ (a b) (@xor a b))

 compare (\ (a b) (@compare a b))
 = (\ (a b) (@equal? a b))
 != (\ (a b) (not (@equal? a b)))
 < (\ (a b) (% (compare a b) less true _ false))
 > (\ (a b) (% (compare a b) greater true _ false))
 <= (\ (a b) (% (compare a b) greater false _ true))
 >= (\ (a b) (% (compare a b) less false _ true))
 max (\ (a b) (if (> a b) a b))
 min (\ (a b) (if (< a b) a b))
 abs (\ (n) (if (< n 0) (- 0 n) n))

 array-length (\ (array) (@array-length array))
 array-get (\ (array index) (@array-get array index))
 array->list (\ (array) (@array->list array))
 list->array (\ (list) (@list->array list))
 filled-list (\ (length item)
  (:
   _ (assert (< length 100))
   rec (\ (rec i)
    (if (= i length) (| empty) (| more (& item item rest (rec rec (+ i 1))))))
   (rec rec 0)))
 filled-array (\ (length item) (list->array (filled-list length item)))
 list-map (\ (list mapper)
  (rec list (\ (rec list)
   (% list
    empty (| empty)
    (more m) (| more (& item (mapper (.item m)) rest (rec (.rest m))))))))
 array-map (\ (array mapper)
  (list->array (list-map (array->list array) mapper)))
 list-map-indexed (\ (list mapper)
  (rec (& list list index 0) (\ (rec args)
   (% (.list args)
    empty (| empty)
    (more m)
     (| more
      (&
       item (mapper (.index args) (.item m))
       rest (rec (& list (.rest m) index (+ (.index args) 1)))))))))
 array-map-indexed (\ (array mapper)
  (list->array (list-map-indexed (array->list array) mapper)))
 list-any (\ (list checker)
  (rec list (\ (rec list)
   (% list
    empty false
    (more m) (if (checker (.item m)) true (rec (.rest m)))))))
 array-any (\ (array checker) (list-any (array->list array) checker))
 list-find (\ (list checker)
  (rec (& list list index 0) (\ (rec args)
   (% (.list args)
    empty (| none)
    (more m)
     (if (checker (.item m))
      (| some (.index args))
      (rec (& list (.rest m) index (+ (.index args) 1))))))))
 array-find (\ (array checker) (list-find (array->list array) checker))
 list-concat (\ (a b)
  (rec a (\ (rec a)
   (% a
    empty b
    (more m) (| more (& item (.item m) rest (rec (.rest m))))))))
 array-concat (\ (a b)
  (list->array (list-concat (array->list a) (array->list b))))
 list-skip (\ (list n)
  (rec (& list list n n) (\ (rec args)
   (:
    list (.list args)
    n (.n args)
    (if (= n 0) list (rec (& list (% list (more m) (.rest m)) n (- n 1))))))))
 list-take (\ (list n)
  (rec (& list list n n) (\ (rec args)
   (:
    list (.list args)
    n (.n args)
    (if (= n 0)
     (| empty)
     (% list (more m)
      (| more (& item (.item m) rest (rec (& list (.rest m) n (- n 1)))))))))))
 list-slice (\ (list from to) (list-take (list-skip list from) (- to from)))
 array-slice (\ (array from to)
  (list->array (list-slice (array->list array) from to)))
 list-update (\ (list index item)
  (list-map-indexed list (\ (i it) (if (= i index) item it))))
 array-update (\ (array index item)
  (list->array (list-update (array->list array) index item)))
 list-remove (\ (list index) (list-concat (list-take list index) (list-skip list (+ index 1))))
 array-remove (\ (array index)
  (list->array (list-remove (array->list array) index)))
 list-insert (\ (list index item)
  (list-concat
   (list-take list index)
   (list-concat (| more (& item item rest (| empty))) (list-skip list index))))
 array-insert (\ (array index item)
  (list->array (list-insert (array->list array) index item)))
 list-get (\ (list index) (% (list-skip list index) (more m) (.item m)))
 list-swap (\ (list a b)
  (list-map-indexed
   list
   (\ (i it) (if (= i a) (list-get list b) (if (= i b) (list-get list a) it)))))
 array-swap (\ (array a b)
  (array-map-indexed
   array
   (\ (i it)
    (if (= i a) (array-get array b) (if (= i b) (array-get array a) it)))))
 list-reverse (\ (list)
  (rec-2 list (| empty) (\ (rec to-reverse reversed)
   (% to-reverse
    empty reversed
    (more m) (rec (.rest m) (| more (& item (.item m) rest reversed)))))))
 array-reverse (\ (array) (list->array (list-reverse (array->list array))))

 list-take-while (\ (list checker)
  (rec list (\ (rec list)
   (% list
    empty (| empty)
    (more m)
     (if (checker (.item m))
      (| more (& item (.item m) rest (rec (.rest m))))
      (| empty))))))
 list-skip-while (\ (list checker)
  (rec list (\ (rec list)
   (% list
    empty (| empty)
    (more m)
     (if (checker (.item m))
      (rec (.rest m))
      list)))))
 list-reduce (\ (list reducer)
  (% list
   (more m)
    (rec-2 (.rest m) (.item m) (\ (rec rest acc)
     (% rest
      empty acc
      (more m) (rec (.rest m) (reducer acc (.item m))))))))
 list-length (\ (list)
  (rec list (\ (rec list)
   (% list
    empty 0
    (more m) (+ 1 (rec (.rest m)))))))
 list-take-and-reverse (\ (list n)
  (rec-2 (& list list n n) (| empty) (\ (rec args reversed)
   (:
    list (.list args)
    n (.n args)
    (if (= n 0)
     reversed
     (% list
      (more m)
       (rec
        (& list (.rest m) n (- n 1))
        (| more (& item (.item m) rest reversed)))))))))
 list-max (\ (list) (list-reduce list (\ (a b) (max a b))))

 string->bytes (\ (string) (@string->bytes string))
 bytes->string (\ (bytes) (@bytes->string bytes))
 string-length (\ (string) (@array-length (string->bytes string)))
 string-concat (\ (a b)
  (bytes->string (array-concat (string->bytes a) (string->bytes b))))
 string-slice (\ (string from to)
  (bytes->string (array-slice (string->bytes string) from to)))
 string-replace-range (\ (string range replacement)
  (string-concat
   (string-concat
    (string-slice string 0 (.start range))
    replacement)
   (string-slice string (.end range) (string-length string))))
 string-remove-range (\ (string start end)
  (string-concat
   (string-slice string 0 start)
   (string-slice string end (string-length string))))
 string-remove (\ (string index)
  (string-concat
   (string-slice string 0 index)
   (string-slice string (+ index 1) (string-length string))))
 string-insert (\ (string index text)
  (string-concat
   (string-concat
    (string-slice string 0 index)
    text)
   (string-slice string index (string-length string))))
 ascii-char (\ (literal) (array-get (string->bytes literal) 0))
 int->string (\ (int)
  (rec-2 int (| empty) (\ (rec int prev)
   (if (= 0 int)
    (bytes->string (list->array prev))
    (rec
     (/ int 10)
     (| more (& item (+ (ascii-char "0") (mod int 10)) rest prev)))))))
 bytes->chars (\ (rec bytes i)
  (if (= i (array-length bytes))
   (| empty)
   (| more (&
    item (@bytes->string ([] (array-get bytes i)))
    rest (rec rec bytes (+ i 1))))))
 bytes->chars-list (\ (bytes) (bytes->chars bytes->chars bytes 0))
 string->chars-list (\ (string) (bytes->chars-list (string->bytes string)))
 string->chars-array (\ (string) (list->array (string->chars-list string)))

 value? (\ (node) (% node value true _ false))
 bind (\ (rec mode input name value)
  (% mode
   expr
    (% input
     value input
     (name n) (if (@equal? name n) value (| name n))
     (let l)
      (| let
       (&
        name (.name l)
        definition (rec rec (| expr) (.definition l) name value)
        body (rec rec (| expr) (.body l) name value)))
     (field f)
      (| field (& of (rec rec (| expr) (.of f) name value) name (.name f)))
     (call c)
      (| call
       (&
        function (rec rec (| expr) (.function c) name value)
        arguments (rec rec (| array) (.arguments c) name value)))
     _ (crash (| todo-bind input))
    )
   array (list->array (rec rec (| list) (array->list input) name value))
   list
    (% input
     empty (| empty)
     (more m)
      (| more
       (&
        item (rec rec (| expr) (.item m) name value)
        rest (rec rec (| list) (.rest m) name value))))
   _ (crash (| unknown-bind-mode mode)))
 )
 bind (\ (input name value) (bind bind (| expr) input name value))
 optimize (\ (rec mode input)
  (% mode
   expr
    (% input
     value input
     (let let)
      (:
       name (.name let)
       definition (rec rec (| expr) (.definition let))
       (% definition
        (value v) (rec rec (| expr) (bind (.body let) name (| value v)))
        _ (:
         body (rec rec (| expr) (.body let))
         (| let (& name name definition definition body body))
        )
       )
      )
     (add args)
      (:
       left (rec rec (| expr) (.left args))
       right (rec rec (| expr) (.right args))
       (% left
        (value l)
         (% right
          (value r) (| value (@add l r))
          _ (| add (& left left right right))
         )
        _ (| add (& left left right right))))
     _ input
    )
   fun
    (@function
     (@arguments input)
     (rec
      rec
      (| expr)
      (| let
       (&
        name "@captured"
        definition (| value (@captured input))
        body (@body input))))
     nil)
  ))
 optimize (\ (function) (optimize optimize (| fun) function))

 ##### "The Render System

  When Pear code is asked to render something for the outside world, it
  communicates using drawing instructions. These are just normal Pear values.

  <drawing-instruction> =
   | nothing
   | fill-path (& path <path> color <color>)
   | translate (& by <point> what <drawing-instruction>)
   | all ([] <drawing-instruction>)

  <point> = (& x y)
  <color> = (& r <int> g <int> b <int>)

  <path> = ([] <path-segment>)
  <path-segment> =
   | move-to <point>
   | line-to <point>

  Initially, I tried to communicate with the outside world using pixel graphics.
  However, I believe that's not the right move as pixels are more difficult to
  handle in code. Having pixels (or some concept of a texture) within Pear
  requires either:
  - mutable values (which Pear doesn't have), or
  - lots of copying on every texture modification (which Pear doesn't have), or
  - a super-smart optimizing compiler (which is useful but it has the sort of
    slow-by-default-and-you-have-to-trust-the-black-box-to-work feeling I don't
    like), or
  - inefficient storage of individual pixels in trees.
  By communicating the intent on a quite high-level, we can instead make use of
  GPUs when turning the high-level drawing instructions into pixels. This is
  also similar to how Flutter works: The Dart VM is decently fast, but not super
  fast, so it just emits drawing instructions that the lower-level C++ engine
  takes and turns into pixels.

  Within Pear, rendering functions usually return structs of the form
  (& draw <drawing-instructions> width <int> height <int>) rather than just raw
  drawing instructions.

  2026-05-10: Added this comment.
 "

 point (\ (x y) (& x x y y))

 black (& r 0 g 0 b 0)
 white (& r 255 g 255 b 255)
 red (& r 144 g 32 b 32)
 blue (& r 32 g 97 b 144)
 green (& r 63 g 110 b 16)
 purple (& r 63 g 32 b 144)
 yellow (& r 254 g 228 b 113)

 # "I try to name the rendering functions in a declarative way
  (e.g. row instead of render-next-to-each-other)."

 empty-box (\ (width height) (& draw (| nothing) width width height height))

 sized-box (\ (width height child)
  (& draw (.draw child) width width height height))

 colored (\ (color child)
  (:
   width (.width child)
   height (.height child)
   (&
    draw
     (| all ([]
      (| fill-path (&
       path ([]
        (| move-to (point 0 0))
        (| line-to (point width 0))
        (| line-to (point width height))
        (| line-to (point 0 height)))
       color color))
      (.draw child)))
    width width
    height height)))

 padding (\ (padding child)
  (if (= (@kind padding) (| int))
   (&
    draw (| translate (& by (& x padding y padding) what (.draw child)))
    width (+ (.width child) (* 2 padding))
    height (+ (.height child) (* 2 padding)))
   (&
    draw
     (| translate (&
      by (& x (.left padding) y (.top padding))
      what (.draw child)))
    width (+ (.width child) (+ (.left padding) (.right padding)))
    height (+ (.height child) (+ (.top padding) (.bottom padding))))))

 padded-row (\ (padding children)
  (:
   res (rec-2 (array->list children) 0 (\ (rec children x)
    (% children
     empty (& draw (| empty) width 0 height 0)
     (more m) (:
      child (.item m)
      rest (rec (.rest m) (+ x (.width child)))
      (&
       draw
        (| more (&
         item (| translate (& by (& x x y 0) what (.draw child)))
         rest (.draw rest)))
       width (+ (.width child) (+ padding (.width rest)))
       height (max (.height child) (.height rest)))))))
   (&
    draw (| all (list->array (.draw res)))
    width (- (.width res) padding)
    height (.height res))))
 row (\ (children) (padded-row 0 children))

 column (\ (children)
  (:
   res (rec-2 (array->list children) 0 (\ (rec children y)
    (% children
     empty (& list (| empty) width 0 height 0)
     (more m) (:
      child (.item m)
      rest (rec (.rest m) (+ y (.height child)))
      (&
       list
        (| more (&
         item (| translate (& by (& x 0 y y) what (.draw child)))
         rest (.list rest)))
       width (max (.width child) (.width rest))
       height (+ (.height child) (.height rest)))))))
   (&
    draw (| all (list->array (.list res)))
    width (.width res)
    height (.height res))))

 parse-pixels (\ (width string)
  (:
   bytes (string->bytes string)
   row-rec (\ (rec i x)
    (: c (array-get bytes i)
     (if (= c (ascii-char "|"))
      (& cursor (+ i 1) result (filled-list (- width x) 0))
      (if (= x width)
       (crash "Pixel line too long.")
       (: rest (rec rec (+ i 1) (+ x 1))
        (&
         cursor (.cursor rest)
         result
          (| more
           (& item (if (= c (ascii-char " ")) 0 1) rest (.result rest)))))))))
   rec (\ (rec i)
    (if (= i (array-length bytes))
     (| empty)
     (: row (row-rec row-rec i 0)
      (| more
       (& item (list->array (.result row)) rest (rec rec (.cursor row)))))))
   (list->array (rec rec 0))))
 pixel-glyph (\ (char width string)
  (:
   pixels (parse-pixels width string)
   height (array-length pixels)
   paths (rec-2 0 0 (\ (rec x y)
    (if (= x width)
     (if (= (+ y 1) height) (| empty) (rec 0 (+ y 1)))
     (if (= (array-get (array-get pixels y) x) 1)
      (| more (&
       item ([]
        (| move-to (point x y))
        (| line-to (point (+ x 1) y))
        (| line-to (point (+ x 1) (+ y 1)))
        (| line-to (point x (+ y 1))))
       rest (rec (+ x 1) y)))
      (rec (+ x 1) y)))))
   (& char char width width paths paths)))

  default-glyph)
 find-glyph (\ (rec char i)
  (if (= i (array-length glyphs))
   default-glyph
   (: g (array-get glyphs i) (if (= char (.char g)) g (rec rec char (+ i 1))))))
 find-glyph (\ (char)
  (: bytes (@string->bytes char)
   (if (and (= (array-length bytes) 1) (< (array-get bytes 0) 123))
    (: glyph (array-get glyphs (array-get bytes 0))
     _
      (if (= (.char glyph) char)
       nil
       (crash (| bad-glyph (& char char glyph glyph))))
     glyph)
    (find-glyph find-glyph char 0))))
 find-kerning (\ (a b) 1.)
 layout-text (\ (text max-width)
  (rec-3 (string->chars-list text) 0. 0. (\ (rec chars x y)
   (% chars
    empty (| empty)
    (more m) (:
     char (.item m)
     rest (.rest m)
     glyph (find-glyph char)
     (if (= char "\n")
      (:
       next-x 0.
       next-y (f+ y line-height)
       (| more (&
        item (& x x y y char char glyph glyph cursor-x next-x cursor-y next-y)
        rest (rec rest next-x next-y))))
      (:
       width (.width glyph)
       kerning (% rest empty 0. (more next) (find-kerning char (.item next)))
       next-x (f+ x (f+ width kerning))
       next-y y
       next-cursor-x (f+ x (f- width (f/ kerning 2.)))
       (| more (&
        item (& x x y y char char glyph glyph cursor-x next-cursor-x cursor-y y)
        rest (rec rest next-x next-y))))))))))
 draw-glyph (\ (glyph color)
  (| all
   (iter->array
    (map
     (list->iter (.paths glyph))
     (\ (path) (| fill-path (& path path color color)))))))
 text (\ (string color)
  (:
   layouted (layout-text string 100000.)
   (&
    draw
     (| all
      (iter->array
       (map (list->iter layouted) (\ (glyph)
        (| translate (&
         by (& x (.x glyph) y (.y glyph))
         what (draw-glyph (.glyph glyph) color)))))))
    width
     (fold
      (map (list->iter layouted) (\ (glyph) (f+ (.x glyph) (.width (.glyph glyph))))) 0. f-max)
    height
     (fold (map (list->iter layouted) (\ (glyph) (f+ (.y glyph) line-height))) 0. f-max))))

 no-modifiers? (\ (key)
  (and-3 (not (.control key)) (not (.shift key)) (not (.alt key))))
 ctrl-modifier? (\ (key)
  (and-3 (.control key) (not (.shift key)) (not (.alt key))))
 alt-modifier? (\ (key)
  (and-3 (not (.control key)) (not (.shift key)) (.alt key)))
 shift-modifier? (\ (key)
  (and-3 (not (.control key)) (.shift key) (not (.alt key))))
 ctrl-shift-modifiers? (\ (key)
  (and-3 (.control key) (.shift key) (not (.alt key))))
 key-escape? (\ (key) (and (= (.keycode key) 256) (no-modifiers? key)))
 key-enter? (\ (key) (and (= (.keycode key) 257) (no-modifiers? key)))
 key-backspace? (\ (key) (and (= (.keycode key) 259) (no-modifiers? key)))
 key-delete? (\ (key) (and (= (.keycode key) 261) (no-modifiers? key)))
 key-right? (\ (key) (and (= (.keycode key) 262) (no-modifiers? key)))
 key-left? (\ (key) (and (= (.keycode key) 263) (no-modifiers? key)))
 key-down? (\ (key) (and (= (.keycode key) 264) (no-modifiers? key)))
 key-up? (\ (key) (and (= (.keycode key) 265) (no-modifiers? key)))
 key-start? (\ (key) (and (= (.keycode key) 268) (no-modifiers? key)))
 key-end? (\ (key) (and (= (.keycode key) 269) (no-modifiers? key)))
 key-ctrl-enter? (\ (key) (and (= (.keycode key) 257) (ctrl-modifier? key)))
 key-ctrl-backspace? (\ (key) (and (= (.keycode key) 259) (ctrl-modifier? key)))
 key-ctrl-right? (\ (key) (and (= (.keycode key) 262) (ctrl-modifier? key)))
 key-ctrl-left? (\ (key) (and (= (.keycode key) 263) (ctrl-modifier? key)))
 key-alt-right? (\ (key) (and (= (.keycode key) 262) (alt-modifier? key)))
 key-alt-left? (\ (key) (and (= (.keycode key) 263) (alt-modifier? key)))
 key-alt-down? (\ (key) (and (= (.keycode key) 264) (alt-modifier? key)))
 key-alt-up? (\ (key) (and (= (.keycode key) 265) (alt-modifier? key)))
 key-shift-right? (\ (key) (and (= (.keycode key) 262) (shift-modifier? key)))
 key-shift-left? (\ (key) (and (= (.keycode key) 263) (shift-modifier? key)))
 key-shift-down? (\ (key) (and (= (.keycode key) 264) (shift-modifier? key)))
 key-shift-up? (\ (key) (and (= (.keycode key) 265) (shift-modifier? key)))
 key-shift-start? (\ (key) (and (= (.keycode key) 268) (shift-modifier? key)))
 key-shift-end? (\ (key) (and (= (.keycode key) 269) (shift-modifier? key)))
 key-ctrl-shift-right? (\ (key)
  (and (= (.keycode key) 262) (ctrl-shift-modifiers? key)))
 key-ctrl-shift-left? (\ (key)
  (and (= (.keycode key) 263) (ctrl-shift-modifiers? key)))
 key-space? (\ (key) (and (= (.keycode key) 32) (no-modifiers? key)))
 key-a? (\ (key) (and (= (.keycode key) 65) (no-modifiers? key)))
 key-d? (\ (key) (and (= (.keycode key) 68) (no-modifiers? key)))
 key-n? (\ (key) (and (= (.keycode key) 78) (no-modifiers? key)))
 key-r? (\ (key) (and (= (.keycode key) 82) (no-modifiers? key)))
 key-s? (\ (key) (and (= (.keycode key) 83) (no-modifiers? key)))
 key-w? (\ (key) (and (= (.keycode key) 87) (no-modifiers? key)))

 # "Text editing

  A cursor consists of the following state:
   - the anchor position (where a selection started)
   - the active position (where the part controlled by the arrow keys is)
   - the desired x position"

 new-cursor (& anchor 0 active 0 desired-x 0.)
 cursor-start (\ (cursor) (min (.anchor cursor) (.active cursor)))
 cursor-end (\ (cursor) (max (.anchor cursor) (.active cursor)))
 cursor-has-selection? (\ (cursor) (!= (.anchor cursor) (.active cursor)))
 cursor-selection (\ (cursor)
  (& start (cursor-start cursor) end (cursor-end cursor)))

 text-x-offset (\ (string width offset)
  (if (= offset 0) 0. (.x (list-get (layout-text string width) (- offset 1)))))
 list-indexed (\ (list)
  (rec-2 list 0 (\ (rec list i)
   (% list
    empty (| empty)
    (more m)
     (| more (&
      item (& index i glyph (.item m))
      rest (rec (.rest m) (+ i 1))))))))
 pick-closer (\ (x a b)
  (:
   ga (.glyph a)
   gb (.glyph b)
   dist-a (f-abs (f- (.x ga) x))
   dist-b (f-abs (f- (.x gb) x))
   (if (f< dist-a dist-b) a b)))
 find-offset-above (\ (x y glyphs)
  (:
   indexed (list-indexed glyphs)
   before (iter->list (take-while (list->iter indexed) (\ (ig) (f< (.y (.glyph ig)) y))))
   (% before
    empty (| none)
    more
     (| some
      (.index
       (reduce (list->iter before) (\ (a b)
        (if (f< (.y (.glyph a)) (.y (.glyph b)))
         b
         (pick-closer x a b)))))))))
 find-offset-below (\ (x y glyphs)
  (:
   indexed (list-indexed glyphs)
   after (iter->list (skip-while (list->iter indexed) (\ (ig) (f<= (.y (.glyph ig)) y))))
   (% after
    empty (| none)
    more
     (| some
      (.index
       (reduce (list->iter after) (\ (a b)
        (if (f< (.y (.glyph a)) (.y (.glyph b)))
         a
         (pick-closer x a b)))))))))
 find-line-start (\ (chars offset)
  (rec offset (\ (rec candidate)
   (cond
    (= candidate 0) 0
    (= (array-get chars (- candidate 1)) "\n") candidate
    else (rec (- candidate 1))))))
 find-line-end (\ (chars offset)
  (rec offset (\ (rec candidate)
   (cond
    (= candidate (array-length chars)) (array-length chars)
    (= (array-get chars candidate) "\n") candidate
    else (rec (+ candidate 1))))))

 word-char? (\ (char)
  (: c (ascii-char char)
   (or-4
    (= char "_")
    (and (>= c (ascii-char "a")) (<= c (ascii-char "z")))
    (and (>= c (ascii-char "A")) (<= c (ascii-char "Z")))
    (and (>= c (ascii-char "0")) (<= c (ascii-char "9"))))))
 punctuation-char? (\ (char) (and (!= char " ") (not (word-char? char))))
 num-leading-word-chars (\ (chars-list)
  (rec chars-list (\ (rec chars)
   (% chars
    empty 0
    (more m) (if (word-char? (.item m)) (+ 1 (rec (.rest m))) 0)))))
 num-leading-punctuation-chars (\ (chars-list)
  (rec chars-list (\ (rec chars)
   (% chars
    empty 0
    (more m) (if (punctuation-char? (.item m)) (+ 1 (rec (.rest m))) 0)))))
 
 # "Skipping (moving ctrl + left/right) =
    1. Skip spaces
    2. How many characters of punctuation follow?
       0: Skip all letters
       1: Skip the punctuation, then all letters after it
       2: Skip all punctuation"
 num-leading-skip-chars (\ (chars-list)
  (rec chars-list (\ (rec chars)
   (% chars
    empty 0
    (more m) (:
     char (.item m)
     rest (.rest m)
     (cond
      (= char " ") (+ (rec rest) 1)
      (word-char? char) (num-leading-word-chars chars)
      else
       (% rest
        empty 1
        (more next-m)
         (if (punctuation-char? (.item next-m))
          (num-leading-punctuation-chars chars)
          (+ (num-leading-word-chars (.rest next-m)) 1)))))))))
 find-word-boundary-after (\ (string offset)
  (+
   offset
   (num-leading-skip-chars
    (list-skip (array->list (string->bytes string)) offset))))
 find-word-boundary-before (\ (string offset)
  (-
   offset
   (num-leading-skip-chars
    (list-take-and-reverse (array->list (string->bytes string)) offset))))

 handle-text-edit-with-cursor (\ (string width cursor event)
  (% event
   (pressed-key key)
    (cond
     (key-enter? key) (:
      new-string (string-replace-range string (cursor-selection cursor) "\n")
      new-offset (+ (cursor-start cursor) 1)
      (&
       string new-string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset new-string width new-offset))))
     (key-ctrl-enter? key) (:
      line-end (find-line-end string (.active cursor))
      new-string (string-insert string line-end "\n")
      new-offset (+ line-end 1)
      (&
       string new-string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset new-string width new-offset))))
     (key-backspace? key)
      (if (cursor-has-selection? cursor)
       (: offset (cursor-start cursor)
        (&
         string (string-remove-range string (cursor-start cursor) (cursor-end cursor))
         cursor (&
          anchor offset
          active offset
          desired-x (text-x-offset string width offset))))
       (: offset (.active cursor)
        (if (= offset 0)
         (& string string cursor cursor)
         (&
          string (string-remove string (- offset 1))
          cursor (&
           anchor (- offset 1)
           active (- offset 1)
           desired-x (text-x-offset string width (- offset 1)))))))
     (key-ctrl-backspace? key)
      (if (cursor-has-selection? cursor)
       (: offset (cursor-start cursor)
        (&
         string (string-remove-range string (cursor-start cursor) (cursor-end cursor))
         cursor (&
          anchor offset
          active offset
          desired-x (text-x-offset string width offset))))
       (:
        offset (.active cursor)
        new-offset (find-word-boundary-before string offset)
        (&
         string (string-remove-range string new-offset offset)
         cursor (&
          anchor new-offset
          active new-offset
          desired-x (text-x-offset string width new-offset)))))
     (key-delete? key)
      (if (cursor-has-selection? cursor)
       (: offset (cursor-start cursor)
        (&
         string (string-remove-range string (cursor-start cursor) (cursor-end cursor))
         cursor
          (&
           anchor offset
           active offset
           desired-x (text-x-offset string width offset))))
       (: offset (cursor-start cursor)
        (if (= offset (string-length string))
         (& string string cursor cursor)
         (& string (string-remove string offset) cursor cursor))))
     (key-right? key) (:
      new-offset
       (if (cursor-has-selection? cursor)
        (cursor-end cursor)
        (min (string-length string) (+ (.anchor cursor) 1)))
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-shift-right? key) (:
      offset (.active cursor)
      (if (= offset (string-length text))
       (& string string cursor cursor)
       (&
        string string
        cursor (&
         anchor (.anchor cursor)
         active (+ offset 1)
         desired-x (text-x-offset string width (+ offset 1))))))
     (key-ctrl-right? key) (:
      new-offset (find-word-boundary-after string (.active cursor))
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-ctrl-shift-right? key) (:
      new-offset (find-word-boundary-after string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-left? key) (:
      new-offset
       (if (cursor-has-selection? cursor)
        (cursor-start cursor)
        (max 0 (- (.anchor cursor) 1)))
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-shift-left? key) (:
      offset (.active cursor)
      (if (= offset 0)
       (& string string cursor cursor)
       (&
        string string
        cursor (&
         anchor (.anchor cursor)
         active (- offset 1)
         desired-x (text-x-offset string width (- offset 1))))))
     (key-ctrl-left? key) (:
      new-offset (find-word-boundary-before (.active cursor) text)
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-ctrl-shift-left? key) (:
      new-offset (find-word-boundary-before string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x (text-x-offset string width new-offset))))
     (key-down? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0.
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-below cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none 0 (some v) v)
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x cursor-desired-x)))
     (key-alt-down? key) (:
      start (find-line-start string (cursor-start cursor))
      end (find-line-end string (cursor-end cursor))
      (if (= end (string-length string))
       (& string string cursor cursor)
       (:
        next-line-end (find-line-end string (+ end 1))
        bytes (array->list (string->bytes string))
        a (list-slice bytes 0 start)
        b (list-slice bytes start end)
        c (list-slice bytes (+ end 1) next-line-end)
        d (list-skip bytes next-line-end)
        (&
         string
          (bytes->string
           (iter->array
            (concat-5
             (list->iter a)
             (list->iter c)
             (list->iter (| more (& item 10 rest (| empty))))
             (list->iter b)
             (list->iter d))))
         cursor (&
          anchor (+ (.anchor cursor) (+ (length (list->iter c)) 1))
          active (+ (.active cursor) (+ (length (list->iter c)) 1))
          desired-x (.desired-x cursor))))))
     (key-shift-down? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0.
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-below cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none (string-length text) (some v) v)
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x cursor-desired-x)))
     (key-up? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0.
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-above cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none 0 (some v) v)
      (&
       string string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x cursor-desired-x)))
     (key-alt-up? key) (:
      start (find-line-start string (cursor-start cursor))
      end (find-line-end string (cursor-end cursor))
      (if (= start 0)
       (& string string cursor cursor)
       (:
        previous-line-start (find-line-start string (- start 1))
        bytes (array->list (string->bytes string))
        a (list-slice bytes 0 previous-line-start)
        b (list-slice bytes previous-line-start (- start 1))
        c (list-slice bytes start end)
        d (list-skip bytes end)
        (&
         string
          (bytes->string
           (iter->array
            (concat-5
             (list->iter a)
             (list->iter c)
             (list->iter (| more (& item 10 rest (| empty))))
             (list->iter b)
             (list->iter d))))
         cursor (&
          anchor (+ (.anchor cursor) (+ (length (list->iter c)) 1))
          active (+ (.active cursor) (+ (length (list->iter c)) 1))
          desired-x (.desired-x cursor))))))
     (key-shift-up? key) (:
      layouted-text (layout-text string width)
      cursor-desired-x (.desired-x cursor)
      cursor-y
       (if (= (.active cursor) 0)
        0.
        (.y (list-get layouted-text (- (.active cursor) 1))))
      new-offset (find-offset-above cursor-desired-x cursor-y layouted-text)
      new-offset (% new-offset none (string-length text) (some v) v)
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active new-offset
        desired-x cursor-desired-x)))
     (key-start? key) (:
      line-start (find-line-start string (.active cursor))
      (&
       string string
       cursor (&
        anchor line-start
        active line-start
        desired-x (text-x-offset string width line-start))))
     (key-shift-start? key) (:
      line-start (find-line-start string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active line-start
        desired-x (text-x-offset string width line-start))))
     (key-end? key) (:
      line-end (find-line-end string (.active cursor))
      (&
       string string
       cursor (&
        anchor line-end
        active line-end
        desired-x (text-x-offset string width line-end))))
     (key-shift-end? key) (:
      line-end (find-line-end string (.active cursor))
      (&
       string string
       cursor (&
        anchor (.anchor cursor)
        active line-end
        desired-x (text-x-offset string width line-end))))
     else (& string string cursor cursor))
   (char char)
    (:
     c (ascii-char char)
    (if
     (or
      (= c 10)
      (and (>= c 32) (<= c 126)))
     (:
      new-string (string-replace-range string (cursor-selection cursor) char)
      new-offset (+ (cursor-start cursor) 1)
      (&
       string new-string
       cursor (&
        anchor new-offset
        active new-offset
        desired-x (text-x-offset new-string width new-offset))))
     (& string string cursor cursor)))))

 handle-text-edit (\ (string event)
  (% event
   (pressed-key key)
    (cond
     (key-backspace? key)
      (if (> (string-length string) 0)
       (string-slice string 0 (- (string-length string) 1))
       string)
     (key-enter? key) (string-concat string "\n")
     else string)
   (char char) (string-concat string char)))

 orchard-color (color "#2e6402")
 cursor-color (color "#ffcb10")
 int-color (color "#009ccb")
 string-color (color "#a86400")
 struct-color (color "#2eae00")
 enum-color (color "#db003e")
 array-color (color "#ff6d1e")
 function-color (color "#8a0cff")

 editable-text (\ (string color cursor)
  (:
   layouted (layout-text string 100000.)
    (&
     draw
      (| all ([]
       (| translate (&
        by (:
         glyph (list-get layouted (.anchor cursor))
         (& x (.x glyph) y (.y glyph)))
        what (.draw (colored cursor-color (empty-box 5. 10.)))))
       (| all
        (iter->array
         (map (list->iter layouted) (\ (glyph)
          (| translate (&
           by (& x (.x glyph) y (.y glyph))
           what (draw-glyph (.glyph glyph) color)))))))))
     width
      (fold
       (map (list->iter layouted) (\ (glyph) (f+ (.x glyph) (.width (.glyph glyph))))) 0. f-max)
     height
      (fold
       (map (list->iter layouted) (\ (glyph) (f+ (.y glyph) line-height))) 0. f-max))))

 draw-cursor (\ (cursor width layouted-text)
  (if (cursor-has-selection? cursor)
   (:
    start (cursor-start cursor)
    end (cursor-end cursor)
    start-position
     (if (= start 0)
      (& x 0. y 0.)
      (: layout (list-get layouted-text (- start 1))
       (point (.x layout) (.y layout))))
    end-position
     (: layout (list-get layouted-text (- end 1))
      (point (.x layout) (.y layout)))
    start-x (.x start-position)
    start-y (.y start-position)
    end-x (.x end-position)
    end-y (.y end-position)
    (if (= start-y end-y)
     (| fill-path (&
      path ([]
       (| move-to start-position)
       (| line-to (point (.x end-position) start-y))
       (| line-to (point (.x end-position) (f+ start-y line-height)))
       (| line-to (point (.x start-position) (f+ start-y line-height))))
      color cursor-color))
     (| fill-path (&
      path ([]
       (| move-to start-position)
       (| line-to (point width start-y))
       (| line-to (point width end-y))
       (| line-to end-position)
       (| line-to (point end-x (f+ end-y line-height)))
       (| line-to (point 0. (f+ end-y line-height)))
       (| line-to (point 0. (f+ start-y line-height)))
       (| line-to (point start-x (f+ start-y line-height))))
      color cursor-color))))
   (:
    offset (.anchor cursor)
    position (if (= offset 0) (& x 0. y 0.) (list-get layouted-text (- offset 1)))
    x (.x position)
    y (.y position)
    (| fill-path (&
     path ([]
      (| move-to (point x y))
      (| line-to (point (f+ x 2.) y))
      (| line-to (point (f+ x 2.) (f+ y line-height)))
      (| line-to (point x (f+ y line-height))))
     color cursor-color)))))

 maybe-render-cursor (\ (enabled node)
  (if enabled (colored cursor-color node) node))
 maybe-render-trailing-cursor (\ (enabled node)
  (if enabled
   (sized-box
    (.width node)
    (.height node)
    (stack ([]
     (padding (& top 0. left (.width node) bottom 0. right 0.)
      (colored cursor-color (empty-box 2. line-height)))
     node)))
   node))
 maybe-render-parenthesized (\ (enabled color child)
  (if enabled
   (row ([]
    (text "(" color)
    (empty-box 1. 0.)
    child
    (empty-box 1. 0.)
    (text ")" color)))
   child))

 action-up? (\ (key) (or (key-up? key) (key-space? key)))
 action-down? (\ (key) (key-down? key))
 action-left? (\ (key) (key-left? key))
 action-right? (\ (key) (key-right? key))
 action-new? (\ (key) (key-enter? key))
 action-remove? (\ (key) (key-backspace? key))
 action-delete? (\ (key) (key-delete? key))
 action-swap-left? (\ (key) (key-alt-left? key))
 action-swap-right? (\ (key) (key-alt-right? key))

 is-identifier-char? (\ (char)
  (and-4 (!= char " ") (!= char "\n") (!= char "(") (!= char ")")))
 identifier-handle (\ (identifier event)
  (% event
   (pressed-key key)
    (cond
     (action-up? key) (| yield-focus identifier)
     else (| update (handle-text-edit identifier event)))
   (char char)
    (if (= char " ")
     (| yield-focus identifier)
     (if (is-identifier-char? char)
      (| update (handle-text-edit identifier event))
      (| update identifier)))))
 identifier-render (\ (identifier color focused)
  (if (= identifier "")
   (sized-box 5. line-height
   (padding (& top 4. left 0. right 0. bottom 0.)
    (colored (if focused cursor-color color) (empty-box 5. 5.))))
   (maybe-render-trailing-cursor focused (text identifier color))))

 new-code-node-from-char (\ (char)
  (:
   c (ascii-char char)
   (cond
    (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
     (| some (| int (& int (- c (ascii-char "0")) focus (| inside))))
    (= char "&") (| some (| struct (& fields ([]) focus (| at-start))))
    (= char "|")
     (| some (| enum (& variant "" payload (| none) focus (| in-variant))))
    (= char "[") (| some (| array (& items ([]) focus (| at-start))))
    (= char "\\")
     (| some
      (| function (&
       arguments ([])
       body (| hole)
       focus (| at-start))))
    (= char "(")
     (| some
      (| call (&
       function (| hole)
       arguments ([])
       focus (| at-function))))
    (= char "%")
     (| some
      (| switch (&
       condition (| hole)
       cases ([])
       focus (| at-condition))))
    (= char "?")
     (| some
      (| if (&
       condition (| hole)
       then (| hole)
       else (| hole)
       focus (| at-condition))))
    (= char "\"")
     (| some (| string (& value "" focus (| inside))))
    (= char " ") (| none)
    (= char "\n") (| none)
    else (| some (| name (& name char focus (| inside)))))))

 new-root (\ (name code) (| root (& name name code code focus (| at-code))))
 new-root-in-name (\ (name code)
  (| root (& name name code code focus (| in-name))))
 root-handle (\ (code-focus code-handle state event)
  (:
   name (.name state)
   code (.code state)
   (% (.focus state)
    at-name
     (% event
      (pressed-key key)
       (cond
        (action-up? key) (| done (| root (& name name code code)))
        (action-down? key)
         (| update (| root (& name name code code focus (| in-name))))
        (action-right? key)
         (| update (| root (& name name code code focus (| at-code))))
        else (| no-change))
      (char char) (| no-change))
    at-code
     (% event
      (pressed-key key)
       (cond
        (action-up? key) (| done (| root (& name name code code)))
        (action-down? key)
         (% code
          (hole h) (| no-change)
          _ (| update
             (| root (& name name code (code-focus code) focus (| in-code)))))
        (action-left? key)
         (| update (| root (& name name code code focus (| at-name))))
        (action-remove? key)
         (| update (| root (& name name code (| hole) focus (| at-code))))
        else (| no-change))
      (char char)
       (% code
        (hole h)
         (% (new-code-node-from-char char)
          (some node) (| update (| root (& name name code node focus (| in-code))))
          none (| no-change))
        _ (| no-change)))
    in-name
     (% (identifier-handle name event)
      (update name)
       (| update (| root (& name name code code focus (| in-name))))
      (yield-focus name)
       (| update (| root (& name name code code focus (| at-name)))))
    in-code
     (% (code-handle code)
      no-change (| no-change)
      (update code)
       (| update (| root (& name name code code focus (| in-code))))
      (yield-focus code)
       (| update (| root (& name name code code focus (| at-code))))
      delete
       (| update
        (| root
         (& name name code (| hole) focus (| at-code))))))))
 root-render (\ (code-render state width)
  (column ([]
   (maybe-render-cursor (% (.focus state) at-name true _ false)
    (maybe-render-trailing-cursor (% (.focus state) in-name true _ false)
     (text (.name state) orchard-color)))
   (empty-box 0. 2.)
   (maybe-render-cursor (% (.focus state) at-code true _ false)
    (code-render (.code state) width)))))

 new-hole (\ () (| hole))
 # "Holes can never be focused or navigated into. When the cursor is at a hole
   (in the parent's at-... state), typing replaces it. The parent draws the
   cursor via maybe-render-cursor, so the hole itself always renders the same."
 hole-render-singleline (\ (state)
  (sized-box 5. line-height
   (padding (& top 4. left 0. right 0. bottom 0.)
    (colored black (empty-box 5. 5.)))))
 hole-render (\ (state) (hole-render-singleline state))

 new-int (\ (int) (| int (& int int focus (| outside))))
 int-focus (\ (state) (| int (& int (.int state) focus (| inside))))
 int-handle (\ (state event)
  (% (.focus state)
   outside (| no-change)
   inside (:
    int (.int state)
    (% event
     (pressed-key key)
      (cond
       (action-up? key) (| yield-focus (| int (& int int focus (| outside))))
       (key-backspace? key) (:
        new-int (/ int 10)
        (if (= new-int 0)
         (| delete)
         (| update (| int (& int new-int focus (| inside))))))
       else (| no-change))
     (char char) (:
      c (ascii-char char)
      (cond
       (= char " ") (| yield-focus (| int (& int int focus (| outside))))
       (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
        (| update
         (| int (& int (+ (* int 10) (- c (ascii-char "0"))) focus (| inside))))
       else (| no-change)))))))
 int-render-singleline (\ (state)
  (maybe-render-trailing-cursor (% (.focus state) inside true outside false)
   (text (int->string (.int state)) int-color)))
 int-render (\ (state) (int-render-singleline state))

 new-name (\ (name) (| name (& name name focus (| outside))))
 name-focus (\ (state) (| name (& name (.name state) focus (| inside))))
 name-handle (\ (state event)
  (% (.focus state)
   outside (| no-change)
   inside (:
    name (.name state)
    (% (identifier-handle name event)
     (yield-focus name) (| yield-focus (| name (& name name focus (| outside))))
     (update name)
      (if (= name "")
       (| delete)
       (| update (| name (& name name focus (| inside)))))))))
 name-render-singleline (\ (state)
  (identifier-render
   (.name state)
   black
   (% (.focus state) inside true outside false)))
 name-render (\ (state) (name-render-singleline state))

 new-string-node (\ (value) (| string (& value value focus (| outside))))
 string-focus (\ (state) (| string (& value (.value state) focus (| inside))))
 string-handle (\ (state event)
  (% (.focus state)
   outside (| no-change)
   inside (:
    value (.value state)
    (% event
     (pressed-key key)
      (if (action-up? key)
       (| yield-focus (| string (& value value focus (| outside))))
       (| update
        (| string (& value (handle-text-edit value event) focus (| inside)))))
     (char char)
      (| update
       (| string (& value (handle-text-edit value event) focus (| inside))))))))
 string-render-singleline (\ (state)
  (row ([]
   (text "\"" string-color)
   (maybe-render-trailing-cursor (% (.focus state) inside true outside false)
    (text (.value state) string-color))
   (text "\"" string-color))))
 string-render (\ (state) (string-render-singleline state))

 new-struct (\ (fields) (| struct (& fields fields focus (| outside))))
 struct-focus (\ (state)
  (| struct (&
   fields (.fields state)
   focus (if (= (array-length (.fields state)) 0) (| at-start) (| at-name 0)))))
 struct-handle (\ (code-focus code-handle state event)
  (:
   fields (.fields state)
   focus (.focus state)
   (% focus
    outside (| no-change)
    at-start
     (% event
      (pressed-key key)
       (cond
        (action-up? key)
         (| yield-focus (| struct (& fields fields focus (| outside))))
        (action-right? key)
         (if (= (array-length fields) 0)
          (| no-change)
          (| update (| struct (& fields fields focus (| at-name 0)))))
        else (| no-change))
      (char char) (:
       new-field (& name char value (| hole))
       (| update
        (| struct (&
         fields (array-insert fields 0 new-field)
         focus (| in-name 0))))))
    (at-name index)
     (% event
      (pressed-key key)
       (cond
        (action-up? key)
         (| yield-focus (| struct (& fields fields focus (| outside))))
        (action-down? key)
         (| update (| struct (& fields fields focus (| in-name index))))
        (action-left? key)
         (if (= index 0)
          (| update (| struct (& fields fields focus (| at-start))))
          (| update
           (| struct (& fields fields focus (| at-value (- index 1))))))
        (action-right? key)
         (| update (| struct (& fields fields focus (| at-value index))))
        (action-swap-left? key)
         (if (= index 0)
          (| no-change)
          (| update
           (| struct (&
            fields (array-swap fields index (- index 1))
            focus (| at-name (- index 1))))))
        (action-swap-right? key)
         (if (= index (- (array-length fields) 1))
          (| no-change)
          (| update
           (| struct (&
            fields (array-swap fields index (+ index 1))
            focus (| at-name (+ index 1))))))
        (action-remove? key)
         (| update
          (| struct
           (&
            fields (array-remove fields index)
            focus (if (= index 0) (| at-start) (| at-value (- index 1))))))
        (action-delete? key)
         (| update
          (| struct
           (&
            fields (array-remove fields index)
            focus
             (if (= index (- (array-length fields) 1))
              (if (= index 0) (| at-start) (| at-value (- index 1)))
              (| at-name index)))))
        else (| no-change))
      (char char) (:
       field (array-get fields index)
       (% (.value field)
        hole
         (% (new-code-node-from-char char)
          (some value)
           (| update
            (| struct (&
             fields
              (array-update fields index (& name (.name field) value value))
             focus (| in-value index))))
          none (| no-change))
        _ (| no-change))))
    (at-value index)
     (% event
      (pressed-key key)
       (cond
        (action-up? key)
         (| yield-focus (| struct (& fields fields focus (| outside))))
        (action-down? key) (:
         field (array-get fields index)
         (% (.value field)
          (hole h) (| no-change)
          _ (:
           new-field (& name (.name field) value (code-focus (.value field)))
           (| update
            (| struct (&
             fields (array-update fields index new-field)
             focus (| in-value index)))))))
        (action-left? key)
         (| update (| struct (& fields fields focus (| at-name index))))
        (action-right? key)
         (if (= index (- (array-length fields) 1))
          (| no-change)
          (| update (| struct (& fields fields focus (| at-name (+ index 1))))))
        (action-swap-left? key)
         (if (= index 0)
          (| no-change)
          (| update
           (| struct (&
            fields (:
             a-i (- index 1)
             b-i index
             a (array-get fields a-i)
             b (array-get fields b-i)
             (iter->array (map-indexed (array->iter fields)
              (\ (i field)
               (cond
                (= i a-i) (& name (.name a) value (.value b))
                (= i b-i) (& name (.name b) value (.value a))
                else field)))))
            focus (| at-value (- index 1))))))
        (action-swap-right? key)
         (if (= index (- (array-length fields) 1))
          (| no-change)
          (| update
           (| struct (&
            fields (:
             a-i index
             b-i (+ index 1)
             a (array-get fields a-i)
             b (array-get fields b-i)
             (iter->array (map-indexed (array->iter fields)
              (\ (i field)
               (cond
                (= i a-i) (& name (.name a) value (.value b))
                (= i b-i) (& name (.name b) value (.value a))
                else field)))))
            focus (| at-value (+ index 1))))))
        (action-remove? key)
         (| update
          (| struct
           (&

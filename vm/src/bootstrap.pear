  render
   (\ (state size) (:
    defs (.defs state)
    focus (.focus state)
    (% focus
     (overview index)
      (.draw
       (column ([]
        (colored orchard-color
         (sized-box (.width size) (f+ line-height 4.)
          (padding 2. (text "Orchard" white))))
        (flow (.width size)
         (iter->array
          (map-indexed
           (array->iter defs)
           (\ (i def)
            (padding 2.
             (maybe-render-cursor (= i index) (text (.name def) black))))))))))
     (in-def state)
      (.draw (padding 2. (code-render (.def state) (f- (.width size) 4.)))))))
  )

 editor-app
)


(:
 # "Nil is used whenever we don't actually want to provide a useful value.
  Functions that only have side-effects (aka they may crash or hang) return nil.
  See the assert function for an example."
 nil (&)

 # "Crashing stuff"
 crash (\ (error) (@crash error))
 assert (\ (check) (if check nil (crash "Assert failed.")))

 rec (\ (input function)
  (:
   rec (\ (rec input) (function (\ (new) (rec rec new)) input))
   (rec rec input)))
 rec-2 (\ (a b function)
  (:
   rec (\ (rec a b) (function (\ (a b) (rec rec a b)) a b))
   (rec rec a b)))
 rec-3 (\ (a b c function)
  (:
   rec (\ (rec a b c) (function (\ (a b c) (rec rec a b c)) a b c))
   (rec rec a b c)))
 rec-4 (\ (a b c d function)
  (:
   rec (\ (rec a b c d) (function (\ (a b c d) (rec rec a b c d)) a b c d))
   (rec rec a b c d)))

 true (| true)
 false (| false)

 _ (assert true)

 else true

 not (\ (a) (if a false true))
 and (\ (a b) (if a b false))
 and-3 (\ (a b c) (and (and a b) c))
 and-4 (\ (a b c d) (and (and-3 a b c) d))
 and-5 (\ (a b c d e) (and (and-4 a b c d) e))
 or (\ (a b) (if a true b))
 or-3 (\ (a b c) (or (or a b) c))
 or-4 (\ (a b c d) (or (or a b c) d))
 or-5 (\ (a b c d e) (or (or a b c d) e))

 + (\ (a b) (@add a b))
 - (\ (a b) (@subtract a b))
 * (\ (a b) (@multiply a b))
 / (\ (a b) (@divide a b))
 mod (\ (a b) (@modulo a b))
 << (\ (a b) (@shift-left a b))
 >> (\ (a b) (@shift-right a b))
 bit-and (\ (a b) (@and a b))
 bit-or (\ (a b) (@or a b))
 bit-xor (\ (a b) (@xor a b))

 compare (\ (a b) (@compare a b))
 = (\ (a b) (@equal? a b))
 != (\ (a b) (not (@equal? a b)))
 < (\ (a b) (% (compare a b) less true _ false))
 > (\ (a b) (% (compare a b) greater true _ false))
 <= (\ (a b) (% (compare a b) greater false _ true))
 >= (\ (a b) (% (compare a b) less false _ true))
 max (\ (a b) (if (> a b) a b))
 min (\ (a b) (if (< a b) a b))
 abs (\ (n) (if (< n 0) (- 0 n) n))

 f+ (\ (a b) (@f-add a b))
 f- (\ (a b) (@f-subtract a b))
 f* (\ (a b) (@f-multiply a b))
 f/ (\ (a b) (@f-divide a b))
 f-compare (\ (a b) (@f-compare a b))
 f= (\ (a b) (% (f-compare a b) equal true _ false))
 f!= (\ (a b) (% (f-compare a b) equal false _ true))
 f< (\ (a b) (% (f-compare a b) less true _ false))
 f> (\ (a b) (% (f-compare a b) greater true _ false))
 f<= (\ (a b) (% (f-compare a b) greater false _ true))
 f>= (\ (a b) (% (f-compare a b) less false _ true))
 f-max (\ (a b) (if (f> a b) a b))
 f-min (\ (a b) (if (f< a b) a b))
 int->float (\ (n) (@int->float n))
 float->int (\ (f) (@float->int f))
 f-abs (\ (n) (if (f< n 0.) (f- 0. n) n))

 array-length (\ (array) (@array-length array))
 array-get (\ (array index) (@array-get array index))
 array->list (\ (array) (@array->list array))
 list->array (\ (list) (@list->array list))

 # "Iterators. An iterator is a function that, when called, returns either
    (| empty) or (| more (& item rest))."
 list->iter (\ (list)
  (rec list (\ (rec list)
   (\ () (% list
    empty (| empty)
    (more m) (| more (& item (.item m) rest (rec (.rest m)))))))))
 array->iter (\ (array)
  (rec 0 (\ (rec i)
   (\ () (if (= i (array-length array))
    (| empty)
    (| more (& item (array-get array i) rest (rec (+ i 1)))))))))
 iter->list (\ (iter)
  (rec iter (\ (rec iter)
   (% (iter)
    empty (| empty)
    (more m) (| more (& item (.item m) rest (rec (.rest m))))))))
 iter->array (\ (iter) (list->array (iter->list iter)))

 map (\ (iter mapper)
  (rec iter (\ (rec iter)
   (\ () (% (iter)
    empty (| empty)
    (more m) (| more (& item (mapper (.item m)) rest (rec (.rest m)))))))))
 map-indexed (\ (iter mapper)
  (rec-2 iter 0 (\ (rec iter index)
   (\ () (% (iter)
    empty (| empty)
    (more m)
     (| more
      (& item (mapper index (.item m)) rest (rec (.rest m) (+ index 1)))))))))
 filter (\ (iter checker)
  (rec iter (\ (next iter)
   (\ () (rec iter (\ (seek iter)
    (% (iter)
     empty (| empty)
     (more m)
      (if (checker (.item m))
       (| more (& item (.item m) rest (next (.rest m))))
       (seek (.rest m))))))))))
 concat (\ (a b)
  (rec a (\ (rec a)
   (\ () (% (a)
    empty (b)
    (more m) (| more (& item (.item m) rest (rec (.rest m)))))))))
 concat-3 (\ (a b c) (concat a (concat b c)))
 concat-4 (\ (a b c d) (concat a (concat-3 b c d)))
 concat-5 (\ (a b c d e) (concat a (concat-4 b c d e)))
 take (\ (iter n)
  (rec-2 iter n (\ (rec iter n)
   (\ () (if (= n 0)
    (| empty)
    (% (iter)
     empty (| empty)
     (more m) (| more (& item (.item m) rest (rec (.rest m) (- n 1))))))))))
 skip (\ (iter n)
  (rec-2 iter n (\ (rec iter n)
   (\ () (if (= n 0)
    (iter)
    (% (iter)
     empty (| empty)
     (more m) ((rec (.rest m) (- n 1)))))))))
 take-while (\ (iter checker)
  (rec iter (\ (rec iter)
   (\ () (% (iter)
    empty (| empty)
    (more m)
     (if (checker (.item m))
      (| more (& item (.item m) rest (rec (.rest m))))
      (| empty)))))))
 skip-while (\ (iter checker)
  (\ () (rec iter (\ (drop iter)
   (% (iter)
    empty (| empty)
    (more m)
     (if (checker (.item m))
      (drop (.rest m))
      (| more (& item (.item m) rest (.rest m)))))))))
 generate (\ (length generator)
  (rec 0 (\ (rec i)
   (\ () (if (= i length)
    (| empty)
    (| more (& item (generator i) rest (rec (+ i 1)))))))))
 fold (\ (iter initial reducer)
  (rec-2 initial iter (\ (rec state iter)
   (% (iter)
    empty state
    (more m) (rec (reducer state (.item m)) (.rest m))))))
 reduce (\ (iter reducer)
  (% (iter)
   empty (crash "called reduce on empty iterator")
   (more m) (fold (.rest m) (.item m) reducer)))
 length (\ (iter) (fold iter 0 (\ (n it) (+ n 1))))
 any (\ (iter checker)
  (rec iter (\ (rec iter)
   (% (iter)
    empty false
    (more m) (if (checker (.item m)) true (rec (.rest m)))))))
 find (\ (iter checker)
  (rec iter (\ (rec iter)
   (% (iter)
    empty (| none)
    (more m) (if (checker (.item m)) (| some (.item m)) (rec (.rest m)))))))
 find-index (\ (iter checker)
  (rec-2 iter 0 (\ (rec iter index)
   (% (iter)
    empty (| none)
    (more m)
     (if (checker (.item m)) (| some index) (rec (.rest m) (+ index 1)))))))

 _ (assert (= (iter->array (array->iter ([] 1 2 3))) ([] 1 2 3)))
 _ (assert (= (iter->array (array->iter ([]))) ([])))
 _ (assert (= (iter->array (map (array->iter ([] 1 2 3)) (\ (x) (* x 2)))) ([] 2 4 6)))
 _ (assert (= (iter->array (map-indexed (array->iter ([] 10 20 30)) (\ (i x) (+ i x)))) ([] 10 21 32)))
 _ (assert (= (iter->array (filter (array->iter ([] 1 2 3 4)) (\ (x) (= (mod x 2) 0)))) ([] 2 4)))
 _ (assert (= (iter->array (concat (array->iter ([] 1 2)) (array->iter ([] 3 4)))) ([] 1 2 3 4)))
 _ (assert (= (iter->array (take (array->iter ([] 1 2 3 4)) 2)) ([] 1 2)))
 _ (assert (= (iter->array (skip (array->iter ([] 1 2 3 4)) 2)) ([] 3 4)))
 _ (assert (= (iter->array (take-while (array->iter ([] 1 2 3 1)) (\ (x) (< x 3)))) ([] 1 2)))
 _ (assert (= (iter->array (skip-while (array->iter ([] 1 2 3 1)) (\ (x) (< x 3)))) ([] 3 1)))
 _ (assert (= (iter->array (generate 3 (\ (i) (* i i)))) ([] 0 1 4)))
 _ (assert (= (fold (array->iter ([] 1 2 3)) 0 +) 6))
 _ (assert (= (reduce (array->iter ([] 1 2 3)) +) 6))
 _ (assert (= (length (array->iter ([] 1 2 3))) 3))
 _ (assert (any (array->iter ([] 1 2 3)) (\ (x) (= x 2))))
 _ (assert (not (any (array->iter ([] 1 2 3)) (\ (x) (= x 9)))))
 _ (assert (= (find (array->iter ([] 1 2 3)) (\ (x) (> x 1))) (| some 2)))
 _ (assert (= (find-index (array->iter ([] 1 2 3)) (\ (x) (= x 3))) (| some 2)))
 _ (assert (= (find-index (array->iter ([] 1 2 3)) (\ (x) (= x 9))) (| none)))

 filled-list (\ (length item)
  (:
   _ (assert (< length 100))
   rec (\ (rec i)
    (if (= i length) (| empty) (| more (& item item rest (rec rec (+ i 1))))))
   (rec rec 0)))
 filled-array (\ (length item) (list->array (filled-list length item)))
 list-skip (\ (list n) (iter->list (skip (list->iter list) n)))
 array-skip (\ (array n) (iter->array (skip (array->iter array) n)))
 list-take (\ (list n) (iter->list (take (list->iter list) n)))
 array-take (\ (array n) (iter->array (take (array->iter array) n)))
 list-slice (\ (list from to) (iter->list (take (skip (list->iter list) from) (- to from))))
 array-slice (\ (array from to)
  (iter->array (take (skip (array->iter array) from) (- to from))))
 list-update (\ (list index item)
  (iter->list (map-indexed (list->iter list) (\ (i it) (if (= i index) item it)))))
 array-update (\ (array index item)
  (iter->array (map-indexed (array->iter array) (\ (i it) (if (= i index) item it)))))
 list-remove (\ (list index)
  (iter->list
   (concat
    (take (list->iter list) index)
    (skip (list->iter list) (+ index 1)))))
 array-remove (\ (array index)
  (iter->array
   (concat
    (take (array->iter array) index)
    (skip (array->iter array) (+ index 1)))))
 list-insert (\ (list index item)
  (iter->list
   (concat-3
    (take (list->iter list) index)
    (list->iter (| more (& item item rest (| empty))))
    (skip (list->iter list) index))))
 array-insert (\ (array index item)
  (iter->array
   (concat-3
    (take (array->iter array) index)
    (list->iter (| more (& item item rest (| empty))))
    (skip (array->iter array) index))))
 list-get (\ (list index) (% ((skip (list->iter list) index)) (more m) (.item m)))
 list-swap (\ (list a b)
  (iter->list
   (map-indexed (list->iter list)
    (\ (i it) (if (= i a) (list-get list b) (if (= i b) (list-get list a) it))))))
 array-swap (\ (array a b)
  (iter->array
   (map-indexed (array->iter array)
    (\ (i it) (if (= i a) (array-get array b) (if (= i b) (array-get array a) it))))))
 list-reverse (\ (list)
  (rec-2 list (| empty) (\ (rec to-reverse reversed)
   (% to-reverse
    empty reversed
    (more m) (rec (.rest m) (| more (& item (.item m) rest reversed)))))))
 array-reverse (\ (array) (list->array (list-reverse (array->list array))))
 list-take-and-reverse (\ (list n)
  (rec-2 (& list list n n) (| empty) (\ (rec args reversed)
   (:
    list (.list args)
    n (.n args)
    (if (= n 0)
     reversed
     (% list
      (more m)
       (rec
        (& list (.rest m) n (- n 1))
        (| more (& item (.item m) rest reversed)))))))))

 # "Unit tests for the positional ops rebuilt on iterators."
 _ (assert (= (list-get (array->list ([] 5 6 7)) 1) 6))
 _ (assert (= (list->array (list-skip (array->list ([] 1 2 3 4)) 2)) ([] 3 4)))
 _ (assert (= (list->array (list-take (array->list ([] 1 2 3 4)) 2)) ([] 1 2)))
 _ (assert (= (list->array (list-slice (array->list ([] 1 2 3 4 5)) 1 4)) ([] 2 3 4)))
 _ (assert (= (list->array (list-update (array->list ([] 1 2 3)) 1 9)) ([] 1 9 3)))
 _ (assert (= (list->array (list-remove (array->list ([] 1 2 3)) 1)) ([] 1 3)))
 _ (assert (= (list->array (list-insert (array->list ([] 1 2 3)) 1 9)) ([] 1 9 2 3)))
 _ (assert (= (list->array (list-swap (array->list ([] 1 2 3)) 0 2)) ([] 3 2 1)))
 _ (assert (= (array-update ([] 1 2 3) 1 9) ([] 1 9 3)))
 _ (assert (= (array-remove ([] 1 2 3) 1) ([] 1 3)))
 _ (assert (= (array-insert ([] 1 2 3) 1 9) ([] 1 9 2 3)))
 _ (assert (= (array-swap ([] 1 2 3) 0 2) ([] 3 2 1)))
 _ (assert (= (array-slice ([] 1 2 3 4 5) 1 4) ([] 2 3 4)))
 _ (assert (= (array-reverse ([] 1 2 3)) ([] 3 2 1)))

 string->bytes (\ (string) (@string->bytes string))
 bytes->string (\ (bytes) (@bytes->string bytes))
 string-length (\ (string) (@array-length (string->bytes string)))
 string-concat (\ (a b)
  (bytes->string
   (iter->array
    (concat
     (array->iter (string->bytes a))
     (array->iter (string->bytes b))))))
 string-concat-3 (\ (a b c) (string-concat a (string-concat b c)))
 string-slice (\ (string from to)
  (bytes->string (array-slice (string->bytes string) from to)))
 string-replace-range (\ (string range replacement)
  (string-concat-3
   (string-slice string 0 (.start range))
   replacement
   (string-slice string (.end range) (string-length string))))
 string-remove-range (\ (string start end)
  (string-concat
   (string-slice string 0 start)
   (string-slice string end (string-length string))))
 string-remove (\ (string index)
  (string-concat
   (string-slice string 0 index)
   (string-slice string (+ index 1) (string-length string))))
 string-insert (\ (string index text)
  (string-concat-3
   (string-slice string 0 index)
   text
   (string-slice string index (string-length string))))
 ascii-char (\ (literal) (array-get (string->bytes literal) 0))
 int->string (\ (int)
  (if (= int 0)
   "0"
   (rec-2 int (| empty) (\ (rec int prev)
    (if (= 0 int)
     (bytes->string (list->array prev))
     (rec
      (/ int 10)
      (| more (& item (+ (ascii-char "0") (mod int 10)) rest prev))))))))
 bytes->chars (\ (rec bytes i)
  (if (= i (array-length bytes))
   (| empty)
   (| more (&
    item (@bytes->string ([] (array-get bytes i)))
    rest (rec rec bytes (+ i 1))))))
 bytes->chars-list (\ (bytes) (bytes->chars bytes->chars bytes 0))
 string->chars-list (\ (string) (bytes->chars-list (string->bytes string)))
 string->chars-array (\ (string) (list->array (string->chars-list string)))

 value? (\ (node) (% node value true _ false))
 bind (\ (rec mode input name value)
  (% mode
   expr
    (% input
     value input
     (name n) (if (@equal? name n) value (| name n))
     (let l)
      (| let
       (&
        name (.name l)
        definition (rec rec (| expr) (.definition l) name value)
        body (rec rec (| expr) (.body l) name value)))
     (field f)
      (| field (& of (rec rec (| expr) (.of f) name value) name (.name f)))
     (call c)
      (| call
       (&
        function (rec rec (| expr) (.function c) name value)
        arguments (rec rec (| array) (.arguments c) name value)))
     _ (crash (| todo-bind input))
    )
   array (list->array (rec rec (| list) (array->list input) name value))
   list
    (% input
     empty (| empty)
     (more m)
      (| more
       (&
        item (rec rec (| expr) (.item m) name value)
        rest (rec rec (| list) (.rest m) name value))))
   _ (crash (| unknown-bind-mode mode)))
 )
 bind (\ (input name value) (bind bind (| expr) input name value))
 optimize (\ (rec mode input)
  (% mode
   expr
    (% input
     value input
     (let let)
      (:
       name (.name let)
       definition (rec rec (| expr) (.definition let))
       (% definition
        (value v) (rec rec (| expr) (bind (.body let) name (| value v)))
        _ (:
         body (rec rec (| expr) (.body let))
         (| let (& name name definition definition body body))
        )
       )
      )
     (add args)
      (:
       left (rec rec (| expr) (.left args))
       right (rec rec (| expr) (.right args))
       (% left
        (value l)
         (% right
          (value r) (| value (@add l r))
          _ (| add (& left left right right))
         )
        _ (| add (& left left right right))))
     _ input
    )
   fun
    (@function
     (@arguments input)
     (rec
      rec
      (| expr)
      (| let
       (&
        name "@captured"
        definition (| value (@captured input))
        body (@body input))))
     nil)
  ))
 optimize (\ (function) (optimize optimize (| fun) function))

 ##### "The Render System

  When Pear code is asked to render something for the outside world, it
  communicates using drawing instructions. These are just normal Pear values.

  <drawing-instruction> =
   | nothing
   | fill-path (& path <path> color <color>)
   | translate (& by <point> what <drawing-instruction>)
   | all ([] <drawing-instruction>)

  <point> = (& x y)
  <color> = (& r <int> g <int> b <int>)

  <path> = ([] <path-segment>)
  <path-segment> =
   | move-to <point>
   | line-to <point>

  Initially, I tried to communicate with the outside world using pixel graphics.
  However, I believe that's not the right move as pixels are more difficult to
  handle in code. Having pixels (or some concept of a texture) within Pear
  requires either:
  - mutable values (which Pear doesn't have), or
  - lots of copying on every texture modification (which Pear doesn't have), or
  - a super-smart optimizing compiler (which is useful but it has the sort of
    slow-by-default-and-you-have-to-trust-the-black-box-to-work feeling I don't
    like), or
  - inefficient storage of individual pixels in trees.
  By communicating the intent on a quite high-level, we can instead make use of
  GPUs when turning the high-level drawing instructions into pixels. This is
  also similar to how Flutter works: The Dart VM is decently fast, but not super
  fast, so it just emits drawing instructions that the lower-level C++ engine
  takes and turns into pixels.

  Within Pear, rendering functions usually return structs of the form
  (& draw <drawing-instructions> width <int> height <int>) rather than just raw
  drawing instructions.

  2026-05-10: Added this comment.
 "

 # "All coordinates and sizes are floats. Colors and offsets stay ints."
 point (\ (x y) (& x x y y))
 fpoint (\ (x y) (& x (int->float x) y (int->float y)))

 parse-hex (\ (string)
  (rec-2 0 (array->list (string->bytes string)) (\ (rec value chars)
   (% chars
    empty value
    (more m) (:
     c (.item m)
     digit
      (cond
       (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
        (- c (ascii-char "0"))
       (and (>= c (ascii-char "a")) (<= c (ascii-char "f")))
        (+ (- c (ascii-char "a")) 10)
       else (crash "invalid hex char"))
     (rec (+ (* value 16) digit) (.rest m)))))))
 color (\ (hex)
  (:
   _ (assert (= (string-length hex) 7))
   _ (assert (= (string-slice hex 0 1) "#"))
   (&
    r (parse-hex (string-slice hex 1 3))
    g (parse-hex (string-slice hex 3 5))
    b (parse-hex (string-slice hex 5 7)))))

 black (color "#000000")
 white (color "#ffffff")
 red (color "#a02020")
 blue (color "#1099a0")
 green (color "#50a010")
 purple (color "#8e31a3")
 yellow (color "#ffd900")

 # "I try to name the rendering functions in a declarative way
  (e.g. row instead of render-next-to-each-other)."

 empty-box (\ (width height) (& draw (| nothing) width width height height))

 sized-box (\ (width height child)
  (& draw (.draw child) width width height height))

 colored (\ (color child)
  (:
   width (.width child)
   height (.height child)
   (&
    draw
     (| all ([]
      (| fill-path (&
       path ([]
        (| move-to (& x 0. y 0.))
        (| line-to (& x width y 0.))
        (| line-to (& x width y height))
        (| line-to (& x 0. y height)))
       color color))
      (.draw child)))
    width width
    height height)))

 # "padding accepts either a float (uniform on all sides) or a struct
   (& left right top bottom) of floats."
 padding (\ (padding child)
  (if (= (@kind padding) (| float))
   (&
    draw (| translate (& by (& x padding y padding) what (.draw child)))
    width (f+ (.width child) (f* 2. padding))
    height (f+ (.height child) (f* 2. padding)))
   (&
    draw
     (| translate (&
      by (& x (.left padding) y (.top padding))
      what (.draw child)))
    width (f+ (.width child) (f+ (.left padding) (.right padding)))
    height (f+ (.height child) (f+ (.top padding) (.bottom padding))))))

 padded-row (\ (padding children)
  (:
   res (rec-2 (array->list children) 0. (\ (rec children x)
    (% children
     empty (& draw (| empty) width 0. height 0.)
     (more m) (:
      child (.item m)
      rest (rec (.rest m) (f+ x (.width child)))
      (&
       draw
        (| more (&
         item (| translate (& by (& x x y 0.) what (.draw child)))
         rest (.draw rest)))
       width (f+ (.width child) (f+ padding (.width rest)))
       height (f-max (.height child) (.height rest)))))))
   (&
    draw (| all (list->array (.draw res)))
    width (f- (.width res) padding)
    height (.height res))))
 row (\ (children) (padded-row 0. children))

 column (\ (children)
  (:
   res (rec-2 (array->list children) 0. (\ (rec children y)
    (% children
     empty (& list (| empty) width 0. height 0.)
     (more m) (:
      child (.item m)
      rest (rec (.rest m) (f+ y (.height child)))
      (&
       list
        (| more (&
         item (| translate (& by (& x 0. y y) what (.draw child)))
         rest (.list rest)))
       width (f-max (.width child) (.width rest))
       height (f+ (.height child) (.height rest)))))))
   (&
    draw (| all (list->array (.list res)))
    width (.width res)
    height (.height res))))

 stack (\ (children)
  (&
   draw (| all (iter->array (map (array->iter children) (\ (child) (.draw child)))))
   width (fold (map (array->iter children) (\ (child) (.width child))) 0. f-max)
   height (fold (map (array->iter children) (\ (child) (.height child))) 0. f-max)
   ))

 flow (\ (max-width children)
  (:
   res
    (rec-4 (array->list children) 0. 0. 0. (\ (rec items x y line-height)
     (% items
      empty (& draws (| empty) bottom (f+ y line-height))
      (more m) (:
       child (.item m)
       wrap? (and (f> x 0.) (f> (f+ x (.width child)) max-width))
       x (if wrap? 0. x)
       y (if wrap? (f+ y line-height) y)
       line-height (if wrap? (.height child) (f-max line-height (.height child)))
       rest (rec (.rest m) (f+ x (.width child)) y line-height)
       (&
        draws
         (| more (&
          item (| translate (& by (& x x y y) what (.draw child)))
          rest (.draws rest)))
        bottom (.bottom rest))))))
   (&
    draw (| all (list->array (.draws res)))
    width max-width
    height (.bottom res))))

 parse-pixels (\ (width string)
  (:
   bytes (string->bytes string)
   row-rec (\ (rec i x)
    (: c (array-get bytes i)
     (if (= c (ascii-char "|"))
      (& cursor (+ i 1) result (filled-list (- width x) 0))
      (if (= x width)
       (crash "Pixel line too long.")
       (: rest (rec rec (+ i 1) (+ x 1))
        (&
         cursor (.cursor rest)
         result
          (| more
           (& item (if (= c (ascii-char " ")) 0 1) rest (.result rest)))))))))
   rec (\ (rec i)
    (if (= i (array-length bytes))
     (| empty)
     (: row (row-rec row-rec i 0)
      (| more
       (& item (list->array (.result row)) rest (rec rec (.cursor row)))))))
   (list->array (rec rec 0))))
 # "pixel-glyph operates on INT pixel coordinates and emits float paths."
 pixel-glyph (\ (char width string)
  (:
   pixels (parse-pixels width string)
   height (array-length pixels)
   paths (rec-2 0 0 (\ (rec x y)
    (if (= x width)
     (if (= (+ y 1) height) (| empty) (rec 0 (+ y 1)))
     (if (= (array-get (array-get pixels y) x) 1)
      (| more (&
       item ([]
        (| move-to (fpoint x y))
        (| line-to (fpoint (+ x 1) y))
        (| line-to (fpoint (+ x 1) (+ y 1)))
        (| line-to (fpoint x (+ y 1))))
       rest (rec (+ x 1) y)))
      (rec (+ x 1) y)))))
   (& char char width (int->float width) paths paths)))
 line-height 13.

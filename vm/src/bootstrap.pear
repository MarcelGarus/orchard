         (| update
          (| call (&
           function function
           arguments (array-insert arguments 0 node)
           focus (| in-argument 0))))
        none (| no-change)))
    (at-argument index)
     (% event
      (pressed-key key)
       (cond
        (key-up? key)
         (| yield-focus
          (| call (& function function arguments arguments focus (| outside))))
        (key-left? key)
         (if (= index 0)
          (| update
           (| call
            (& function function arguments arguments focus (| at-function))))
          (| update
           (| call (&
            function function
            arguments arguments
            focus (| at-argument (- index 1))))))
        (key-right? key)
         (if (= index (- (array-length arguments) 1))
          (| no-change)
          (| update
           (| call (&
            function function
            arguments arguments
            focus (| at-argument (+ index 1))))))
        (key-down? key)
         (| update
          (| call (&
           function function
           arguments
            (array-update
             arguments
             index
             (code-focus (array-get arguments index)))
           focus (| in-argument index))))
        (key-backspace? key)
         (| update
          (| call (&
           function function
           arguments (array-remove arguments index)
           focus (if (= index 0) (| at-function) (| at-argument (- index 1))))))
        (key-delete? key)
         (| update
          (| call (&
           function function
           arguments (array-remove arguments index)
           focus
            (if (= index (- (array-length arguments) 1))
             (if (= index 0) (| at-function) (| at-argument (- index 1)))
             (| at-argument index)))))
        (key-alt-left? key)
         (if (= index 0)
          (| no-change)
          (| update
           (| call (&
            function function
            arguments (array-swap arguments index (- index 1))
            focus (| at-argument (- index 1))))))
        (key-alt-right? key)
         (if (= index (- (array-length arguments) 1))
          (| no-change)
          (| update
           (| call (&
            function function
            arguments (array-swap arguments index (+ index 1))
            focus (| at-argument (+ index 1))))))
        else (| no-change))
      (char char)
       (% (new-code-node-from-char char)
        (some node)
         (| update
          (| call (&
           function function
           arguments (array-insert arguments (+ index 1) node)
           focus (| in-argument (+ index 1)))))
        none (| no-change)))
    (in-argument index)
     (% (code-handle (array-get arguments index))
      no-change (| no-change)
      (update new-argument)
       (| update
        (| call (&
         function function
         arguments (array-update arguments index new-argument)
         focus focus)))
      (yield-focus new-argument)
       (| update
        (| call (&
         function function
         arguments (array-update arguments index new-argument)
         focus (| at-argument index))))))))
 call-color function-color
 call-render-singleline (\ (code-render-singleline state space-allowed)
  (maybe-render-parenthesized
   (or (not space-allowed) (= 0 (array-length (.arguments state))))
   call-color
   (row ([]
    (maybe-render-cursor (% (.focus state) at-function true _ false)
     (code-render-singleline (.function state) false))
    (row
     (array-map-indexed (.arguments state) (\ (index argument)
      (row ([]
       (empty-box 5. 0.)
       (maybe-render-cursor
        (% (.focus state) (at-argument i) (= i index) _ false)
        (code-render-singleline argument false)))))))))))
 call-render (\ (code-render state width)
  (column ([]
   (code-render (.function state) width)
   (row ([]
    (empty-box 10. 0.)
    (rec-2 (array->list (.arguments state)) 0 (\ (rec arguments index)
     (% arguments
      empty (empty-box 0. 0.)
      (more m)
       (column ([]
        (maybe-render-cursor
         (% (.focus state) (at-argument i) (= i index) _ false)
         (code-render (.item m) (f- width 10.)))
        (empty-box 0. (% (.rest m) empty 0. more 2.))
        (rec (.rest m) (+ index 1))))))))))))

 new-folded (\ (value) (| folded value))
 folded-focus (\ (focus value)
  (focus
   (% (@kind value)
    int (new-int value)
    string (new-name value)
    struct
     (new-struct
      (array-map
       (@fields value)
       (\ (field) (& name (.name field) value (| folded (.value field))))))
    enum (new-enum (@variant value) (| some (| folded (@payload value))))
    array (new-array (array-map value (\ (item) (| folded item))))
    _ (crash (| unknown-kind value))
    )))
 folded-render-singleline (\ (state) (text "..." red))
 folded-render (\ (state) (folded-render-singleline state))

 code-focus (\ (code)
  (rec code (\ (focus code)
   (% code
    (name state) (name-focus state)
    (int state) (int-focus state)
    (struct state) (struct-focus state)
    (enum state) (enum-focus state)
    (array state) (array-focus state)
    (folded state) (folded-focus focus state)
    (function state) (function-focus focus state)
    (call state) (call-focus focus state)
    _ (crash (| todo-focus code))))))
 code-handle (\ (code event)
  (rec code (\ (handle code)
   (% code
    (root state) (root-handle code-focus handle state event)
    (name state) (name-handle state event)
    (int state) (int-handle state event)
    (struct state) (struct-handle code-focus handle state event)
    (enum state) (enum-handle code-focus handle state event)
    (array state) (array-handle code-focus handle state event)
    (function state) (function-handle code-focus handle state event)
    (call state) (call-handle code-focus handle state event)
    _ (crash (| todo-handle code))))))
 code-render-singleline (\ (code space-allowed)
  (rec-2 code space-allowed (\ (render code space-allowed)
   (% code
    (root state) (empty-box 100000000. 0.)
    (name state) (name-render-singleline state)
    (int state) (int-render-singleline state)
    (struct state) (struct-render-singleline render state space-allowed)
    (enum state) (enum-render-singleline render state space-allowed)
    (array state) (array-render-singleline render state space-allowed)
    (function state) (function-render-singleline render state space-allowed)
    (call state) (call-render-singleline render state space-allowed)
    (folded state) (folded-render-singleline state)
    _ (crash (| todo-render code))))))
 code-render (\ (code width)
  (rec-2 code width (\ (render code width)
   (:
    singleline (code-render-singleline code true)
    (if (f<= (.width singleline) width)
     singleline
     (% code
      (root state) (root-render render state width)
      (name state) (name-render state)
      (int state) (int-render state)
      (struct state) (struct-render render code-render-singleline state width)
      (enum state) (enum-render render state width)
      (array state) (array-render render state width)
      (function state) (function-render render state width)
      (call state) (call-render render state width)
      (folded state) (folded-render state)
      _ (crash (| todo-render code))))))))

 make-app (\ (initial-state render handle)
  (rec initial-state (\ (rec state)
   (&
    render (\ (size) (render state size))
    update (\ (event) (rec (handle state event)))
    state state))))

 create-editor-state (\ (name code)
  (new-root
   name
   (rec code (\ (rec code)
    (% code
     (name name) (new-name name)
     (struct struct)
      (new-struct
       (array-map struct (\ (field)
        (& name (.name field) value (rec (.value field))))))
     (function function)
      (new-function (.arguments function) (rec (.body function)))
     (call call)
      (new-call
       (rec (.function call))
       (array-map (.arguments call) (\ (argument) (rec argument))))
     _ (crash (| todo code))
     )))))
 editor-app (\ (defs)
  (make-app
   (& defs defs focus (| overview 0))
   (\ (state size) (:
    defs (.defs state)
    focus (.focus state)
    (% focus
     (overview index)
      (.draw
       (column
        (array-concat
         ([] (colored green (padding 2. (text "Orchard" black))))
         (array-map-indexed defs (\ (i def)
          (padding 2. (text (.name def) (if (= i index) green black)))))
        )))
     (in-def state)
      (.draw (padding 2. (code-render (.def state) (f- (.width size) 4.)))))))
   (\ (state event) (:
    defs (.defs state)
    focus (.focus state)
    (% focus
     (overview index)
      (% event
       (pressed-key key)
        (cond
         (key-left? key)
          (if (= index 0) state (& defs defs focus (| overview (- index 1))))
         (key-right? key)
          (if (= index (- (array-length defs) 1))
           state
           (& defs defs focus (| overview (+ index 1))))
         (key-down? key) (:
          def (array-get defs index)
          (&
           defs defs
           focus
            (| in-def (&
             index index
             def (create-editor-state (.name def) (.code def))))))
         else state
         )
       _ state)
     (in-def s) (:
      index (.index s)
      def (.def s)
      (% (code-handle def event)
       no-change state
       (update def) (& defs defs focus (| in-def (& index index def def)))))
     )))))

 notes-app (\ (notes)
  (make-app
   (& focus (| at 0) notes notes)
   (\ (state size)
    (.draw
     (colored
      (& r 170 g 200 b 150)
      (padding 2.
       (% (.focus state)
        (at index)
         (column
          (array-map-indexed
           (.notes state)
           (\ (i note)
            (text (.title note) (if (= i index) cursor-color black)))))
        (in info) (:
         note (array-get (.notes state) (.index info))
         (column ([]
          (text (.title note) red)
          (empty-box 0. 5.)
          (editable-text (.content note) black (.cursor info))))))))))
   (\ (state event)
    (:
     focus (.focus state)
     notes (.notes state)
     (% focus
      (at index)
       (% event
        (pressed-key key)
         (cond
          (key-down? key)
           (&
            focus
             (| at (if (= index (- (array-length notes) 1)) index (+ index 1)))
            notes notes)
          (key-up? key)
           (& focus (| at (if (= index 0) index (- index 1))) notes notes)
          (key-enter? key)
           (& focus (| in (& index index cursor new-cursor)) notes notes)
          else state)
        char state)
      (in info) (:
       index (.index info)
       cursor (.cursor info)
       note (array-get notes index)
       width 1000.
       (% event
        (pressed-key key)
         (if (key-escape? key)
          (& focus (| at index) notes notes)
          (:
           result
            (handle-text-edit-with-cursor (.content note) width cursor event)
           new-note (& title (.title note) content (.string result))
           (&
            focus (| in (& index index cursor (.cursor result)))
            notes (array-update notes index new-note))))
        (char c) (:
         result
          (handle-text-edit-with-cursor (.content note) width cursor event)
         new-note (& title (.title note) content (.string result))
         (&
          focus (| in (& index index cursor (.cursor result)))
          notes (array-update notes index new-note))))))))))

 calculator-app (:
  parse (\ (chars)
   (rec-2 (| expr) chars (\ (parse mode chars)
    (% mode
     tight (:
      parse-int (\ (chars)
       (rec-2 chars 0 (\ (recurse chars num)
        (% chars
         empty (& num num rest (| empty))
         (more m) (:
          c (ascii-char (.item m))
          (if (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
           (recurse (.rest m) (+ (* num 10) (- c (ascii-char "0"))))
           (& num num rest chars)))))))
      (% chars
       empty (| none)
       (more m) (:
        c (ascii-char (.item m))
        (cond
         (and (>= c (ascii-char "0")) (<= c (ascii-char "9")))
          (: res (parse-int chars)
           (| some (& term (| number (.num res)) rest (.rest res))))
         (= c (ascii-char "x")) (| some (& term (| x) rest (.rest m)))
         else (| none)))))
     multiply-divide (:
      (% (parse (| tight) chars)
       none (| none)
       (some result)
        (rec result (\ (rec so-far)
         (% (.rest so-far)
          empty (| some so-far)
          (more m) (:
           c (.item m)
           (cond
            (= c "*")
             (% (parse (| tight) (.rest m))
              none (| error "* needs operand")
              (some result)
               (rec (&
                term (| multiply (& left (.term so-far) right (.term result)))
                rest (.rest result))))
            (= c "/")
             (% (parse (| tight) (.rest m))
              none (| error "/ needs operand")
              (some result)
               (rec (&
                term (| divide (& left (.term so-far) right (.term result)))
                rest (.rest result))))
            else (| some so-far))))))))
     add-subtract (:
      (% (parse (| multiply-divide) chars)
       none (| none)
       (error e) (| error e)
       (some result)
        (rec result (\ (rec so-far)
         (% (.rest so-far)
          empty (| some so-far)
          (more m) (:
           c (.item m)
           (cond
            (= c "+")
             (% (parse (| multiply-divide) (.rest m))
              none (| error "+ needs operand")
              (error e) (| error e)
              (some result)
               (rec (&
                term (| add (& left (.term so-far) right (.term result)))
                rest (.rest result))))
            (= c "-")
             (% (parse (| multiply-divide) (.rest m))
              none (| error "- needs operand")
              (error e) (| error e)
              (some result)
               (rec (&
                term (| subtract (& left (.term so-far) right (.term result)))
                rest (.rest result))))
            else (| some so-far))))))))
     expr (parse (| add-subtract) chars)))))
  eval (\ (term)
   (rec term (\ (eval term)
    (% term
     (number n) n
     (add args) (+ (eval (.left args)) (eval (.right args)))
     (subtract args) (- (eval (.left args)) (eval (.right args)))
     (multiply args) (* (eval (.left args)) (eval (.right args)))
     (divide args) (/ (eval (.left args)) (eval (.right args)))
     ))))
  contains-x (\ (term)
   (rec term (\ (rec term)
    (% term
     number false
     x true
     (add args) (or (rec (.left args)) (rec (.right args)))
     (subtract args) (or (rec (.left args)) (rec (.right args)))
     (multiply args) (or (rec (.left args)) (rec (.right args)))
     (divide args) (or (rec (.left args)) (rec (.right args)))
     ))))
  sample (\ (term) (:
   compiled
    (@function
     ([] "x")
     (rec term (\ (rec term)
      (% term
       (number n) (| value n)
       x (| name "x")
       (add args) (| add (& left (rec (.left args)) right (rec (.right args))))
       (subtract args) (| subtract (& left (rec (.left args)) right (rec (.right args))))
       (multiply args) (| multiply (& left (rec (.left args)) right (rec (.right args))))
       (divide args) (| divide (& left (rec (.left args)) right (rec (.right args))))
       )))
     nil)
   (array-generate 100 (\ (x) (& x x y (compiled x))))))
  calculate-output (\ (input) (:
   (if (= input "")
    (| empty)
    (% (parse (string->chars-list input))
     (error error) (| error error)
     none (| error "error")
     (some result)
      (% (.rest result)
       more (| error "unparsed rest")
       empty (:
        term (.term result)
        (if (contains-x term)
         (| graph (sample term))
         (% (@sandbox 1000000 (\ () (eval (.term result))))
          timeout (| error "timeout")
          (returned n)  (| number n)
          (crashed e)  (| error e)))))))))
  (make-app
   (& input "" output (calculate-output ""))
   (\ (state size)
    (.draw
     (column ([]
      (colored (color "#cbddaa") (padding 2. (text (.input state) black)))
      (% (.output state)
       empty (colored (color "#ffc85b") (padding 2. (text "moin" black)))
       (error e) (colored (color "#ff7d7a") (padding 2. (text e white)))
       (number n)
        (colored (color "#ffc85b") (padding 2. (text (int->string n) black)))
       (graph samples) (:
        xs (list-map (array->list samples) (\ (sample) (.x sample)))
        ys (list-map (array->list samples) (\ (sample) (.y sample)))
        x-max (list-max xs)
        y-max (list-max ys)
        scale-x (f/ 100. (int->float x-max))
        scale-y (f/ 100. (int->float y-max))
        (colored (color "#9977ff")
         (sized-box 100. 100.
          (stack
           (array-map samples (\ (sample)
            (padding
             (&
              left (f* scale-x (int->float (.x sample)))
              top  (f- 100. (f* scale-y (int->float (.y sample))))
              right 0.
              bottom 0.)
             (colored white (empty-box 1. 1.))))))))))))))
   (\ (state event) (:
    input (.input state)
    output (.output state)
    (%
     (% event
      (pressed-key key)
       (cond
        (key-backspace? key)
         (if (= input "")
          (| no-change)
          (| new-input (string-slice input 0 (- (string-length input) 1))))
        else (| no-change))
      (char c) (| new-input (string-concat input c)))
     no-change state
     (new-input input) (& input input output (calculate-output input)))))))


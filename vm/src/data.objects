amd "parse-hex (\\ (string)\n  (rec-2 0 (array->list (string->bytes string)) (\\ (rec value chars)\n    (% chars\n      empty value\n      (more m) (:\n        c (.item m)\n        digit\n          (cond\n            (and (>= c (ascii-char \"0\")) (<= c (ascii-char \"9\"))) (- c (ascii-char \"0\"))\n            (and (>= c (ascii-char \"a\")) (<= c (ascii-char \"f\"))) (+ 10 (- c (ascii-char \"a\")))\n            else (crash \"invalid hex char\"))))\n        (rec (+ (* value 16) digit) (.rest m)))))"
ame (ic amd)
amf (ia ame)
amg "color (\\ (hex) (:\n  _ (assert (= (string-length hex) 7))\n  _ (assert (= (string-slice hex 0 1) \"#\"))\n  (&\n    r (parse-hex (string-slice hex 1 3))\n    g (parse-hex (string-slice hex 3 5))\n    b (parse-hex (string-slice hex 5 7)))))"

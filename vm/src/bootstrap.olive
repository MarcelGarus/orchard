            (# (%name "@words") (%object 1))))))
         (%crash (%object ('string "You can only turn words into strings.")))))
      (str= tag "string-get-word")
       (%let "@string" (rec lower :expr (.string payload))
        (%let "@index" (rec lower :expr (.index payload))
         (%if (%and (%'string? (%name "@string")) (%'int? (%name "@index")))
          (%'int
           (%load (%load-1 (%name "@string")) (%load-int (%name "@index"))))
          (%crash

          (%crash (%object ('string "You can only xor ints."))))))
      (str=7 tag "compare")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%let "result"
           (%compare (%load-int (%name "@a")) (%load-int (%name "@b")))
           (%if (%and (%name "result") (%word 1))
            (%object (| "equal" nil))
            (%if (%and (%shift-right (%name "result") (%word 1)) (%word 1))
             (%object (| "greater" nil))
             (%object (| "less" nil)))))
          (%crash (%object ('string "You can only compare ints."))))))
      (str= tag "string-to-bytes")
       (%let "@string" (rec lower :expr payload)
        (%if (%'string? (%name "@string"))
         (%flatten-to-inner
          (%new-inner (#
           (%object (# "array"))
           (%call
            (%object
             (\ (string i)
              (if (= i (* 8 (size string)))
               nil
               (: c (str-get string i)
                (if (= c 0) nil (# ('int c) (rec string (+ i 1))))))))
            (# (%load-1 (%name "@string")) (%object 0))))))
         (%crash (%object ('string "You can only turn strings into bytes.")))))
      (str= tag "bytes-to-string")
       (%let "@bytes" (rec lower :expr payload)
        (%if (%'array? (%name "@bytes"))
         (%new-inner (#
          (%object (# "string"))
          (%flatten-to-leaf
           (%call
            (%object
             (\ (bytes i)
              (: bytes-to-str-pack-rec
               (\ (bytes i shift acc)

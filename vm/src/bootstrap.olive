# "Olive: Optimizable Lisp Implementing Various Expressions"

%word (\ (w) (# "word" w))
%object (\ (o) (# "object" o))
%name (\ (n) (# "name" n))
%let (\ (name def body) (# "let" name def body))
%also (\ (ignored value) (# "also" ignored value))
%add (\ (a b) (# "add" a b))
%subtract (\ (a b) (# "subtract" a b))
%multiply (\ (a b) (# "multiply" a b))
%divide (\ (a b) (# "divide" a b))
%modulo (\ (a b) (# "modulo" a b))
%shift-right (\ (a b) (# "shift-right" a b))
%shift-left (\ (a b) (# "shift-left" a b))
%and (\ (a b) (# "and" a b))
%or (\ (a b) (# "or" a b))
%xor (\ (a b) (# "xor" a b))
%compare (\ (a b) (# "compare" a b))
%if (\ (condition then else) (# "if" condition then else))
%new-leaf (\ (words) (# "new-leaf" words))
%new-inner (\ (words) (# "new-inner" words))
%flatten-to-leaf (\ (object) (# "flatten-to-leaf" object))
%flatten-to-inner (\ (object) (# "flatten-to-inner" object))
%points (\ (object) (# "points" object))
%size (\ (object) (# "size" object))
%load (\ (object index) (# "load" object index))
%call (\ (fun args) (# "call" fun args))
%rec (\ (args) (# "rec" args))
%collect-garbage (\ (body) (# "collect-garbage" body))
%crash (\ (error) (# "crash" error))
%unreachable (\ () (# "unreachable"))

%equal? (\ (a b) (%and (%compare a b) (%word 1)))
%greater? (\ (a b) (%and (%shift-right (%compare a b) (%word 1)) (%word 1)))
%less? (\ (a b) (%and (%shift-right (%compare a b) (%word 2)) (%word 1)))
%load-0 (\ (obj) (%load obj (%word 0)))
%load-1 (\ (obj) (%load obj (%word 1)))
%load-2 (\ (obj) (%load obj (%word 2)))
%load-3 (\ (obj) (%load obj (%word 3)))

also (\ (a b) b)
also-3 (\ (a b c) c)
also-4 (\ (a b c d) d)

+ (# (# "a" "b")
 (%new-leaf (# (%add (%load-0 (%name "a")) (%load-0 (%name "b"))))))
- (# (# "a" "b")
 (%new-leaf (# (%subtract (%load-0 (%name "a")) (%load-0 (%name "b"))))))
* (# (# "a" "b")
 (%new-leaf (# (%multiply (%load-0 (%name "a")) (%load-0 (%name "b"))))))
/ (# (# "a" "b")
 (%new-leaf (# (%divide (%load-0 (%name "a")) (%load-0 (%name "b"))))))
mod (# (# "a" "b")
 (%new-leaf (# (%modulo (%load-0 (%name "a")) (%load-0 (%name "b"))))))
>> (# (# "a" "b")
 (%new-leaf (# (%shift-right (%load-0 (%name "a")) (%load-0 (%name "b"))))))
<< (# (# "a" "b")
 (%new-leaf (# (%shift-left (%load-0 (%name "a")) (%load-0 (%name "b"))))))
and (# (# "a" "b")
 (%new-leaf (# (%and (%load-0 (%name "a")) (%load-0 (%name "b"))))))
or (# (# "a" "b")
 (%new-leaf (# (%or (%load-0 (%name "a")) (%load-0 (%name "b"))))))
xor (# (# "a" "b")
 (%new-leaf (# (%xor (%load-0 (%name "a")) (%load-0 (%name "b"))))))
crash (# (# "error") (%crash (%name "error")))
false 0
true 1
and-3 (\ (a b c) (and (and a b) c))
and-4 (\ (a b c d) (and (and-3 a b c) d))
and-5 (\ (a b c d e) (and (and-4 a b c d) e))
or-3 (\ (a b c) (or (or a b) c))
or-4 (\ (a b c d) (or (or-3 a b c) d))
or-5 (\ (a b c d e) (or (or-4 a b c d) e))
or-6 (\ (a b c d e f) (or (or-5 a b c d e) f))
or-7 (\ (a b c d e f g) (or (or-6 a b c d e f) g))
or-8 (\ (a b c d e f g h) (or (or-7 a b c d e f g) h))
or-9 (\ (a b c d e f g h i) (or (or-8 a b c d e f g h) i))
or-10 (\ (a b c d e f g h i j) (or (or-9 a b c d e f g h i) j))
or-11 (\ (a b c d e f g h i j k) (or (or-10 a b c d e f g h i j) k))
or-12 (\ (a b c d e f g h i j k l) (or (or-11 a b c d e f g h i j k) l))
or-13 (\ (a b c d e f g h i j k l m) (or (or-12 a b c d e f g h i j k l) m))
not (\ (a) (- 1 a))
compare (# (# "a" "b")
 (%new-leaf (# (%compare (%load-0 (%name "a")) (%load-0 (%name "b"))))))
= (# (# "a" "b")
 (%new-leaf (#
  (%and (%compare (%load-0 (%name "a")) (%load-0 (%name "b"))) (%word 1)))))
> (# (# "a" "b")
 (%new-leaf (#
  (%and
   (%shift-right
    (%compare (%load-0 (%name "a")) (%load-0 (%name "b")))
    (%word 1))
   (%word 1)))))
< (# (# "a" "b")
 (%new-leaf (#
  (%and
   (%shift-right
    (%compare (%load-0 (%name "a")) (%load-0 (%name "b")))
    (%word 2))
   (%word 1)))))
!= (\ (a b) (not (= a b)))
>= (\ (a b) (not (< a b)))
<= (\ (a b) (not (> a b)))
odd? (\ (a) (and a 1))
even? (\ (a) (not (odd? a)))
size (# (# "object") (%new-leaf (# (%size (%name "object")))))
inner? (# (# "object") (%new-leaf (# (%points (%name "object")))))
. (# (# "index" "object") (%load (%name "object") (%load-0 (%name "index"))))
.0 (# (# "object") (%load-0 (%name "object")))
.1 (# (# "object") (%load-1 (%name "object")))
.2 (# (# "object") (%load-2 (%name "object")))
.3 (# (# "object") (%load-3 (%name "object")))
load-word (# (# "object" "index")
 (%new-leaf (# (%load (%name "object") (%load-0 (%name "index"))))))
nil (#)
nil? (\ (obj) (= 0 (size obj)))
not-nil? (\ (obj) (!= 0 (size obj)))
flatten-to-leaf (# (# "obj") (%flatten-to-leaf (%name "obj")))
flatten-to-inner (# (# "obj") (%flatten-to-inner (%name "obj")))
array-to-list-rec (\ (array i)
 (if (= i (size array)) nil (# (. i array) (rec array (+ i 1)))))
array-to-list (\ (array) (array-to-list-rec array 0))
str=-rec (\ (a b i limit)
 (if (= i limit) true (if (= (load-word a i) (load-word b i)) (rec a b (+ i 1) limit) false)))
str= (\ (a b) (if (= (size a) (size b)) (str=-rec a b 0 (size a)) false))
str=1word (\ (a b)
 (if (= (size b) 1)
  (if (= (size a) 1) (= (load-word a 0) (load-word b 0)) false)
  (crash (# "bad str=1word" b))))
str=2words (\ (a b)
 (if (= (size b) 2)
  (if (= (size a) 2)
   (and (= (load-word a 0) (load-word b 0)) (= (load-word a 1) (load-word b 1)))
   false)
  (crash (# "bad str=2words" b))))
str=1 (\ (a b) (str=1word a b))
str=2 (\ (a b) (str=1word a b))
str=3 (\ (a b) (str=1word a b))
str=4 (\ (a b) (str=1word a b))
str=5 (\ (a b) (str=1word a b))
str=6 (\ (a b) (str=1word a b))
str=7 (\ (a b) (str=1word a b))
str=8 (\ (a b) (str=1word a b))
str=9 (\ (a b) (str=2words a b))
str=10 (\ (a b) (str=2words a b))
str=11 (\ (a b) (str=2words a b))
str=12 (\ (a b) (str=2words a b))
str=13 (\ (a b) (str=2words a b))
str=14 (\ (a b) (str=2words a b))
str=15 (\ (a b) (str=2words a b))
str=16 (\ (a b) (str=2words a b))
str-get (\ (string i) (and 255 (>> (load-word string (>> i 3)) (* 8 (and i 7)))))
first-char (\ (string) (and 255 (load-word string 0)))
chars-to-str-pack-rec (\ (chars shift acc)
 (if (>= shift 64)
  (# acc chars)
  (if (nil? chars) (# acc chars) (rec (.1 chars) (+ shift 8) (+ acc (* (.0 chars) (<< 1 shift)))))))
chars-to-str-rec (\ (chars)
 (if (nil? chars) nil (: r (chars-to-str-pack-rec chars 0 0) (# (.0 r) (rec (.1 r))))))
chars-to-str (\ (chars) (flatten-to-leaf (chars-to-str-rec chars)))
str-to-chars-rec (\ (string size i)
 (if (= size i)
  nil
  (: word (load-word string i)
   (: c (and word 255) (if (= c 0) nil (# c
    (: c (and (>> word 8) 255) (if (= c 0) nil (# c
     (: c (and (>> word 16) 255) (if (= c 0) nil (# c
      (: c (and (>> word 24) 255) (if (= c 0) nil (# c
       (: c (and (>> word 32) 255) (if (= c 0) nil (# c
        (: c (and (>> word 40) 255) (if (= c 0) nil (# c
         (: c (and (>> word 48) 255) (if (= c 0) nil (# c
          (: c (and (>> word 56) 255) (if (= c 0) nil (# c
           (rec string size (+ i 1)))))))))))))))))))))))))))))
str-to-chars (\ (string) (str-to-chars-rec string (size string) 0))
list-concat (\ (a b) (if (nil? a) b (# (.0 a) (rec (.1 a) b))))
list-contains (\ (list string)
 (if (nil? list) false (if (str= (.0 list) string) true (rec (.1 list) string))))
list-remove (\ (list string)
 (if (nil? list)
  nil
  (if (str= (.0 list) string) (rec (.1 list) string) (# (.0 list) (rec (.1 list) string)))))
str-concat (\ (a b) (chars-to-str (list-concat (str-to-chars a) (str-to-chars b))))
str-concat-3 (\ (a b c)
 (chars-to-str (list-concat (str-to-chars a) (list-concat (str-to-chars b) (str-to-chars c)))))
ascii-newline 10
ascii-space 32
ascii-quote 34
ascii-open-paren 40
ascii-close-paren 41
ascii-0 48
ascii-9 57
ascii-at 64
ascii-backslash 92
ascii-n 110

# "Optimize IR"
word? (\ (ir) (str=4 (.0 ir) "word"))
object? (\ (ir) (str=6 (.0 ir) "object"))
name? (\ (ir) (str=4 (.0 ir) "name"))
let? (\ (ir) (str=3 (.0 ir) "let"))
also? (\ (ir) (str=4 (.0 ir) "also"))
add? (\ (ir) (str=3 (.0 ir) "add"))
subtract? (\ (ir) (str=8 (.0 ir) "subtract"))
multiply? (\ (ir) (str=8 (.0 ir) "multiply"))
divide? (\ (ir) (str=6 (.0 ir) "divide"))
modulo? (\ (ir) (str=6 (.0 ir) "modulo"))
shift-right? (\ (ir) (str=11 (.0 ir) "shift-right"))
shift-left? (\ (ir) (str=10 (.0 ir) "shift-left"))
and? (\ (ir) (str=3 (.0 ir) "and"))
or? (\ (ir) (str=2 (.0 ir) "or"))
xor? (\ (ir) (str=3 (.0 ir) "xor"))
compare? (\ (ir) (str=7 (.0 ir) "compare"))
if? (\ (ir) (str=2 (.0 ir) "if"))
new-leaf? (\ (ir) (str=8 (.0 ir) "new-leaf"))
new-inner? (\ (ir) (str=9 (.0 ir) "new-inner"))
flatten-to-leaf? (\ (ir) (str=15 (.0 ir) "flatten-to-leaf"))
flatten-to-inner? (\ (ir) (str=16 (.0 ir) "flatten-to-inner"))
points? (\ (ir) (str=6 (.0 ir) "points"))
size? (\ (ir) (str=4 (.0 ir) "size"))
load? (\ (ir) (str=4 (.0 ir) "load"))
call? (\ (ir) (str=4 (.0 ir) "call"))
rec? (\ (ir) (str=3 (.0 ir) "rec"))
collect-garbage? (\ (ir) (str=15 (.0 ir) "collect-garbage"))
crash? (\ (ir) (str=5 (.0 ir) "crash"))
unreachable? (\ (ir) (str=11 (.0 ir) "unreachable"))

# "Some recursive functions can operate in one of multiple modes. These are the
   modes."
:fun "fun"
:expr "expr"
:maybe-expr "maybe-expr"
:list "list"
:let "let"
:fields "fields"
:field-keys "keys"
:field-values "values"
:cases "cases"
:params "params"
else true

# ""
has-rec (\ (mode ir)
 (cond
  (= mode :expr)
   (cond
    (word? ir) false
    (object? ir) false
    (name? ir) false
    (let? ir) (if (rec :expr (.2 ir)) true (rec :expr (.3 ir)))
    (also? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (add? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (subtract? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (multiply? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (divide? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (modulo? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (shift-left? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (shift-right? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (and? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (or? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (xor? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (compare? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (load? ir) (if (rec :expr (.1 ir)) true (rec :expr (.2 ir)))
    (if? ir)
     (if (rec :expr (.1 ir))
      true
      (if (rec :expr (.2 ir)) true (rec :expr (.3 ir))))
    (new-leaf? ir) (rec :list (array-to-list (.1 ir)))
    (new-inner? ir) (rec :list (array-to-list (.1 ir)))
    (flatten-to-leaf? ir) (rec :expr (.1 ir))
    (flatten-to-inner? ir) (rec :expr (.1 ir))
    (points? ir) (rec :expr (.1 ir))
    (size? ir) (rec :expr (.1 ir))
    (collect-garbage? ir) (rec :expr (.1 ir))
    (crash? ir) (rec :expr (.1 ir))
    (call? ir) (if (rec :expr (.1 ir)) true (rec :list (array-to-list (.2 ir))))
    (rec? ir) true
    (unreachable? ir) false
    else (crash (# "unknown node in has-rec" (.0 ir))))
  (= mode :fun) (rec :expr (.1 ir))
  (= mode :list)
   (if (nil? ir) false (if (rec :expr (.0 ir)) true (rec :list (.1 ir))))
  else (crash "unknown has-rec mode")))
wrap-lets (\ (params args body)
 (if (nil? params)
  body
  (%let (.0 params) (.0 args) (rec (.1 params) (.1 args) body))))
all-words? (\ (irs)
 (if (nil? irs) true (if (word? (.0 irs)) (rec (.1 irs)) false)))
unwrap-words (\ (irs) (if (nil? irs) nil (# (.1 (.0 irs)) (rec (.1 irs)))))
all-objects? (\ (irs)
 (if (nil? irs) true (if (object? (.0 irs)) (rec (.1 irs)) false)))
unwrap-objects (\ (irs) (if (nil? irs) nil (# (.1 (.0 irs)) (rec (.1 irs)))))
bind (\ (mode name val ir)
 (cond
  (= mode :expr)
   (cond
    (word? ir) ir
    (object? ir) ir
    (name? ir) (if (str= (.1 ir) name) val ir)
    (let? ir)
     (: def (rec :expr name val (.2 ir))
      (if (str= (.1 ir) name)
       (%let (.1 ir) def (.3 ir))
       (%let (.1 ir) def (rec :expr name val (.3 ir)))))
    (also? ir) (%also (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (add? ir) (%add (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (subtract? ir)
     (%subtract (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (multiply? ir)
     (%multiply (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (divide? ir)
     (%divide (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (modulo? ir)
     (%modulo (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (shift-left? ir)
     (%shift-left (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (shift-right? ir)
     (%shift-right (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (and? ir) (%and (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (or? ir) (%or (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (xor? ir) (%xor (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (compare? ir)
     (%compare (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (load? ir) (%load (rec :expr name val (.1 ir)) (rec :expr name val (.2 ir)))
    (if? ir)
     (%if (rec :expr name val (.1 ir))
      (rec :expr name val (.2 ir))
      (rec :expr name val (.3 ir)))
    (new-leaf? ir)
     (%new-leaf (flatten-to-inner (rec :list name val (array-to-list (.1 ir)))))
    (new-inner? ir)
     (%new-inner
      (flatten-to-inner (rec :list name val (array-to-list (.1 ir)))))
    (flatten-to-leaf? ir) (%flatten-to-leaf (rec :expr name val (.1 ir)))
    (flatten-to-inner? ir) (%flatten-to-inner (rec :expr name val (.1 ir)))
    (points? ir) (%points (rec :expr name val (.1 ir)))
    (size? ir) (%size (rec :expr name val (.1 ir)))
    (collect-garbage? ir) (%collect-garbage (rec :expr name val (.1 ir)))
    (crash? ir) (%crash (rec :expr name val (.1 ir)))
    (call? ir)
     (%call
      (rec :expr name val (.1 ir))
      (flatten-to-inner (rec :list name val (array-to-list (.2 ir)))))
    (rec? ir)
     (%rec (flatten-to-inner (rec :list name val (array-to-list (.1 ir)))))
    (unreachable? ir) ir
    else (crash (# "unknown node in bind" ir)))
  (= mode :list)
   (if (nil? ir)
    nil
    (# (rec :expr name val (.0 ir)) (rec :list name val (.1 ir))))
  else (crash "bad mode in bind")))
num-usages (\ (mode name ir)
 (cond
  (= mode :expr)
   (cond
    (word? ir) 0
    (object? ir) 0
    (name? ir) (if (str= (.1 ir) name) 1 0)
    (let? ir)
     (+
      (rec :expr name (.2 ir))
      (if (str= (.1 ir) name) 0 (rec :expr name (.3 ir))))
    (also? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (add? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (subtract? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (multiply? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (divide? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (modulo? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (shift-left? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (shift-right? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (and? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (or? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (xor? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (compare? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (load? ir) (+ (rec :expr name (.1 ir)) (rec :expr name (.2 ir)))
    (if? ir)
     (+
      (rec :expr name (.1 ir))
      (+ (rec :expr name (.2 ir)) (rec :expr name (.3 ir))))
    (new-leaf? ir) (rec :list name (array-to-list (.1 ir)))
    (new-inner? ir) (rec :list name (array-to-list (.1 ir)))
    (flatten-to-leaf? ir) (rec :expr name (.1 ir))
    (flatten-to-inner? ir) (rec :expr name (.1 ir))
    (points? ir) (rec :expr name (.1 ir))
    (size? ir) (rec :expr name (.1 ir))
    (collect-garbage? ir) (rec :expr name (.1 ir))
    (crash? ir) (rec :expr name (.1 ir))
    (call? ir)
     (+ (rec :expr name (.1 ir)) (rec :list name (array-to-list (.2 ir))))
    (rec? ir) (rec :list name (array-to-list (.1 ir)))
    (unreachable? ir) 0
    else (crash (# "unknown node in bind" ir)))
   (= mode :list)
    (if (nil? ir) 0 (+ (rec :expr name (.0 ir)) (rec :list name (.1 ir))))
   else (crash "bad mode in num-usages")))
pure? (\ (mode ir)
 (cond
  (= mode :expr)
   (cond
    (word? ir) true
    (object? ir) true
    (name? ir) true
    (let? ir) (and (rec :expr (.2 ir)) (rec :expr (.3 ir)))
    (also? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (add? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (subtract? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (multiply? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (divide? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (modulo? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (shift-left? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (shift-right? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (and? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (or? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (xor? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (compare? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (load? ir) (and (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (if? ir) (and-3 (rec :expr (.1 ir)) (rec :expr (.2 ir)) (rec :expr (.3 ir)))
    (new-leaf? ir) (rec :list (array-to-list (.1 ir)))
    (new-inner? ir) (rec :list (array-to-list (.1 ir)))
    (flatten-to-leaf? ir) (rec :expr (.1 ir))
    (flatten-to-inner? ir) (rec :expr (.1 ir))
    (points? ir) (rec :expr (.1 ir))
    (size? ir) (rec :expr (.1 ir))
    (collect-garbage? ir) false
    (crash? ir) false
    (call? ir) false
    (rec? ir) false
    (unreachable? ir) true
    else (crash (# "unknown node in pure?" ir)))
  (= mode :list)
   (if (nil? ir) true (and (rec :expr (.0 ir)) (rec :list (.1 ir))))
  else (crash "bad mode in pure?")))
wrap-also (\ (list inner)
 (if (nil? list) inner (%also (.0 list) (rec (.1 list) inner))))
split-list-at (\ (list n)
 (if (= n 0)
  (# (#) (.0 list) (.1 list))
  (: rest (rec (.1 list) (- n 1))
   (# (# (.0 list) (.0 rest)) (.1 rest) (.2 rest)))))
list-append (\ (list item)
 (if (nil? list) (# item nil) (# (.0 list) (rec (.1 list) item))))
str-append-tick (\ (s) (chars-to-str (list-append (str-to-chars s) 39)))
all-names (\ (mode ir)
 (cond
  (= mode :expr)
   (cond
    (word? ir) nil
    (object? ir) nil
    (name? ir) (# (.1 ir) nil)
    (let? ir) (list-concat (rec :expr (.2 ir)) (rec :expr (.3 ir)))
    (also? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (add? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (subtract? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (multiply? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (divide? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (modulo? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (shift-left? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (shift-right? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (and? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (or? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (xor? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (compare? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (load? ir) (list-concat (rec :expr (.1 ir)) (rec :expr (.2 ir)))
    (if? ir)
     (list-concat
      (rec :expr (.1 ir))
      (list-concat (rec :expr (.2 ir)) (rec :expr (.3 ir))))
    (new-leaf? ir) (rec :list (array-to-list (.1 ir)))
    (new-inner? ir) (rec :list (array-to-list (.1 ir)))
    (flatten-to-leaf? ir) (rec :expr (.1 ir))
    (flatten-to-inner? ir) (rec :expr (.1 ir))
    (points? ir) (rec :expr (.1 ir))
    (size? ir) (rec :expr (.1 ir))
    (collect-garbage? ir) (rec :expr (.1 ir))
    (crash? ir) (rec :expr (.1 ir))
    (call? ir)
     (list-concat (rec :expr (.1 ir)) (rec :list (array-to-list (.2 ir))))
    (rec? ir) (rec :list (array-to-list (.1 ir)))
    (unreachable? ir) nil
    else (crash (# "unknown node in all-names" ir)))
  (= mode :list)
   (if (nil? ir) nil (list-concat (rec :expr (.0 ir)) (rec :list (.1 ir))))
  else (crash "bad mode in all-names")))
fresh-name (\ (name forbidden)
 (if (list-contains forbidden name)
  (rec (str-append-tick name) forbidden)
  name))
rename-for-capture (\ (params body forbidden)
 (if (nil? params)
  (# nil body)
  (: p (.0 params)
   (if (list-contains forbidden p)
    (: p2 (fresh-name p (list-concat (all-names :expr body) forbidden))
     (: body2 (bind :expr p (# "name" p2) body)
      (: rest (rec (.1 params) body2 forbidden)
       (# (# p2 (.0 rest)) (.1 rest)))))
    (: rest (rec (.1 params) body forbidden) (# (# p (.0 rest)) (.1 rest)))))))
ensure-not-capturing (\ (mode ir forbidden)
 (cond
  (= mode :expr)
   (cond
    (word? ir) ir
    (object? ir) ir
    (name? ir) ir
    (let? ir)
     (: name (.1 ir)
      (: def (rec :expr (.2 ir) forbidden)
       (if (list-contains forbidden name)
        (: new-name
         (fresh-name name (list-concat (all-names :expr (.3 ir)) forbidden))
         (: body (bind :expr name (# "name" new-name) (.3 ir))
          (%let new-name def (rec :expr body forbidden))))
        (%let name def (rec :expr (.3 ir) forbidden)))))
    (also? ir)
     (%also (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (add? ir) (%add (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (subtract? ir)
     (%subtract (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (multiply? ir)
     (%multiply (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (divide? ir)
     (%divide (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (modulo? ir)
     (%modulo (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (shift-left? ir)
     (%shift-left (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (shift-right? ir)
     (%shift-right (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (and? ir) (%and (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (or? ir) (%or (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (xor? ir) (%xor (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (compare? ir)
     (%compare (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (load? ir)
     (%load (rec :expr (.1 ir) forbidden) (rec :expr (.2 ir) forbidden))
    (if? ir)
     (%if (rec :expr (.1 ir) forbidden)
      (rec :expr (.2 ir) forbidden)
      (rec :expr (.3 ir) forbidden))
    (new-leaf? ir)
     (%new-leaf
      (flatten-to-inner (rec :list (array-to-list (.1 ir)) forbidden)))
    (new-inner? ir)
     (%new-inner
      (flatten-to-inner (rec :list (array-to-list (.1 ir)) forbidden)))
    (flatten-to-leaf? ir) (%flatten-to-leaf (rec :expr (.1 ir) forbidden))
    (flatten-to-inner? ir) (%flatten-to-inner (rec :expr (.1 ir) forbidden))
    (points? ir) (%points (rec :expr (.1 ir) forbidden))
    (size? ir) (%size (rec :expr (.1 ir) forbidden))
    (collect-garbage? ir) (%collect-garbage (rec :expr (.1 ir) forbidden))
    (crash? ir) (%crash (rec :expr (.1 ir) forbidden))
    (call? ir)
     (%call
      (rec :expr (.1 ir) forbidden)
      (flatten-to-inner (rec :list (array-to-list (.2 ir)) forbidden)))
    (rec? ir)
     (%rec (flatten-to-inner (rec :list (array-to-list (.1 ir)) forbidden)))
    (unreachable? ir) ir
    else (crash (# "unknown node in ensure-not-capturing" ir)))
  (= mode :list)
   (if (nil? ir)
    nil
    (# (rec :expr (.0 ir) forbidden) (rec :list (.1 ir) forbidden)))
  else (crash "bad mode in ensure-not-capturing")))
optimize (\ (mode ir)
 (cond
  (= mode :expr)
   (cond
    (word? ir) ir
    (object? ir) ir
    (name? ir) ir
    (let? ir)
     (: name (.1 ir)
      (: def (rec :expr (.2 ir))
       (if (or (object? def) (word? def))
        (rec :expr (bind :expr name def (.3 ir)))
        (if (name? def)
         (if (str= name (.1 def))
          (rec :expr (.3 ir))
          (: body (ensure-not-capturing :expr (.3 ir) (# (.1 def) nil))
           (rec :expr (bind :expr name def body))))
         (: num-uses (num-usages :expr name (.3 ir))
          (if (= num-uses 0)
           (if (pure? :expr def)
            (rec :expr (.3 ir))
            (%also def (rec :expr (.3 ir))))
           (if (and (= num-uses 1) (pure? :expr def))
            (: free-names (all-names :expr def)
             (: body (ensure-not-capturing :expr (.3 ir) free-names)
              (rec :expr (bind :expr name def body))))
            (%let name def (rec :expr (.3 ir))))))))))
    (also? ir)
     (: ignored (rec :expr (.1 ir))
      (if (pure? :expr ignored)
       (rec :expr (.2 ir))
       (%also ignored (rec :expr (.2 ir)))))
    (add? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir))
       (if (and (word? left) (word? right))
        (%word (+ (.1 left) (.1 right)))
        (%add left right))))
    (subtract? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir))
       (if (and (word? left) (word? right))
        (%word (- (.1 left) (.1 right)))
        (%subtract left right))))
    (multiply? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir))
       (if (and (word? left) (word? right))
        (%word (* (.1 left) (.1 right)))
        (%multiply left right))))
    (divide? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir)) (%divide left right)))
    (modulo? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir)) (%modulo left right)))
    (shift-left? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir)) (%shift-left left right)))
    (shift-right? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir))
       (if (and (word? left) (word? right))
        (%word (>> (.1 left) (.1 right)))
        (%shift-right left right))))
    (and? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir))
       (if (word? left)
        (if (word? right) (%word (and (.1 left) (.1 right))) (%and left right))
        (%and left right))))
    (or? ir)
     (: left (rec :expr (.1 ir)) (: right (rec :expr (.2 ir)) (%or left right)))
    (xor? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir)) (%xor left right)))
    (compare? ir)
     (: left (rec :expr (.1 ir))
      (: right (rec :expr (.2 ir))
       (if (and (word? left) (word? right))
        (%word (compare (.1 left) (.1 right)))
        (%compare left right))))
    (if? ir)
     (: condition (rec :expr (.1 ir))
      (if (word? condition)
       (if (.1 condition) (rec :expr (.2 ir)) (rec :expr (.3 ir)))
       (: then (rec :expr (.2 ir))
        (: else (rec :expr (.3 ir)) (%if condition then else)))))
    (new-leaf? ir)
     (: words (rec :list (array-to-list (.1 ir)))
      (if (all-words? words)
       (%object (flatten-to-leaf (unwrap-words words)))
       (%new-leaf (flatten-to-inner words))))
    (new-inner? ir)
     (: children (rec :list (array-to-list (.1 ir)))
      (if (all-objects? children)
       (%object (flatten-to-inner (unwrap-objects children)))
       (%new-inner (flatten-to-inner children))))
    (flatten-to-leaf? ir) (: arg (rec :expr (.1 ir)) (%flatten-to-leaf arg))
    (flatten-to-inner? ir) (: arg (rec :expr (.1 ir)) (%flatten-to-inner arg))
    (points? ir) (: arg (rec :expr (.1 ir)) (%points arg))
    (size? ir)
     (: arg (rec :expr (.1 ir))
      (if (object? arg) (%word (size (.1 arg))) (%size arg)))
    (load? ir)
     (: object (rec :expr (.1 ir))
      (: index (rec :expr (.2 ir))
       (if (and (object? object) (word? index))
        (: obj (.1 object)
         (: idx (.1 index)
          (if (>= idx (size obj))
           (%crash (%object "unreachable load index out of bounds"))
           (if (inner? obj)
            (%object (. idx obj))
            (%word (load-word obj idx))))))
        (if (and (or (new-leaf? object) (new-inner? object)) (word? index))
         (: children (.1 object)
          (: n (.1 index)
           (if (>= n (size children))
            (%crash (%object "unreachable load index out of bounds"))
            (: split
             (split-list-at (array-to-list children) n)
             (: fresh
              (fresh-name "loaded" (all-names :list (.2 split)))
              (rec
               :expr
               (wrap-also
                (.0 split)
                (%let
                 fresh
                 (.1 split)
                 (wrap-also (.2 split) (%name fresh))))))))))
         (%load object index)))))
    (call? ir)
     (: fun (rec :expr (.1 ir))
      (: args (rec :list (array-to-list (.2 ir)))
       (if (object? fun)
        (: fun (.1 fun)
         (if (= (size fun) 2)
          (if (!= (size (.2 ir)) (size (.0 fun)))
           (%crash (%object (# "unreachable num args doesn't match" ir fun)))
           (if (has-rec :fun fun)
            (%call (%object fun) (flatten-to-inner args))
            (: renamed
             (rename-for-capture
              (array-to-list (.0 fun))
              (.1 fun)
              (all-names :list args))
             (rec :expr (wrap-lets (.0 renamed) args (.1 renamed))))))
          (%crash "unreachable fun is not a fun")))
        (%call fun (flatten-to-inner args)))))
    (rec? ir)
     (: args (rec :list (array-to-list (.1 ir)))
      (%rec (flatten-to-inner args)))
    (collect-garbage? ir) (%collect-garbage (rec :expr (.1 ir)))
    (crash? ir) (: error (rec :expr (.1 ir)) (%crash error))
    (unreachable? ir) ir
    else (# "unknown node in optimize" (.0 ir)))
  (= mode :fun) (# (.0 ir) (rec :expr (.1 ir)))
  (= mode :list) (if (nil? ir) nil (# (rec :expr (.0 ir)) (rec :list (.1 ir))))
  else (crash "bad mode in optimize")))

# "Next up is code that can compile this Olive file. This makes Olive
 self-hosted. More important, unlike the Olive compiler written in raw objects
 (bootstrap.olive), this compiler is optimizing, so it can compile itself into
 a faster compiler."

# "Parsing"
is-digit (\ (char) (and (>= char ascii-0) (<= char ascii-9)))
is-name (\ (char)
 (and-5
  (!= char ascii-newline)
  (!= char ascii-space)
  (!= char ascii-open-paren)
  (!= char ascii-close-paren)
  (!= char ascii-quote)))
consume-whitespace (\ (input)
 (if (nil? input)
  nil
  (: c (.0 input)
   (if (or (= c ascii-newline) (= c ascii-space)) (rec (.1 input)) input))))
parse-string-rec (\ (input)
 (if (nil? input) (crash "string doesn't end")
  (: c (.0 input)
   (cond
    (= c ascii-quote) (# (.1 input) nil)
    (= c ascii-backslash)
     (: t (.1 input)
      (if (nil? t) (crash "expected escape char")
       (: escaped (.0 t)
        (: escaped
         (cond
          (= escaped ascii-backslash) ascii-backslash
          (= escaped ascii-quote) ascii-quote
          (= escaped ascii-n) ascii-newline
          else (crash "unknown escape sequence"))
         (: res (rec (.1 t)) (# (.0 res) (# escaped (.1 res))))))))
    else (: res (rec (.1 input)) (# (.0 res) (# c (.1 res))))))))
parse-int-rec (\ (input num)
 (if (nil? input)
  (# nil num)
  (: c (.0 input)
   (if (is-digit c)
    (rec (.1 input) (+ (* num 10) (- c ascii-0)))
    (# input num)))))
parse-name-rec (\ (input)
 (if (nil? input)
  (# nil nil)
  (: c (.0 input)
   (if (is-name c)
    (: r (rec (.1 input)) (# (.0 r) (# c (.1 r))))
    (# input nil)))))
parse (\ (mode input)
 (if (= mode :list)
  (: r (rec :expr input)
   (if (nil? r)
    (# input nil)
    (: rest (rec :list (.0 r)) (# (.0 rest) (# (.1 r) (.1 rest))))))
  (: input (consume-whitespace input)
   (if (nil? input)
    nil
    (: c (.0 input)
     (cond
      (= c ascii-close-paren) nil
      (is-digit c) (: r (parse-int-rec input 0) (# (.0 r) (# "int" (.1 r))))
      (= c ascii-quote)
       (: r (parse-string-rec (.1 input))
        (# (.0 r) (# "string" (chars-to-str (.1 r)))))
      (= c ascii-open-paren)
       (: group-res (rec :list (.1 input))
        (: input (consume-whitespace (.0 group-res))
         (if (= (.0 input) ascii-close-paren)
          (# (.1 input) (# "group" (flatten-to-inner (.1 group-res))))
          (crash "expected closing paren"))))
      else
       (: name (parse-name-rec input)
        (# (.0 name) (# "name" (chars-to-str (.1 name)))))))))))
int? (\ (ast) (str=3 (.0 ast) "int"))
string? (\ (ast) (str=6 (.0 ast) "string"))
group? (\ (ast) (str=5 (.0 ast) "group"))
# "Note that name? is already defined for the IR, and it also works on ASTs."

# "Olive Semantics"
extract-args (\ (asts)
 (if (nil? asts)
  nil
  (#
   (: name (.0 asts) (if (name? name) (.1 name) (crash "bad arg")))
   (rec (.1 asts)))))
list-has? (\ (list name)
 (if (nil? list) false (if (str= (.0 list) name) true (rec (.1 list) name))))
globals-lookup (\ (globals name)
 (if (nil? globals)
  (crash (# "unknown name" name))
  (: global (.0 globals)
   (if (str= (.0 global) name) (.1 global) (rec (.1 globals) name)))))
compile-olive-expr (\ (mode locals globals ast)
 (cond
  (= mode :expr)
   (cond
    (name? ast)
     (: name (.1 ast)
      (if (list-has? locals name)
       (%name name)
       (%object (globals-lookup globals name))))
    (group? ast)
     (: children (.1 ast)
      (if (= (size children) 0)
       (crash "empty group")
       (if (name? (.0 children))
        (: name (.1 (.0 children))
         (cond
          (str=1 name ":")
           (if (!= (size children) 4)
            (crash "bad let")
            (: name
             (: name-ast (.1 children)
              (if (str= (.0 name-ast) "name") (.1 name-ast) (crash "bad let")))
             (%let
              name
              (rec :expr locals globals (.2 children))
              (rec :expr (# name locals) globals (.3 children)))))
          (str=2 name "if")
           (if (!= (size children) 4)
            (crash "bad if")
            (%if
             (%load-0 (rec :expr locals globals (.1 children)))
             (rec :expr locals globals (.2 children))
             (rec :expr locals globals (.3 children))))
          (str=4 name "cond")
           (if (even? (size children))
            (crash "bad cond")
            (rec :cases locals globals (.1 (array-to-list children))))
          (str=1 name "#")
           (%new-inner
            (flatten-to-inner
             (rec :list locals globals (.1 (array-to-list children)))))
          (str=1 name "\\")
           (%object
            (: args
             (: args-ast (.1 children)
              (if (str= (.0 args-ast) "group")
               (extract-args (array-to-list (.1 args-ast)))
               (crash "bad args")))
             (optimize
              :fun
              (#
               (flatten-to-inner args)
               (rec :expr args globals (.2 children))))))
          (str=3 name "rec")
           (%rec
            (flatten-to-inner
             (rec :list locals globals (.1 (array-to-list children)))))
          true
           (%call
            (rec :expr locals globals (.0 children))
            (flatten-to-inner
             (rec :list locals globals (.1 (array-to-list children)))))))
        (%call
         (rec :expr locals globals (.0 children))
         (flatten-to-inner
          (rec :list locals globals (.1 (array-to-list children))))))))
     (int? ast) (%object (.1 ast))
     (string? ast) (%object (.1 ast))
     else (crash (# "unknown node" ast)))
  (= mode :list)
   (if (nil? ast)
    nil
    (# (rec :expr locals globals (.0 ast)) (rec :list locals globals (.1 ast))))
  (= mode :cases)
   (if (nil? ast)
    (%crash (%object "Reached end of cond."))
    (%if (%load-0 (rec :expr locals globals (.0 ast)))
     (rec :expr locals globals (.0 (.1 ast)))
     (rec :cases locals globals (.1 (.1 ast)))))))
compile-olive (\ (globals asts)
 (if (nil? asts)
  (globals-lookup globals "export")
  (: name
   (: name (.0 asts)
    (if (str= (.0 name) "name") (.1 name) (crash "expected def name")))
   (: rest (.1 asts)
    (if (nil? rest)
     (crash "expected def")
     (: ir (compile-olive-expr :expr nil globals (.0 rest))
      (: value ((# (#) ir)) (rec (# (# name value) globals) (.1 rest)))))))))

# "Stuff for working with Pear values."
'int (\ (value) (# (# "int") value))
'string (\ (string) (# (# "string") string))
&-names-rec (\ (rec arr i)
 (if (>= i (size arr)) nil (# (. i arr) (rec rec arr (+ i 2)))))
&-values-rec (\ (rec arr i)
 (if (>= i (size arr)) nil (# (. i arr) (rec rec arr (+ i 2)))))
& (\ (pairs)
 (: names (&-names-rec &-names-rec pairs 0)
  (: values (&-values-rec &-values-rec pairs 1)
   (: type-tag (flatten-to-inner (# "struct" names))
    (flatten-to-inner (# type-tag values))))))
&1 (\ (k1 v1) (# (# "struct" k1) v1))
&2 (\ (k1 v1 k2 v2) (# (# "struct" k1 k2) v1 v2))
&3 (\ (k1 v1 k2 v2 k3 v3) (# (# "struct" k1 k2 k3) v1 v2 v3))
| (\ (variant payload) (# (# "enum" variant) payload))
'array (\ (items) (flatten-to-inner (# (# "array") items)))
'nil (# (# "struct") )
'\ (\ (args jam instructions) (# (# "lambda") instructions 'nil args jam))
'none (| "none" 'nil)
'some (\ (payload) (| "some" payload))
'true (| "true" 'nil)
'false (| "false" 'nil)
kind (\ (value) (.0 (.0 value)))
'int? (\ (value) (str=3 (kind value) "int"))
'string? (\ (value) (str=6 (kind value) "string"))
'struct? (\ (value) (str=6 (kind value) "struct"))
'enum? (\ (value) (str=4 (kind value) "enum"))
'some? (\ (value) (if ('enum? value) (str=4 (.1 (.0 value)) "some") false))
'none? (\ (value) (if ('enum? value) (str=4 (.1 (.0 value)) "none") false))
'array? (\ (value) (str=5 (kind value) "array"))
'function? (\ (value) (str=8 (kind value) "function"))
field-rec (\ (fields i limit name)
 (if (= i limit)
  (crash ('string (str-concat-3 "Field " name " doesn't exist.")))
  (if (str= (. i fields) name) i (rec fields (+ i 1) limit name))))
field (\ (struct name)
 (. (field-rec (.0 struct) 1 (size (.0 struct)) name) struct))
.arguments (\ (struct) (field struct "arguments"))
.array (\ (struct) (field struct "array"))
.body (\ (struct) (field struct "body"))
.captured (\ (struct) (field struct "captured"))
.cases (\ (struct) (field struct "cases"))
.condition (\ (struct) (field struct "condition"))
.default (\ (struct) (field struct "default"))
.definition (\ (struct) (field struct "definition"))
.function (\ (struct) (field struct "function"))
.index (\ (struct) (field struct "index"))
.item (\ (struct) (field struct "item"))
.left (\ (struct) (field struct "left") struct)
.name (\ (struct) (field struct "name"))
.of (\ (struct) (field struct "of"))
.payload (\ (struct) (field struct "payload"))
.rest (\ (struct) (field struct "rest"))
.right (\ (struct) (field struct "right"))
.string (\ (struct) (field struct "string"))
.value (\ (struct) (field struct "value"))
.variant (\ (struct) (field struct "variant"))
variant (\ (enum) (.1 (.0 enum)))
payload (\ (enum) (.1 enum))
unwrap (\ (result) (.1 result))

# "Pear code is first converted into a Pear value that represents the code.
 Every expression is an enum with one of the following shapes:
 | value Value
 | name String
 | let (& name String definition Expr body Expr)
 | add (& left Expr right Expr)
 | subtract (& left Expr right Expr)
 | multiply (& left Expr right Expr)
 | divide (& left Expr right Expr)
 | modulo (& left Expr right Expr)
 | shift-left (& left Expr right Expr)
 | shift-right (& left Expr right Expr)
 | and (& left Expr right Expr)
 | or (& left Expr right Expr)
 | xor (& left Expr right Expr)
 | compare (& left Expr right Expr)
 | struct ([] (& field String value Expr) ...)
 | field (& of Expr name Expr)
 | enum (& variant String payload Expr)
 | switch
    (&
     condition Expr
     cases ([] (& variant String payload (| some String) body Expr))
     default (| some Expr))
 | array ([] Expr ...)
 | get (& array Expr index Expr)
 | function (& arguments ([] String ...) body Expr captured Expr)
 | arguments Expr
 | body Expr
 | captured Expr
 | kind Expr
"
%kind (\ (value) (%load-0 (%load-0 value)))
%'int? (\ (value)
 (%and (%compare (%load-0 (%kind value)) (%word "int")) (%word 1)))
%'string? (\ (value)
 (%and (%compare (%load-0 (%kind value)) (%word "string")) (%word 1)))
%'struct? (\ (value)
 (%and (%compare (%load-0 (%kind value)) (%word "struct")) (%word 1)))
%'enum? (\ (value)
 (%and (%compare (%load-0 (%kind value)) (%word "enum")) (%word 1)))
%'array? (\ (value)
 (%and (%compare (%load-0 (%kind value)) (%word "array")) (%word 1)))
%'function? (\ (value)
 (%and (%compare (%load-0 (%kind value)) (%word "function")) (%word 1)))
%'int (\ (int) (%new-inner (# (%object (# "int")) (%new-leaf (# int)))))
%load-int (\ (value) (%load-0 (%load-1 value)))
unwrap-args-rec (\ (items)
 (if (nil? items)
  nil
  (: item (.0 items)
   (if ('string? item)
    (# (.1 item) (rec (.1 items)))
    (crash ('string "make-function needs string arguments."))))))
unwrap-args (\ (value)
 (if ('array? value)
  (flatten-to-inner (unwrap-args-rec (.1 (array-to-list value))))
  (crash ('string "make-function needs an arguments array."))))
args-to-array-rec (\ (args)
 (if (nil? args) nil (# ('string (.0 args)) (.1 args))))
args-to-array (\ (args)
 (flatten-to-inner (# (# "array") (args-to-array-rec (array-to-list args)))))
assert (\ (check error) (if check nil (crash error)))
validate-pear (\ (mode ir vars)
 (cond
  (= mode :expr)
   (if ('enum? ir)
    (: tag (.1 (.0 ir))
     (: payload (.1 ir)
      (cond
       (str=5 tag "value") nil
       (str=4 tag "name")
        (also
         (assert ('string? payload) (| "invalid" ir))
         (assert (list-contains vars (.1 payload)) (| "not-in-scope" payload)))
       (str=3 tag "let")
        (also-4
         (assert ('struct? payload) (| "invalid" ir))
         (assert ('string? (.name payload)) (| "invalid" ir))
         (rec :expr (.definition payload) vars)
         (rec :expr (.body payload) (# (.1 (.name payload)) vars)))
       (str=6 tag "equal")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=3 tag "add")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=8 tag "subtract")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=8 tag "multiply")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=6 tag "divide")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=6 tag "modulo")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=10 tag "shift-left")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=11 tag "shift-right")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=3 tag "and")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=2 tag "or")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=3 tag "xor")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=7 tag "compare")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.left payload) vars)
         (rec :expr (.right payload) vars))
       (str=4 tag "kind") (rec :expr payload vars)
       (str= tag "string-to-bytes") (rec :expr payload vars)
       (str= tag "bytes-to-string") (rec :expr payload vars)
       (str=11 tag "make-struct") (rec :expr payload vars)
       (str=6 tag "fields") (rec :expr payload vars)
       (str=7 tag "variant") (rec :expr payload vars)
       (str=7 tag "payload") (rec :expr payload vars)
       (str=13 tag "array-to-list") (rec :expr payload vars)
       (str=13 tag "list-to-array") (rec :expr payload vars)
       (str=9 tag "arguments") (rec :expr payload vars)
       (str=8 tag "captured") (rec :expr payload vars)
       (str=4 tag "body") (rec :expr payload vars)
       (str=5 tag "crash") (rec :expr payload vars)
       (str= tag "string-get-byte")
        (also
         (rec :expr (.string payload) vars)
         (rec :expr (.index payload) vars))
       (str= tag "string-get-word")
        (also
         (rec :expr (.string payload) vars)
         (rec :expr (.index payload) vars))
       (str=6 tag "struct")
        (also
         (assert ('array? payload)
          ('string "A struct needs an array of fields."))
         (rec :fields (.1 (array-to-list payload)) vars))
       (str=5 tag "field")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.of payload) vars)
         (rec :expr (.name payload) vars))
       (str=4 tag "enum")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (assert ('string? (.variant payload))
          ('string "An enum needs a string variant."))
         (rec :expr (.payload payload) vars))
       (str=9 tag "make-enum")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.variant payload) vars)
         (rec :expr (.payload payload) vars))
       (str=6 tag "switch")
        (also-4
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.condition payload) vars)
         (: cases (.cases payload)
          (also
           (assert ('array? cases) (| "invalid" ir))
           (rec :cases (.1 (array-to-list cases)) vars)))
         (: default (.default payload)
          (if ('some? default)
           (rec :expr (.1 default) vars)
           (assert ('none? default) (| "invalid" ir)))))
       (str=5 tag "array")
        (also
         (assert ('array? payload) (| "invalid" ir))
         (rec :list (.1 (array-to-list payload)) vars))
       (str=9 tag "array-get")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.array payload) vars)
         (rec :expr (.index payload) vars))
       (str=13 tag "make-function")
        (also-4
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.arguments payload) vars)
         (rec :expr (.body payload) vars)
         (rec :expr (.captured payload) vars))
       (str=4 tag "call")
        (also-3
         (assert ('struct? payload) (| "invalid" ir))
         (rec :expr (.function payload) vars)
         (: args (.arguments payload)
          (if ('array? args)
           (rec :list (.1 (array-to-list args)) vars)
           (crash ('string "Call needs arguments array.")))))
       (str=15 tag "collect-garbage") (rec :expr payload vars)
       else (crash ('string (str-concat-3 "Unknown expression " tag "."))))))
    (crash (| "invalid" ir)))
  (= mode :list)
   (if (nil? ir) nil (also (rec :expr (.0 ir) vars) (rec :list (.1 ir) vars)))
  (= mode :fields)
   (if (nil? ir)
    nil
    (: item (.0 ir)
     (also-4
      (assert ('struct? item) ('string "Field needs to be a struct."))
      (assert ('string? (.name item))
       ('string "Field name needs to be a string."))
      (rec :expr (.value item) vars)
      (rec :fields (.1 ir) vars))))
  (= mode :cases)
   (if (nil? ir)
    nil  
    (: case (.0 ir)
     (also-4
      (assert ('struct? case) ('string "Switch cases must be structs."))
      (if ('string? (.variant case))
       nil
       (crash ('string "A case variant has to be a string.")))
      (: payload (.payload case)
       (if ('some? payload)
        (assert ('string? (.1 payload))
         ('string "A case needs a string as a payload."))
        (assert ('none? payload)
         ('string "Case payload must be some or none."))))
      (rec :expr (.body case) vars)
      (rec :cases (.1 ir) vars))))
  else (crash (# "Unknown validate mode" mode))))
lower-pear (\ (lower mode ir)
 (cond
  (= mode :expr)
   (: tag (variant ir)
    (: payload (payload ir)
     (cond
      (str=5 tag "value") (%object payload)
      (str=4 tag "name") (%name (.1 payload))
      (str=3 tag "let")
       (%let (.1 (.name payload)) (rec lower :expr (.definition payload))
        (rec lower :expr (.body payload)))
      (str=6 tag "equal")
       (%if
        (%load-0
         (%call
          (%object
           (\ (mode left right i)
            (if (= mode 0)
             (if
              (and
               (= (inner? left) (inner? right))
               (= (size left) (size right)))
              (if (inner? left) (rec 1 left right 0) (str= left right))
              false)
             (if (= i (size left))
              true
              (if (rec 0 (. i left) (. i right) 0)
               (rec 1 left right (+ i 1))
               false)))))
          (#
           (%object 0)
           (rec lower :expr (.left payload))
           (rec lower :expr (.right payload))
           (%object 0))))
        (%object 'true)
        (%object 'false))
      (str=4 tag "kind")
       (%new-inner (#
        (%new-inner (#
         (%object "enum")
         (%load-0 (%load-0 (rec lower :expr payload)))))
        (%object 'nil)))
      (str=3 tag "add")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%'int (%add (%load-int (%name "@a")) (%load-int (%name "@b"))))
          (%crash (%object ('string "You can only add ints."))))))
      (str=8 tag "subtract")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%'int (%subtract (%load-int (%name "@a")) (%load-int (%name "@b"))))
          (%crash (%object ('string "You can only subtract ints."))))))
      (str=8 tag "multiply")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%'int (%multiply (%load-int (%name "@a")) (%load-int (%name "@b"))))
          (%crash (%object ('string "You can only multiply ints."))))))
      (str=6 tag "divide")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%let "@a" (%load-int (%name "@a"))
           (%let "@b" (%load-int (%name "@b"))
            (%if (%name "@b")
             (%'int (%divide (%name "@a") (%name "@b")))
             (%crash (%object ('string "You can not divide by zero."))))))
          (%crash (%object ('string "You can only divide ints."))))))
      (str=6 tag "modulo")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%let "@a" (%load-int (%name "@a"))
           (%let "@b" (%load-int (%name "@b"))
            (%if (%name "@b")
             (%'int (%modulo (%name "@a") (%name "@b")))
             (%crash (%object ('string "You can not divide by zero."))))))
          (%crash (%object ('string "You can only modulo ints."))))))
      (str=10 tag "shift-left")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if (%and (%'int? (%name "@a")) (%'int? (%name "@b")))
          (%'int
           (%shift-left (%load-int (%name "@a")) (%load-int (%name "@b"))))
          (%crash (%object ('string "You can only shift-left ints."))))))
      (str=11 tag "shift-right")
       (%let "@a" (rec lower :expr (.left payload))
        (%let "@b" (rec lower :expr (.right payload))
         (%if
          (%and (%'int? (%name "@a")) (%'int? (%name "@b")))

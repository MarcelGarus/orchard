             (flatten-to-inner
              (list-concat (array-to-list (.1 args)) (# "@captured" nil)))
             (rec lower :expr (.1 body))))))
           (%let "@args" args
            (%let "@body" body
             (%also
              (%call (%object validate-pear) (#
               (%object :expr)
               (%name "@body")
               (%new-inner (#
                (%object "@captured")
                (%call (%object array-to-list) (# (%name "@args")))))))
              (%new-inner (#
               (%object "function")
               (%name "@args")
               (%name "@body")
               (%call (%object lower) (#
                (%object lower)
                (%object :expr)
                (%name "@body")))))))))))
        (rec lower :expr (.captured payload))))
      (str=4 tag "call")
       (: args (.arguments payload)
        (%let "@a" (rec lower :expr (.function payload))
         (%if (%'function? (%name "@a"))
          (%if
           (%equal?
            (%size (%load-1 (%load-0 (%name "@a"))))
            (%word (- (size args) 1)))
           (%call
            (%load-3 (%load-0 (%name "@a")))
            (flatten-to-inner
             (list-concat
              (rec lower :list (.1 (array-to-list args)))
              (# (%load-1 (%name "@a")) nil))))
           (%crash (%object ('string "Wrong number of arguments."))))
          (%crash (%object ('string "You can only call functions."))))))
      (str=9 tag "arguments")
       (%let "@fun" (rec lower :expr payload)
        (%if (%'function? (%name "@fun"))
         (%call (%object args-to-array) (# (%load-1 (%load-0 (%name "@fun")))))
         (%crash (%object ('string "Arguments needs a function.")))))
      (str=4 tag "captured")
       (%let "@fun" (rec lower :expr payload)
        (%if (%'function? (%name "@fun"))
         (%load-1 (%name "@fun"))
         (%crash (%object ('string "Captured needs a function.")))))
      (str=4 tag "body")
       (%let "@fun" (rec lower :expr payload)
        (%if (%'function? (%name "@fun"))
         (%load-2 (%load-0 (%name "@fun")))
         (%crash (%object ('string "@body needs a function.")))))
      (str=5 tag "crash") (%crash (rec lower :expr payload))
      (str=15 tag "collect-garbage")
       (%collect-garbage
        (%let "@a" (rec lower :expr payload)
         (%if (%'function? (%name "@a"))
          (%if (%size (%load-1 (%load-0 (%name "@a"))))
           (%crash
            (%object
             ('string
              "@collect-garbage expects a function that takes no arguments.")))
           (%call
            (%load-3 (%load-0 (%name "@a")))
            (# (%load-1 (%name "@a")))))
          (%crash (%object ('string "@collect-garbage expects a function."))))))
      else (crash (# "todo lower-pear" ir)))))
  (= mode :list)
   (if (nil? ir) nil (# (rec lower :expr (.0 ir)) (rec lower :list (.1 ir))))
  (= mode :field-keys)
   (if (nil? ir) nil (# (.1 (.name (.0 ir))) (rec lower :field-keys (.1 ir))))
  (= mode :field-values)
   (if (nil? ir)
    nil
    (# (rec lower :expr (.value (.0 ir))) (rec lower :field-values (.1 ir))))
  (= mode :cases)
   (: cases (.0 ir)
    (: default (.1 ir)
     (if (nil? cases)
      (if ('some? default)
       (rec lower :expr (.1 default))
       (%crash (%object ('string "Unhandled variant."))))
      (: case (.0 cases) 
       (: variant (.variant case)
        (: payload (.payload case)
         (: body (.body case)
          (%if
           (%load-0
            (%call (%object str=) (#
             (%load-1 (%load-0 (%name "@condition")))
             (%object (.1 variant)))))
           (if ('some? payload)
            (%let (.1 (.1 payload)) (%load-1 (%name "@condition"))
             (rec lower :expr body))
            (rec lower :expr body))
           (rec lower :cases (# (.1 cases) default))))))))))
  true (crash (# "todo mode" mode))))
lower-pear (\ (mode ir) (lower-pear lower-pear mode ir))
find-captured (\ (mode ir bound captured)
 (cond
  (= mode :expr)
   (: tag (variant ir)
    (: payload (payload ir)
     (cond
      (str= tag "value") captured
      (str= tag "name")
       (: name (unwrap payload)
        (if (list-contains bound name)
         captured
         (if (list-contains captured name) captured (# name captured))))
      (str= tag "let")
       (rec :expr (.definition payload) bound
        (rec :expr (.body payload) (# (.1 (.1 (.1 ir))) bound) captured))
      (str=6 tag "equal")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=3 tag "add")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=8 tag "subtract")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=8 tag "multiply")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=6 tag "divide")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=6 tag "modulo")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=10 tag "shift-left")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=11 tag "shift-right")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=3 tag "and")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=2 tag "or")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=3 tag "xor")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=7 tag "compare")
       (rec :expr (.left payload) bound
        (rec :expr (.right payload) bound captured))
      (str=4 tag "kind") (rec :expr payload bound captured)
      (str=11 tag "make-struct") (rec :expr payload bound captured)
      (str=6 tag "fields") (rec :expr payload bound captured)
      (str=7 tag "variant") (rec :expr payload bound captured)
      (str=7 tag "payload") (rec :expr payload bound captured)
      (str=13 tag "array-to-list") (rec :expr payload bound captured)
      (str=13 tag "list-to-array") (rec :expr payload bound captured)
      (str=9 tag "arguments") (rec :expr payload bound captured)
      (str=8 tag "captured") (rec :expr payload bound captured)
      (str=4 tag "body") (rec :expr payload bound captured)
      (str=5 tag "crash") (rec :expr payload bound captured)
      (str= tag "struct")
       (rec :fields (.1 (array-to-list payload)) bound captured)
      (str= tag "field")
       (rec :expr (.of payload) bound
        (rec :expr (.name payload) bound captured))
      (str= tag "enum") (rec :expr (.payload payload) bound captured)
      (str= tag "switch")
       (rec :expr (.condition payload) bound
        (rec :cases (.1 (array-to-list (.cases payload))) bound
         (rec :maybe-expr (.default payload) bound captured)))
      (str= tag "make-enum")
       (rec :expr (.variant payload) bound
        (rec :expr (.payload payload) bound captured))
      (str= tag "array")
       (rec :list (.1 (array-to-list payload)) bound captured)
      (str= tag "array-length") (rec :expr payload bound captured)
      (str= tag "array-get")
       (rec :expr (.array payload) bound
        (rec :expr (.index payload) bound captured))
      (str= tag "make-function")
       (rec :expr (.arguments payload) bound
        (rec :expr (.captured payload) bound
         (rec :expr (.body payload) bound captured)))
      (str= tag "call")
       (rec :expr (.function payload) bound
        (rec :list (.1 (array-to-list (.arguments payload))) bound captured))
      (str= tag "crash") (rec :expr payload bound captured)
      true (crash (# "todo find-captured" ir)))))
  (= mode :maybe-expr)
   (if ('some? ir) (rec :expr (.1 ir) bound captured) captured)
  (= mode :list)
   (if (nil? ir)
    captured
    (rec :expr (.0 ir) bound (rec :list (.1 ir) bound captured)))
  (= mode :fields)
   (if (nil? ir)
    captured
    (rec :expr (.value (.0 ir)) bound (rec :fields (.1 ir) bound captured)))
  (= mode :cases)
   (if (nil? ir)
    captured
    (: case (.0 ir)
     (rec :cases (.1 ir) bound
      (if ('some? (.payload case))
       (rec :expr (.body case) (# (.1 (.1 (.payload case))) bound) captured)
       (rec :expr (.body case) bound captured)))))
  true (crash (# "bad find-captured mode" mode))))
wrap-params (\ (params)
 (if (nil? params) nil (# ('string (.0 params)) (rec (.1 params)))))
wrap-with-captured (\ (ir captured)
 (if (nil? captured)
  ir
  (: name (.0 captured)
   (| "let"
    (&3
     "name" ('string name)
     "definition"
      (| "field"
       (&2
        "of" (| "name" ('string "@captured"))
        "name" (| "value" ('string name))))
     "body" (rec ir (.1 captured)))))))
create-captured-values (\ (captured)
 (if (nil? captured)
  nil
  (#
   (&2
    "name" ('string (.0 captured))
    "value" (| "name" ('string (.0 captured))))
   (rec (.1 captured)))))
create-captured-struct (\ (captured)
 (| "struct"
  (flatten-to-inner (# (# "array") (create-captured-values captured)))))
analyze-pear (\ (mode ast)
 (cond
  (= mode :expr)
   (cond
    (name? ast) (| "name" ('string (.1 ast)))
    (group? ast)
     (: children (.1 ast)
      (: first (if (nil? children) (crash "empty group") (.0 children))
       (: rest (.1 (array-to-list children))
        (if (name? first)
         (: name (.1 first)
          (cond
           (str=1 name ":")
            (if (odd? (size children)) (crash "bad let") (rec :let rest))
           (str=2 name "[]") (| "array" ('array (rec :list rest)))
           (str=1 name "&") (| "struct" ('array (rec :fields rest)))
           (= (first-char name) ".")
            (if (!= (size children) 2)
             (crash "bad field")
             (| "field"
              (&2
               "of" (rec :expr (.1 children))
               "name"
                (| "value" ('string (chars-to-str (.1 (str-to-chars name))))))))
           (str=1 name "|")
            (| "enum"
             (if (< (size children) 2)
              (crash "bad enum")
              (: variant
               (if (name? (.1 children))
                ('string (.1 (.1 children)))
                (crash "bad enum"))
               (if (= (size children) 2)
                (&2 "variant" variant "payload" (| "value" 'nil))
                (if (= (size children) 3)
                 (&2 "variant" variant "payload" (rec :expr (.0 (.1 rest))))
                 (crash "bad enum"))))))
           (str=1 name "%")
            (if (odd? (size children))
             (crash "bad switch")
             (: condition (rec :expr (.1 children))
              (: cases (rec :cases (.1 rest))
               (| "switch"
                (&3
                 "condition" condition
                 "cases" ('array (.0 cases))
                 "default" (if (nil? (.1 cases)) 'none ('some (.1 cases))))))))
           (str=1 name "\\")
            (if (!= (size children) 3)
             (crash "bad function")
             (: params
              (if (group? (.1 children))
               (rec :params (array-to-list (.1 (.1 children))))
               (crash "bad function"))
              (: body (rec :expr (.2 children))
               (: captured (find-captured :expr body params (#))
                (| "make-function"
                 (&3
                  "arguments"
                   (| "value"
                    (flatten-to-inner (# (# "array") (wrap-params params))))
                  "body" (| "value" (wrap-with-captured body captured))
                  "captured" (create-captured-struct captured)))))))
           (= (first-char name) "@")
            (: args (flatten-to-inner (.1 (array-to-list children)))
             (cond
              (str=7 name "@equal?")
               (if (!= (size args) 2)
                (crash "bad @equal?")
                (| "equal"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=5 name "@kind")
               (if (!= (size args) 1)
                (crash "bad @kind")
                (| "kind" (rec :expr (.0 args))))
              (str=4 name "@add")
               (if (!= (size args) 2)
                (crash "bad @add")
                (| "add"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=9 name "@subtract")
               (if (!= (size args) 2)
                (crash "bad @subtract")
                (| "subtract"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=9 name "@multiply")
               (if (!= (size args) 2)
                (crash "bad @multiply")
                (| "multiply"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=7 name "@divide")
               (if (!= (size args) 2)
                (crash "bad @divide")
                (| "divide"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=7 name "@modulo")
               (if (!= (size args) 2)
                (crash "bad @modulo")
                (| "modulo"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=11 name "@shift-left")
               (if (!= (size args) 2)
                (crash "bad @shift-left")
                (| "shift-left"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=12 name "@shift-right")
               (if (!= (size args) 2)
                (crash "bad @shift-right")
                (| "shift-right"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=4 name "@and")
               (if (!= (size args) 2)
                (crash "bad @and")
                (| "and"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=3 name "@or")
               (if (!= (size args) 2)
                (crash "bad @or")
                (| "or"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=4 name "@xor")
               (if (!= (size args) 2)
                (crash "bad @xor")
                (| "xor"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=8 name "@compare")
               (if (!= (size args) 2)
                (crash "bad @compare")
                (| "compare"
                 (&2
                  "left" (rec :expr (.0 args))
                  "right" (rec :expr (.1 args)))))
              (str=14 name "@string->bytes")
               (if (!= (size args) 1)
                (crash "bad @string->bytes")
                (| "string-to-bytes" (rec :expr (.0 args))))
              (str=14 name "@bytes->string")
               (if (!= (size args) 1)
                (crash "bad @bytes->string")
                (| "bytes-to-string" (rec :expr (.0 args))))
              (str=16 name "@string-get-byte")
               (if (!= (size args) 2)
                (crash "bad @string-get-byte")
                (| "string-get-byte"
                 (&2
                  "string" (rec :expr (.0 args))
                  "index" (rec :expr (.1 args)))))
              (str=14 name "@string->words")
               (if (!= (size args) 1)
                (crash "bad @string->words")
                (| "string-to-words" (rec :expr (.0 args))))
              (str=14 name "@words->string")
               (if (!= (size args) 1)
                (crash "bad @words->string")
                (| "words-to-string" (rec :expr (.0 args))))
              (str=16 name "@string-get-word")
               (if (!= (size args) 2)
                (crash "bad @string-get-word")
                (| "string-get-word"
                 (&2
                  "string" (rec :expr (.0 args))
                  "index" (rec :expr (.1 args)))))
              (str=7 name "@struct")
               (if (!= (size args) 1)
                (crash "bad @struct")
                (| "make-struct" (rec :expr (.0 args))))
              (str=6 name "@field")
               (if (!= (size args) 2)
                (crash "bad @field")
                (| "field"
                 (&2
                  "of" (rec :expr (.0 args))
                  "name" (rec :expr (.1 args)))))
              (str=7 name "@fields")
               (if (!= (size args) 1)
                (crash "bad @fields")
                (| "fields" (rec :expr (.0 args))))
              (str=5 name "@enum")
               (if (!= (size args) 2)
                (crash "bad @enum")
                (| "make-enum"
                 (&2
                  "variant" (rec :expr (.0 args))
                  "payload" (rec :expr (.1 args)))))
              (str=8 name "@variant")
               (if (!= (size args) 1)
                (crash "bad @variant")
                (| "variant" (rec :expr (.0 args))))
              (str=8 name "@payload")
               (if (!= (size args) 1)
                (crash "bad @payload")
                (| "payload" (rec :expr (.0 args))))
              (str=13 name "@array-length")
               (if (!= (size args) 1)
                (crash "bad @array-length")
                (| "array-length" (rec :expr (.0 args))))
              (str=10 name "@array-get")
               (if (!= (size args) 2)
                (crash "bad @array-get")
                (| "array-get"
                 (&2
                  "array" (rec :expr (.0 args))
                  "index" (rec :expr (.1 args)))))
              (str=12 name "@array->list")
               (if (!= (size args) 1)
                (crash "bad @array->list")
                (| "array-to-list" (rec :expr (.0 args))))
              (str=12 name "@list->array")
               (if (!= (size args) 1)
                (crash "bad @list->array")
                (| "list-to-array" (rec :expr (.0 args))))
              (str=9 name "@function")
               (if (!= (size args) 3)
                (crash "bad @function")
                (| "make-function"
                 (&3
                  "arguments" (rec :expr (.0 args))
                  "body" (rec :expr (.1 args))
                  "captured" (rec :expr (.2 args)))))
              (str=10 name "@arguments")
               (if (!= (size args) 1)
                (crash "bad @arguments")
                (| "arguments" (rec :expr (.0 args))))
              (str=9 name "@captured")
               (if (!= (size args) 1)
                (crash "bad @captured")
                (| "captured" (rec :expr (.0 args))))
              (str=5 name "@body")
               (if (!= (size args) 1)
                (crash "bad @body")
                (| "body" (rec :expr (.0 args))))
              (str=6 name "@crash")
               (if (!= (size args) 1)
                (crash "bad @crash")
                (| "crash" (rec :expr (.0 args))))
              (str=16 name "@collect-garbage")
               (if (!= (size args) 1)
                (crash "bad @collect-garbage")
                (| "collect-garbage" (rec :expr (.0 args))))
              else
               (crash ('string (str-concat-3 "Unknown builtin " name ".")))))
           else
            (| "call"
             (&2
              "function" (rec :expr first)
              "arguments" ('array (rec :list rest))))))
         (| "call"
          (&2
           "function" (rec :expr first)
           "arguments" ('array (rec :list rest))))))))
    (int? ast) (| "value" ('int (.1 ast)))
    (string? ast) (| "value" ('string (.1 ast)))
    else (crash (# "unknown ast node" ast)))
  (= mode :list)
   (if (nil? ast) nil (# (rec :expr (.0 ast)) (rec :list (.1 ast))))
  (= mode :let)
   (if (nil? (.1 ast))
    (rec :expr (.0 ast))
    (: first (.0 ast)
     (: second (.0 (.1 ast))
      (: rest (.1 (.1 ast))
       (: name (if (name? first) (.1 first) (crash "bad let"))
        (if (str=1 name "#")
         (rec :let rest)
         (: def (rec :expr second)
          (| "let"
           (&3
            "name" ('string name)
            "definition" def
            "body" (rec :let rest))))))))))
  (= mode :fields)
   (if (nil? ast)
    nil
    (: first (.0 ast)
     (: second (.0 (.1 ast))
      (: rest (.1 (.1 ast))
       (#
        (&2
         "name" ('string (if (name? first) (.1 first) (crash "bad struct")))
         "value" (rec :expr second))
        (rec :fields rest))))))
  (= mode :cases)
   (if (nil? ast)
    (# nil nil)
    (: left (.0 ast)
     (: body (.0 (.1 ast))
      (: rest (.1 (.1 ast))
       (: variant
        (if (name? left)
         (.1 left)
         (if (group? left)
          (if (!= (size (.1 left)) 2)
           (crash "bad switch left group")
           (: variant_ast (.0 (.1 left))
            (if (name? variant_ast)
             (.1 variant_ast)
             (crash "bad switch variant"))))
          (crash "bad switch left")))
        (: payload
         (if (name? left)
          'none
          (: payload_ast (.1 (.1 left))
           (if (name? payload_ast)
            ('some ('string (.1 payload_ast)))
            (crash "bad switch payload"))))
         (if (str=1 variant "_")
          (: rest (rec :cases rest)
           (if (not-nil? (.1 rest))
            (crash "multiple default cases")
            (# (.0 rest) (rec :expr body))))
          (: rest (rec :cases rest)
           (#
            (#
             (&3
              "variant" ('string variant)
              "payload" payload
              "body" (rec :expr body))
             (.0 rest))
            (.1 rest))))))))))
  (= mode :params)
   (if (nil? ast)
    nil
    (#
     (if (name? (.0 ast)) (.1 (.0 ast)) (crash "bad function"))
     (rec :params (.1 ast))))
  else (crash (# "unknown mode" mode))))

function-with-nil-closure (\ (args pear-body compiled)
 (# (# "function" args pear-body compiled) 'nil))
export (&2
 "compile_olive"
  (function-with-nil-closure (# "code") 'nil (\ (code _)
   (compile-olive nil (.1 (parse :list (str-to-chars (.1 code)))))))
 "compile_pear"
  (function-with-nil-closure (# "code") 'nil (\ (code _)
   (: pear-ir (analyze-pear :expr (.1 (parse :expr (str-to-chars (.1 code)))))
    (also
     (validate-pear :expr pear-ir (#))
     (function-with-nil-closure (#) pear-ir (# (# "@captured")
      (optimize :expr (lower-pear :expr pear-ir)))))))))

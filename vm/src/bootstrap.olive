              (%and (%load-int (%name "@index")) (%word 7))))))
          (%crash
           (%object
            ('string "@string-get-byte needs a string and an index."))))))
      (str= tag "string-to-words")
       (%let "@string" (rec lower :expr payload)
        (%if (%'string? (%name "@string"))
         (%flatten-to-inner
          (%new-inner (#
